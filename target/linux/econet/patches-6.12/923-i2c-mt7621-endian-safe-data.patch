From: XR500v OpenWrt project
Subject: [PATCH] i2c: mt7621: make FIFO data packing endian-safe

SM0D0/SM0D1 hold the first transferred byte in bits 7:0. Using memcpy()
between the byte buffer and u32 registers only implements that layout on a
little-endian CPU. On the big-endian EN751221 it writes the bytes into the
high lanes and copies zero from the high lane on reads.

Pack and unpack the register words explicitly so the controller works on both
CPU endiannesses.
--- a/drivers/i2c/busses/i2c-mt7621.c
+++ b/drivers/i2c/busses/i2c-mt7621.c
@@ -142,6 +142,6 @@ static int mtk_i2c_xfer(struct i2c_adapte
 	struct i2c_msg *pmsg;
 	u16 addr;
-	int i, j, ret, len, page_len;
+	int i, j, k, ret, len, page_len;
 	u32 cmd;
 	u32 data[2];
 
@@ -195,7 +195,11 @@ static int mtk_i2c_xfer(struct i2c_adapte
 				cmd = (len > 8) ?
 					SM0CTL1_READ : SM0CTL1_READ_LAST;
 			} else {
-				memcpy(data, &pmsg->buf[j], page_len);
+				data[0] = 0;
+				data[1] = 0;
+				for (k = 0; k < page_len; k++)
+					data[k / 4] |= (u32)pmsg->buf[j + k] <<
+							 (8 * (k % 4));
 				iowrite32(data[0], i2c->base + REG_SM0D0_REG);
 				iowrite32(data[1], i2c->base + REG_SM0D1_REG);
 				cmd = SM0CTL1_WRITE;
@@ -208,7 +212,9 @@ static int mtk_i2c_xfer(struct i2c_adapte
 			if (pmsg->flags & I2C_M_RD) {
 				data[0] = ioread32(i2c->base + REG_SM0D0_REG);
 				data[1] = ioread32(i2c->base + REG_SM0D1_REG);
-				memcpy(&pmsg->buf[j], data, page_len);
+				for (k = 0; k < page_len; k++)
+					pmsg->buf[j + k] = data[k / 4] >>
+							    (8 * (k % 4));
 			} else {
 				if (!(pmsg->flags & I2C_M_IGNORE_NAK)) {
 					ret = mtk_i2c_check_ack(i2c,

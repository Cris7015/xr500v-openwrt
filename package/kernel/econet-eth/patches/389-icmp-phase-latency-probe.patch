+static struct en75_icmp_phase_sample en75_icmp_phase[EN75_ICMP_PHASE_SLOTS];
+static DEFINE_SPINLOCK(en75_icmp_phase_lock);
+static unsigned int en75_icmp_phase_next;
+static bool en75_icmp_phase_probe = true;
+static int en75_icmp_phase_log_us = 1000;

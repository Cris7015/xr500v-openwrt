+/* dump the raw words of the engine-built (unbind) FoE entry at 'hash' so we can
+ * reverse the engine's exact tuple byte-layout. w0=ib1, then orig tuple, ib2... */
+void en75_ppe_dump_slot(struct en75_ppe *ppe, u16 hash)
+{
+	u32 *w = (u32 *)((u8 *)ppe->foe_virt + (u32)hash * EN75_FOE_ENTRY_SIZE);
+
+	pr_info_ratelimited("XR500v FoE[%u]: %08x %08x %08x %08x %08x %08x %08x %08x %08x %08x\n",
+			    hash, w[0], w[1], w[2], w[3], w[4],
+			    w[5], w[6], w[7], w[8], w[9]);
+}
+
+/* poll the CAH sw-access request bit clear (RA_HWNAT is_request_done, 1ms*1000) */
+static bool en75_cah_wait(struct en75_ppe *ppe)
+{
+	int n = 1000;
+
+	while (n--) {
+		if (!(readl(ppe->base + EN75_PPE_CACHE_CTL) & EN75_PPE_CAH_REQ))
+			return true;
+		udelay(1000);
+	}
+	return false;
+}
+
+/* port of RA_HWNAT FoeDumpCacheEntry (foe_fdb.c:143): read each of the 16 CAH
+ * cache lines' resident entry-number + state. THE diagnostic for our central
+ * blocker -- on the EN751221 the engine FORWARD_BUILDs unbind entries into this
+ * cache, NOT the DRAM table (which is why TB_USED stays 0 and en75_ppe_dump_slot
+ * reads zeros). A 'valid'/'dirty' line here with the test flow's slot proves it. */
+void en75_ppe_dump_cache(struct en75_ppe *ppe)
+{
+	u32 gate = readl(ppe->base + EN75_PPE_CAH_GATE);
+	u32 ctrl;
+	int line;
+
+	/* build #39: the REAL cache enable is CAH_GATE (0x334) bit0, NOT CACHE_CTL
+	 * 0x320 -- the old check read 0x320 (which sits at 0x4000 after a clean-all)
+	 * and always bailed "DISABLED" so we never saw the cache lines. */
+	if (!(gate & BIT(0))) {
+		pr_info("XR500v PPE cache: DISABLED (CAH_GATE=%08x)\n", gate);
+		return;
+	}
+	pr_info("XR500v PPE cache dump (CAH_GATE=%08x):\n", gate);
+	/* RA_HWNAT FoeDumpCacheEntry disables the cache before the sw-access read
+	 * loop so the engine isn't racing us. Restore at the end. */
+	writel(gate & ~BIT(0), ppe->base + EN75_PPE_CAH_GATE);
+	for (line = 0; line < EN75_PPE_CAH_LINES; line++) {
+		u32 rd, tag, state;
+
+		/* line number [14:0] + OFFSET_RW=0x1f [23:16] (== get entry number) */
+		writel((line & 0x7fff) |
+		       (EN75_PPE_CAH_OFFRW_ENTRYNUM << 16),
+		       ppe->base + EN75_PPE_CAH_LINE_RW);
+		/* sw-access cmd = read (2) at CAH_CTRL[13:12] */
+		ctrl = readl(ppe->base + EN75_PPE_CACHE_CTL);
+		ctrl &= ~(0x3u << EN75_PPE_CAH_CMD_SHIFT);
+		ctrl |= 0x2u << EN75_PPE_CAH_CMD_SHIFT;
+		writel(ctrl, ppe->base + EN75_PPE_CACHE_CTL);
+		/* trigger the request */
+		writel(ctrl | EN75_PPE_CAH_REQ, ppe->base + EN75_PPE_CACHE_CTL);
+		if (!en75_cah_wait(ppe)) {
+			pr_info("  line %2d: timeout\n", line);
+			continue;
+		}
+		rd = readl(ppe->base + EN75_PPE_CAH_RDATA);
+		tag = rd & 0xffff;
+		state = (rd >> 16) & 0x3;
+		pr_info("  line %2d: state=%-7s entry=%u (rdata=%08x)\n", line,
+			state == 3 ? "lock" : state == 2 ? "dirty" :
+			state == 1 ? "valid" : "invalid", tag, rd);
+		/* foe_fdb.c: for a resident line, read the first 16 words of the
+		 * cached FoE entry (OFFSET_RW=0..15) -> the engine's OWN parse:
+		 * w0=ib1, w1=sip, w2=dip, w3=ports, w4=ib2. THE answer to whether the
+		 * routed flow's engine-parsed tuple == our committed swab tuple. */
+		if (state) {
+			int w;
+
+			for (w = 0; w < 16; w++) {
+				u32 dc;
+
+				writel((line & 0x7fff) | ((u32)w << 16),
+				       ppe->base + EN75_PPE_CAH_LINE_RW);
+				dc = readl(ppe->base + EN75_PPE_CACHE_CTL);
+				dc &= ~(0x3u << EN75_PPE_CAH_CMD_SHIFT);
+				dc |= 0x2u << EN75_PPE_CAH_CMD_SHIFT;
+				writel(dc, ppe->base + EN75_PPE_CACHE_CTL);
+				writel(dc | EN75_PPE_CAH_REQ, ppe->base + EN75_PPE_CACHE_CTL);
+				if (en75_cah_wait(ppe))
+					pr_info("      w%02d=%08x\n", w,
+						readl(ppe->base + EN75_PPE_CAH_RDATA));
+			}
+		}
+	}
+	writel(gate, ppe->base + EN75_PPE_CAH_GATE);	/* restore cache enable */
+}
+
+/* enable/disable + flush the PPE lookup cache (RA_HWNAT PpeSetCacheEbl). With
+ * the cache OFF the engine works straight on the DRAM FoE table, so unbind
+ * entries become visible to en75_ppe_dump_slot and the mainline tuple-match in
+ * __en75_ppe_check_skb -- the decisive A/B for the cache hypothesis. */
+/* EN751221: operate the REAL cache enable/config register (0x334), NOT 0x320.
+ * ON = full-word 0x33 (OEM PpeSetCacheEbl); OFF = clear bit0. The old 0x320
+ * version was a NO-OP, so every prior cache A/B test was invalid. */
+void en75_ppe_cache_set(struct en75_ppe *ppe, bool on)
+{
+	if (on)
+		writel(0x33, ppe->base + EN75_PPE_CAH_GATE);
+	else
+		writel(readl(ppe->base + EN75_PPE_CAH_GATE) & ~BIT(0),
+		       ppe->base + EN75_PPE_CAH_GATE);
+	pr_info("XR500v PPE cache %s: 0x334=%08x\n", on ? "ON" : "OFF",
+		readl(ppe->base + EN75_PPE_CAH_GATE));
+}
+
+/* scan the whole 16384-slot DRAM FoE table and log every non-zero entry (slot +
+ * ib1 + orig tuple). Diagnostic for the descriptor-slot vs table-slot mismatch:
+ * run it after a flow to find which slot the engine ACTUALLY put our tuple in
+ * (match by ports), vs the slot the RX descriptor reported. One-shot, ~ms. */
+void en75_ppe_scan_table(struct en75_ppe *ppe)
+{
+	int i, found = 0;
+
+	pr_info("XR500v PPE table scan (non-zero entries, max 256):\n");
+	for (i = 0; i < EN75_PPE_ENTRIES; i++) {
+		struct mtk_foe_entry *e =
+			(struct mtk_foe_entry *)((u8 *)ppe->foe_virt + (u32)i * EN75_FOE_ENTRY_SIZE);
+
+		if (!e->ib1)
+			continue;
+		if (++found <= 256)
+			pr_info("  [%u] ib1=%08x state=%lu sip=%08x dip=%08x ports=%08x ib2=%08x\n",
+				i, e->ib1, FIELD_GET(MTK_FOE_IB1_STATE, e->ib1),
+				e->ipv4.orig.src_ip, e->ipv4.orig.dest_ip,
+				e->ipv4.orig.ports, e->ipv4.ib2);
+	}
+	pr_info("XR500v PPE table scan: %d non-zero entries total\n", found);
+}
+
+/* THE fill+flip bind (RA_HWNAT model, #25): the engine already FORWARD_BUILT an
+ * UNBIND entry for our flow at ITS OWN hash slot (NOT the descriptor's ppe_entry,
+ * which we proved is unrelated). Find that entry by matching the L4 PORTS (which
+ * the engine stores correctly, unlike the IPs whose encoding we couldn't crack),
+ * then bind IN PLACE: keep the engine's tuple untouched, just set egress dest_port
+ * (pse) + flip STATE to BIND + cache-clear. The engine matches incoming packets
+ * against its OWN stored tuple, so the IP-encoding mismatch becomes irrelevant. */
+int en75_ppe_bind_by_scan(struct en75_ppe *ppe)
+{
+	struct en75_flow_entry *e;
+	struct hlist_node *n;
+	int b, i, bound = 0, scanned = 0;
+	u32 cc;
+
+	spin_lock_bh(&ppe->lock);
+	for (b = 0; b < EN75_PPE_NUM_FLOWS; b++) {
+		hlist_for_each_entry_safe(e, n, &ppe->foe_flow[b], list) {
+			u32 want_ports = e->data.ipv4.orig.ports;
+			u8 pse = FIELD_GET(MTK_FOE_IB2_DEST_PORT, e->data.ipv4.ib2);
+
+			scanned++;
+			for (i = 0; i < EN75_PPE_ENTRIES; i++) {
+				struct mtk_foe_entry *hwe =
+					(struct mtk_foe_entry *)((u8 *)ppe->foe_virt +
+						(u32)i * EN75_FOE_ENTRY_SIZE);
+
+				u32 cur_state, cur_dp;
+
+				if (!hwe->ib1 || hwe->ipv4.orig.ports != want_ports)
+					continue;
+				cur_state = FIELD_GET(MTK_FOE_IB1_STATE, hwe->ib1);
+				cur_dp = FIELD_GET(MTK_FOE_IB2_DEST_PORT, hwe->ipv4.ib2);
+				/* #27: the EN751221 engine FORWARD_BUILDs its UNBIND entry as
+				 * state=2 + DEST_PORT=7 (its unbind->CPU format), so the old
+				 * "skip if state==BIND" never flipped it. Flip IN PLACE: change
+				 * DEST_PORT to our pse (forward) + (re)assert BIND + ttl/cah,
+				 * KEEP the engine's tuple. Skip only once we've already set it. */
+				if (cur_dp == pse && cur_state == MTK_FOE_STATE_BIND)
+					continue;	/* already flipped by us */
+				pr_info("XR500v PPE bind_by_scan: ports=%08x @slot %d FOUND cur_state=%u cur_dp=%u ib1=%08x ib2=%08x -> flip dp=%u\n",
+					want_ports, i, cur_state, cur_dp, hwe->ib1, hwe->ipv4.ib2, pse);
+
+				hwe->ipv4.ib2 &= ~MTK_FOE_IB2_DEST_PORT;
+				hwe->ipv4.ib2 |= FIELD_PREP(MTK_FOE_IB2_DEST_PORT, pse);
+				hwe->ib1 |= MTK_FOE_IB1_BIND_CACHE | MTK_FOE_IB1_BIND_TTL;
+				hwe->ib1 &= ~MTK_FOE_IB1_STATE;
+				hwe->ib1 |= FIELD_PREP(MTK_FOE_IB1_STATE, MTK_FOE_STATE_BIND);
+				dma_wmb();
+				cc = readl(ppe->base + EN75_PPE_CACHE_CTL);
+				writel(cc | EN75_PPE_CACHE_CTL_CLEAR, ppe->base + EN75_PPE_CACHE_CTL);
+				writel(cc & ~EN75_PPE_CACHE_CTL_CLEAR, ppe->base + EN75_PPE_CACHE_CTL);
+				e->hash = i;
+				bound++;
+				pr_info("XR500v PPE bind_by_scan: flow ports=%08x -> engine slot %d FLIPPED state=BIND dp=%u ib1=%08x ib2=%08x\n",
+					want_ports, i, pse, hwe->ib1, hwe->ipv4.ib2);
+				break;
+			}
+		}
+	}
+	spin_unlock_bh(&ppe->lock);
+	pr_info("XR500v PPE bind_by_scan: %d flows scanned, %d bound\n", scanned, bound);
+	return bound;
+}
+
+/* write CDMA1_VLAN_CTRL (fe_base+0x400). 0x81000001 = OEM value that pops the
+ * MT7530 special tag on RX so the PPE can parse the inner IPv4 frame. */
+void en75_ppe_set_vlan_ctrl(struct en75_ppe *ppe, u32 val)
+{
+	u32 old = readl(ppe->fe_base + EN75_CDMA1_VLAN_CTRL);
+
+	writel(val, ppe->fe_base + EN75_CDMA1_VLAN_CTRL);
+	pr_info("XR500v PPE vlan_ctrl: CDMA1_VLAN_CTRL %08x -> %08x (rb=%08x)\n",
+		old, val, readl(ppe->fe_base + EN75_CDMA1_VLAN_CTRL));
+}
+
+void en75_ppe_fe_rw(struct en75_ppe *ppe, u32 off, bool write, u32 val)
+{
+	u32 old = readl(ppe->fe_base + (off & 0xfffc));
+
+	if (write) {
+		writel(val, ppe->fe_base + (off & 0xfffc));
+		pr_info("XR500v PPE fe[%04x]: %08x -> %08x (rb=%08x)\n",
+			off & 0xfffc, old, val, readl(ppe->fe_base + (off & 0xfffc)));
+	} else {
+		pr_info("XR500v PPE fe[%04x] = %08x\n", off & 0xfffc, old);
+	}
+}
+
+/* patch 356: allocate the per-eth PPE state (struct + foe_flow + rate-limit). */
+struct en75_ppe *en75_ppe_attach(struct device *dev, void __iomem *base,
+				 void __iomem *fe_base, void *foe_virt,
+				 dma_addr_t foe_phys, struct net_device *conduit)
+{
+	struct en75_ppe *ppe = devm_kzalloc(dev, sizeof(*ppe), GFP_KERNEL);
+
+	if (!ppe)
+		return NULL;
+	ppe->dev = dev;
+	ppe->base = base;
+	ppe->fe_base = fe_base;
+	/* build #47 (Codex): HASH_SEED (ppe+0x244) must be set before the engine runs;
+	 * our phase-1a init left it at reset (0). OEM writes 0x12345678. phase-1a's
+	 * TB_CFG write does NOT touch 0x244, so setting it here (probe, pre-enable)
+	 * survives. HASH_MODE (TB_CFG bits[15:14]) was bumped 1->3 in patch 350. */
+	writel(0x12345678u, base + 0x244);
+	ppe->foe_virt = foe_virt;
+	ppe->foe_phys = foe_phys;
+	ppe->conduit = conduit;
+	spin_lock_init(&ppe->lock);
+	ppe->foe_flow = devm_kcalloc(dev, EN75_PPE_NUM_FLOWS,
+				     sizeof(*ppe->foe_flow), GFP_KERNEL);
+	ppe->foe_check_time = devm_kcalloc(dev, EN75_PPE_ENTRIES,
+					   sizeof(*ppe->foe_check_time), GFP_KERNEL);
+	if (!ppe->foe_flow || !ppe->foe_check_time)
+		return NULL;
+	return ppe;
+}
+
+/* --- V1 egress builders (mainline mtk_foe_entry_set_*; IPv4 l2 only) --- */
+
+void en75_foe_entry_set_dsa(struct mtk_foe_entry *entry, int port, bool passthrough)
+{
+	struct mtk_foe_mac_info *l2 = &entry->ipv4.l2;
+
+	l2->etype = BIT(port) & 0x3f;		/* DP bitmap GENMASK(5,0) */
+	if (passthrough)
+		l2->etype |= BIT(7);		/* XR500v: cascaded 2nd MT7530 passthrough */
+	if (!(entry->ib1 & MTK_FOE_IB1_BIND_VLAN_LAYER))
+		entry->ib1 |= FIELD_PREP(MTK_FOE_IB1_BIND_VLAN_LAYER, 1);
+	else
+		l2->etype |= BIT(8);
+	entry->ib1 &= ~MTK_FOE_IB1_BIND_VLAN_TAG;
+}
+
+void en75_foe_entry_set_queue(struct mtk_foe_entry *entry, unsigned int queue)
+{
+	u32 *ib2 = &entry->ipv4.ib2;
+
+	*ib2 &= ~MTK_FOE_IB2_QID;
+	*ib2 |= FIELD_PREP(MTK_FOE_IB2_QID, queue);
+	/* build #62: OEM ib2 -- switch-egress (dp=1, GSW) uses PSE_QOS=0 (0x..020);
+	 * only QDMA/GPON upstream (dp=6) uses PSE_QOS=1 (0x..0d0). We were always
+	 * forcing PSE_QOS=1 (-> 0x..030), wrong for our nested-DSA switch egress. */
+	*ib2 |= MTK_FOE_IB2_PSE_QOS;
+}
+
+void en75_foe_entry_set_pppoe(struct mtk_foe_entry *entry, int sid)
+{
+	struct mtk_foe_mac_info *l2 = &entry->ipv4.l2;
+
+	if (!(entry->ib1 & MTK_FOE_IB1_BIND_VLAN_LAYER) ||
+	    (entry->ib1 & MTK_FOE_IB1_BIND_VLAN_TAG))
+		l2->etype = ETH_P_PPP_SES;
+	entry->ib1 |= MTK_FOE_IB1_BIND_PPPOE;
+	l2->pppoe_id = sid;
+}
+
+void en75_foe_entry_set_vlan(struct mtk_foe_entry *entry, int vid)
+{
+	struct mtk_foe_mac_info *l2 = &entry->ipv4.l2;
+
+	switch (FIELD_GET(MTK_FOE_IB1_BIND_VLAN_LAYER, entry->ib1)) {
+	case 0:
+		entry->ib1 |= MTK_FOE_IB1_BIND_VLAN_TAG |
+			      FIELD_PREP(MTK_FOE_IB1_BIND_VLAN_LAYER, 1);
+		l2->vlan1 = vid;
+		return;
+	case 1:
+		if (!(entry->ib1 & MTK_FOE_IB1_BIND_VLAN_TAG)) {
+			l2->vlan1 = vid;
+			l2->etype |= BIT(8);
+		} else {
+			l2->vlan2 = vid;
+			entry->ib1 += FIELD_PREP(MTK_FOE_IB1_BIND_VLAN_LAYER, 1);
+		}
+		return;
+	default:
+		return;
+	}
+}
+
+/* --- foe_flow registration + RX bind (mainline mtk_ppe.c core, V1/IPv4) --- */
+
+/* match the orig 5-tuple (12B after ib1) + the UDP bit */
+static bool __maybe_unused en75_flow_entry_match(struct en75_flow_entry *e, struct mtk_foe_entry *hwe)
+{
+	if ((hwe->ib1 ^ e->data.ib1) & MTK_FOE_IB1_UDP)
+		return false;
+	return !memcmp(&e->data.data, &hwe->data,
+		       offsetof(struct mtk_foe_entry, ipv4.ib2) - sizeof(hwe->ib1));
+}
+
+/* caller holds ppe->lock; invalidate the HW slot this flow was bound to */
+static void en75_foe_entry_clear_locked(struct en75_ppe *ppe, struct en75_flow_entry *e)
+{
+	if (e->hash != 0xffff) {
+		struct mtk_foe_entry *hwe =
+			(struct mtk_foe_entry *)((u8 *)ppe->foe_virt +
+						 (u32)e->hash * EN75_FOE_ENTRY_SIZE);
+		u32 cc;
+
+		hwe->ib1 &= ~MTK_FOE_IB1_STATE;
+		hwe->ib1 |= FIELD_PREP(MTK_FOE_IB1_STATE, MTK_FOE_STATE_INVALID);
+		dma_wmb();
+		cc = readl(ppe->base + EN75_PPE_CACHE_CTL);
+		writel(cc | EN75_PPE_CACHE_CTL_CLEAR, ppe->base + EN75_PPE_CACHE_CTL);
+		writel(cc & ~EN75_PPE_CACHE_CTL_CLEAR, ppe->base + EN75_PPE_CACHE_CTL);
+	}
+	e->hash = 0xffff;
+}
+
+/* register a prepared flow into the SW bucket; NO HW write (mainline
+ * mtk_foe_entry_commit). The RX hook binds it on the first matching packet. */
+int en75_foe_entry_register(struct en75_ppe *ppe, struct en75_flow_entry *e)
+{
+	u32 hash = en75_ppe_hash_entry(&e->data);
+
+	e->hash = 0xffff;
+	spin_lock_bh(&ppe->lock);
+	hlist_add_head(&e->list, &ppe->foe_flow[hash / EN75_PPE_HASH_OFFSET]);
+	spin_unlock_bh(&ppe->lock);
+	return 0;
+}
+
+void en75_foe_entry_unregister(struct en75_ppe *ppe, struct en75_flow_entry *e)
+{
+	spin_lock_bh(&ppe->lock);
+	en75_foe_entry_clear_locked(ppe, e);
+	hlist_del_init(&e->list);
+	spin_unlock_bh(&ppe->lock);
+}
+
+/* RX path: a steered-but-unbound flow missed and the engine reported its own
+ * FoE slot in 'hash'. Bind a registered flow there. TWO match strategies:
+ *
+ *  (1) mainline fast-path: if the engine wrote a DRAM-visible UNBIND entry at
+ *      'hash', tuple-match it (en75_flow_entry_match) and bind the matching
+ *      flow. This is what mtk_ppe does.
+ *
+ *  (2) EN751221 fall-back: the engine FORWARD_BUILDs unbind entries into its
+ *      CAH *cache*, NOT the DRAM table (TB_USED stays 0, the slot reads zeros),
+ *      so (1) finds nothing to match. When exactly ONE flow is registered and
+ *      still unbound, it IS this flow -> bind it at the engine's reported slot.
+ *      en75_foe_entry_commit() writes DRAM + pulses CACHE_CTL.CLEAR, so the
+ *      engine drops its cached unbind entry and re-reads our BIND entry.
+ *      (Multi-flow disambiguation will need the CAH read or an skb parse; this
+ *      single-flow path is the first-light proof that binding HITs at all.) */
+/* P5 RX-bind: pse the bound flow forwards to. 1 = GDM1 (CPU, HIT observable via
+ * crsn>=16); 7 = DISCARD oracle (flow stops). Tunable live via ppe_rx_bind_pse. */
+static u8 en75_rx_bind_pse = 1;
+
+/* build #41: ATOMIC dump (ChatGPT "Test C") -- fired from the RX hook on a crsn frame so
+ * we catch the cache AT the crsn=15 instant (no userspace race that evicts our flow).
+ * Reads DRAM[the engine-reported slot] + the 16 CAH lines' DATA words (w0=ib1,w1=sip,
+ * w2=dip,w3=ports,w4=ib2 -- these READ FINE; only the meta 0x1f echoes, so we skip it).
+ * Runs under the caller's spin_lock_bh (atomic; en75_cah_cmd busy-waits, cmd completes in
+ * us). Answers: is OUR flow (sip=c0a844f8) in the cache RIGHT NOW, under which line, and
+ * what does DRAM[reported-slot] actually hold (state)? */
+static void en75_ppe_atomic_dump(struct en75_ppe *ppe, u16 hash)
+{
+	struct mtk_foe_entry *hwe =
+		(struct mtk_foe_entry *)((u8 *)ppe->foe_virt +
+					 (u32)hash * EN75_FOE_ENTRY_SIZE);
+	u32 gate = readl(ppe->base + EN75_PPE_CAH_GATE);
+	int line, i;
+
+	pr_info("XR500v ATOMIC: slot=%u DRAM ib1=%08x state=%lu sip=%08x dip=%08x ports=%08x ib2=%08x\n",
+		hash, hwe->ib1, FIELD_GET(MTK_FOE_IB1_STATE, hwe->ib1),
+		hwe->ipv4.orig.src_ip, hwe->ipv4.orig.dest_ip,
+		hwe->ipv4.orig.ports, hwe->ipv4.ib2);
+	writel(gate & ~BIT(0), ppe->base + EN75_PPE_CAH_GATE);		/* gate down */
+	for (line = 0; line < EN75_PPE_CAH_LINES; line++) {
+		u32 w[5];
+
+		for (i = 0; i < 5; i++) {
+			writel((line & 0x7fff) | ((u32)i << 16),
+			       ppe->base + EN75_PPE_CAH_LINE_RW);
+			w[i] = en75_cah_cmd(ppe, 2) ?
+			       readl(ppe->base + EN75_PPE_CAH_RDATA) : 0xdeaddead;
+		}
+		pr_info("XR500v ATOMIC: cah[%2d] ib1=%08x sip=%08x dip=%08x ports=%08x ib2=%08x\n",
+			line, w[0], w[1], w[2], w[3], w[4]);
+	}
+	writel(gate, ppe->base + EN75_PPE_CAH_GATE);			/* gate up */
+}
+
+/* P5 RX-bind (build #31) -- Codex/OEM-disasm finding: the engine's FORWARD_BUILT
+ * unbind entry is CACHE-resident, NOT in the DRAM table, and CACHE_CTL.CLEAR
+ * DISCARDS the cache (no write-back). PpeSetEntryBind flips ib1 only because the
+ * OEM first MATERIALIZES the entry in DRAM from the packet. So:
+ *  - if the DRAM slot already holds an entry (engine evicted it) -> FLIP in place
+ *    (byte-order safe, keeps the engine's tuple);
+ *  - if the slot is empty (cache-resident) -> COMMIT the registered flow's entry
+ *    to DRAM at slot=hash (en75_foe_entry_commit: full 80B + ib1-last + dma_wmb +
+ *    cache-clear) so the engine re-reads our BIND. The committed tuple must match
+ *    the engine's lookup byte order (engine stores swab32 of network order) --
+ *    set via ppe_t_* params (test swab vs raw without reflashing). */
+/* build #61: PREBIND promote. Called from the RX call-site when the engine raised
+ * crsn=HIT_PRE_BIND(0x1a) -- its handshake that it accepted our preb=1 and staged
+ * the bind internally. ONLY now (per OEM ra_nat.c:3150) do we flip UNBIND->BIND.
+ * This is the step the direct state=BIND write skipped: on the EN751221 the HW owns
+ * the state field of dynamic entries and ignores a SW-forced BIND; preb is the only
+ * lever, and the engine confirms via this crsn. Target bound format = OEM entry2726
+ * (state=BIND, ttl/cah/ka set, vlan_layer preserved). bit24 stays set (preb->ttl). */
+void en75_ppe_prebind_promote(struct en75_ppe *ppe, u16 hash)
+{
+	struct mtk_foe_entry *hwe;
+	u32 state;
+
+	if (!READ_ONCE(en75_ppe_prebind) || hash >= EN75_PPE_ENTRIES)
+		return;
+	spin_lock_bh(&ppe->lock);
+	hwe = (struct mtk_foe_entry *)((u8 *)ppe->foe_virt +
+				       (u32)hash * EN75_FOE_ENTRY_SIZE);
+	state = FIELD_GET(MTK_FOE_IB1_STATE, hwe->ib1);
+	if (hwe->ib1 && (hwe->ib1 & MTK_FOE_IB1_UNBIND_PREBIND) &&
+	    state != MTK_FOE_STATE_BIND) {
+		hwe->ib1 &= ~MTK_FOE_IB1_STATE;
+		hwe->ib1 |= FIELD_PREP(MTK_FOE_IB1_STATE, MTK_FOE_STATE_BIND) |
+			    MTK_FOE_IB1_BIND_TTL | MTK_FOE_IB1_BIND_CACHE |
+			    MTK_FOE_IB1_BIND_KEEPALIVE;
+		en75_foe_entry_set_oem_bind_meta(hwe);
+		dma_wmb();
+		en75_ppe_cache_clean_all(ppe);
+		en75_ppe_diag_event(EN75_PPE_DIAG_PREBIND_PROMOTE);
+		pr_info_ratelimited("XR500v PREBIND promote: slot=%u UNBIND->BIND (crsn=0x1a) ib1=%08x ib2=%08x\n",
+				    hash, hwe->ib1, hwe->ipv4.ib2);
+	}
+	spin_unlock_bh(&ppe->lock);
+}
+
+void __en75_ppe_check_skb(struct en75_ppe *ppe, struct sk_buff *skb, u16 hash, u8 crsn)
+{
+	struct mtk_foe_entry *hwe;
+	struct en75_flow_entry *e, *cand = NULL;
+	struct hlist_node *n;
+	u32 state, cur_dp;
+	int b, ncand = 0;
+
+	/* build #57: this RX frame's descriptor 'hash' IS the engine LOOKUP slot.
+	 * Record it keyed by the inner pre-NAT tuple so the TX bind lands here. */
+	en75_ppe_rx_record(ppe, skb, hash);
+
+	/* build #68: OEM bind timing -- act only when the engine asks (0x0f). */
+	if (READ_ONCE(en75_ppe_bind_on_rate)) {
+		if (crsn != 0x0f) {
+			en75_ppe_diag_gate_skip(crsn);
+			pr_info_ratelimited("XR500v PPE rate-gate: skip crsn=%u slot=%u\n",
+					    crsn, hash);
+			return;
+		}
+		en75_ppe_diag_event(EN75_PPE_DIAG_GATE_PASS);
+	}
+
+	spin_lock_bh(&ppe->lock);
+	hwe = (struct mtk_foe_entry *)((u8 *)ppe->foe_virt +
+				       (u32)hash * EN75_FOE_ENTRY_SIZE);
+	state = FIELD_GET(MTK_FOE_IB1_STATE, hwe->ib1);
+	cur_dp = FIELD_GET(MTK_FOE_IB2_DEST_PORT, hwe->ipv4.ib2);
+
+	/* build #41: one-shot atomic dump (cache+DRAM at this exact crsn frame). */
+	if (READ_ONCE(en75_ppe_atomic)) {
+		WRITE_ONCE(en75_ppe_atomic, false);
+		en75_ppe_atomic_dump(ppe, hash);
+	}
+
+	/* build #43 FLIP-IN-PLACE (OEM PpeTxHandler model, workflow w7h8wpopm high-conf,
+	 * 3 agents converged): the ENGINE itself FORWARD_BUILDs the FoE skeleton at THIS
+	 * slot (requires FLOW_CFG=0x0600f700 so the engine writes DRAM) and reports the
+	 * index in the RX descriptor. The OEM only PATCHES that engine-built entry in
+	 * place -- sets dest_port + flips ib1.state=BIND, KEEPING the engine's own match
+	 * tuple -- it NEVER writes a from-scratch entry (= our 42-build rank-1 mistake;
+	 * the engine ignores foreign slots/tuples). Then CAH-flush so the engine re-reads
+	 * its now-BIND entry instead of the stale cached UNBIND. dest_port via en75_flip_dp
+	 * (1=GSW/LAN-switch egress for our nested-DSA, 2=GMAC/WAN). HW-forward verifiable
+	 * via RXHWF_OK_CNT(fe+0x594) climbing vs RXCPU_OK_CNT(fe+0x590). */
+	if (READ_ONCE(en75_ppe_flip) && hwe->ib1 &&
+	    state != MTK_FOE_STATE_BIND) {
+		/* set egress dest_port + PORT_MG/AG=0x3f and PSE_QOS=0 -- the OEM
+		 * switch-egress ib2 is 0x00FFF020 (dp=1, fqos/PSE_QOS=0); only the
+		 * GPON/QDMA dp=6 upstream path uses PSE_QOS=1 (ib2=0x00FFF0D0). */
+		hwe->ipv4.ib2 &= ~(MTK_FOE_IB2_DEST_PORT | MTK_FOE_IB2_PSE_QOS |
+				   MTK_FOE_IB2_PORT_MG | MTK_FOE_IB2_PORT_AG);
+		hwe->ipv4.ib2 |= FIELD_PREP(MTK_FOE_IB2_DEST_PORT, en75_flip_dp) |
+				 FIELD_PREP(MTK_FOE_IB2_PORT_MG, 0x3f) |
+				 FIELD_PREP(MTK_FOE_IB2_PORT_AG, 0x3f);
+		if (READ_ONCE(en75_ppe_prebind)) {
+			/* build #61: OEM PREBIND model -- set preb(bit24)+cache, KEEP
+			 * state=UNBIND. The engine raises crsn=HIT_PRE_BIND(0x1a) on the
+			 * next matching packet; en75_ppe_prebind_promote() then flips to
+			 * BIND. The OEM never SW-forces BIND on a dynamic entry (the HW
+			 * owns the state field); preb is the handshake we'd been skipping. */
+			hwe->ib1 |= MTK_FOE_IB1_UNBIND_PREBIND | MTK_FOE_IB1_BIND_CACHE;
+			dma_wmb();
+			en75_ppe_cache_clean_all(ppe);
+			en75_ppe_diag_event(EN75_PPE_DIAG_PREBIND_ARM);
+			pr_info_ratelimited("XR500v PREBIND arm: slot=%u preb=1 dp=%u ib1=%08x ib2=%08x ports=%08x\n",
+					    hash, en75_flip_dp, hwe->ib1,
+					    hwe->ipv4.ib2, hwe->ipv4.orig.ports);
+			goto out;
+		}
+		hwe->ib1 &= ~MTK_FOE_IB1_STATE;
+		hwe->ib1 |= FIELD_PREP(MTK_FOE_IB1_STATE, MTK_FOE_STATE_BIND) |
+			    MTK_FOE_IB1_BIND_CACHE | MTK_FOE_IB1_BIND_TTL;
+		dma_wmb();
+		/* build #49: publish with the OEM GLOBAL clean-all (cache_mode), not the
+		 * per-line clear whose tag-search never matched our slot. In-driver here so
+		 * the engine drops its cached UNBIND and re-reads our BIND -- an external
+		 * clean-all loop starved the flip (FLIPs=0). */
+		if (READ_ONCE(en75_ppe_cache_mode) == 1)
+			en75_ppe_cache_clean_all(ppe);
+		else
+			en75_ppe_cah_clear_one(ppe, hash);
+		en75_ppe_diag_event(EN75_PPE_DIAG_FLIP);
+		pr_info_ratelimited("XR500v FLIP slot=%u UNBIND->BIND dp=%u sip=%08x dip=%08x ports=%08x\n",
+				    hash, en75_flip_dp, hwe->ipv4.orig.src_ip,
+				    hwe->ipv4.orig.dest_ip, hwe->ipv4.orig.ports);
+		goto out;
+	}
+
+	/* build #42 TX-hook mode: the engine reported its FoE slot for this flow --
+	 * record it + arm the TX commit, then bail. en75_ppe_tx_bind() fills the
+	 * COMPLETE entry (egress MACs/pppoe/NAT'd tuple/DSA dp) from the egress
+	 * packet and commits at this slot, exactly like the OEM PpeTxHandler. The
+	 * RX rank-1 commit below (incomplete entry) is what the engine rejects. */
+	if (READ_ONCE(en75_ppe_tx_hook)) {
+		WRITE_ONCE(en75_tx_bind_slot, hash);
+		WRITE_ONCE(en75_tx_bind_arm, true);
+		en75_ppe_diag_event(EN75_PPE_DIAG_TX_ARM);
+		goto out;
+	}
+
+	/* already bound by us (EN751221 unbind is state=2+dp=7, so key "done" on dp). */
+	if (hwe->ib1 && state == MTK_FOE_STATE_BIND && cur_dp == en75_rx_bind_pse)
+		goto out;
+
+	/* RANK-1 FIX (workflow wf_ca253665, OEM-disasm high-conf): the engine has TWO
+	 * parsers -- LOOKUP (parses the real frame OK; this is why classify works and why
+	 * the engine HITs entries holding the REAL tuple) and FORWARD_BUILD (byte-lane
+	 * shifts -> stores .64). The OEM NEVER trusts the HW-built tuple: it builds the
+	 * 5-tuple in SOFTWARE (PpeFillInL3Info, real IPs) and commits it; PpeSetEntryBind
+	 * only flips state. The old code FLIPped the engine's shifted DRAM entry in place
+	 * (keeping .64) -> the engine's LOOKUP of the real packet (.64) never matched its
+	 * stored shifted tuple -> MISS -> rebuild -> crsn=15 forever. FIX: ALWAYS COMMIT
+	 * the registered flow's REAL-IP tuple at slot=hash (the descriptor's slot), exactly
+	 * like the OEM. Inline+per-packet so it wins the race vs the engine's auto-rebuild.
+	 * Do NOT use en75_flow_entry_match (memcmps vs the shifted hwe->data -> never hits);
+	 * single registered flow = commit it. Re-commit each frame until the engine HITs
+	 * (then the BIND survives and the dp-guard above short-circuits). */
+	for (b = 0; b < EN75_PPE_NUM_FLOWS; b++)
+		hlist_for_each_entry_safe(e, n, &ppe->foe_flow[b], list) {
+			cand = e;
+			ncand++;
+		}
+	if (ncand == 1) {
+		cand->hash = hash;
+		en75_foe_entry_set_pse_port(&cand->data, en75_rx_bind_pse);
+		en75_foe_entry_commit(ppe, &cand->data, hash);
+		en75_ppe_diag_event(EN75_PPE_DIAG_RX_COMMIT);
+		pr_info_ratelimited("XR500v PPE RX-bind: COMMIT reg-flow to DRAM slot=%u dp=%u (SW-build)\n",
+				    hash, en75_rx_bind_pse);
+	} else {
+		en75_ppe_diag_event(EN75_PPE_DIAG_NOBIND);
+		pr_info_ratelimited("XR500v PPE RX-bind NObind: slot=%u empty, ncand=%d\n",
+				    hash, ncand);
+	}
+out:
+	spin_unlock_bh(&ppe->lock);
+}
+
+/* build #42: the OEM FoeBindToPpe -- called from en75_dev_xmit (conduit TX) on
+ * the EGRESS frame after the RX hook armed a slot. Parse the real egress packet
+ * (post-NAT, post-pppoe-encap, post-DSA-tag), LOG it (ground truth for the BRAS
+ * MAC / pppoe session-id / DSA dp / SNAT'd tuple we can't read otherwise), fill
+ * the COMPLETE EN751221 FoE entry, and commit BIND at the armed slot.
+ *
+ * Egress frame at the conduit (lan3 DSA user -> tagger -> GDM1):
+ *   [0:5] dst=BRAS  [6:11] src=router  [12:15] MTK tag  [16:17] etype 0x8864
+ *   [18:23] pppoe hdr (sid@+4)  [24:25] ppp 0x0021  [26:] IPv4 (NAT'd)
+ * The MTK tag may be absent (direct eth0) -> etype at 12; we locate 0x8864. */
+void en75_ppe_tx_bind(struct en75_ppe *ppe, struct sk_buff *skb)
+{
+	const u8 *d = skb->data, *iph, *l4, *dmac, *smac;
+	unsigned int len = skb->len;
+	struct en75_flow_entry *fe, *cand = NULL;
+	struct mtk_foe_entry e;
+	u32 nsip, ndip;
+	u16 sid = 0, ppp, nsport = 0, ndport = 0, dp_bm = 0;
+	u8 ipproto, ihl;
+	int eo, b, ncand = 0;
+
+	if (len < 48)
+		return;
+	dmac = d;		/* egress dest MAC (BRAS / next-hop) */
+	smac = d + 6;		/* egress src  MAC (router on lan3)  */
+
+	/* locate the PPPoE-session ethertype (0x8864): offset 16 if the MTK special
+	 * tag is present (DSA user-port egress), 12 if not. */
+	if (get_unaligned_be16(d + 16) == ETH_P_PPP_SES) {
+		eo = 16;
+		dp_bm = d[13];		/* MTK tag[1] = (1<<dp_index) | passthrough(bit7) */
+	} else if (get_unaligned_be16(d + 12) == ETH_P_PPP_SES) {
+		eo = 12;
+	} else {
+		return;			/* not a pppoe-session frame -> ignore */
+	}
+	sid = get_unaligned_be16(d + eo + 4);		/* pppoe session-id */
+	ppp = get_unaligned_be16(d + eo + 8);		/* ppp protocol */
+	if (ppp != 0x0021)				/* IPv4 only */
+		return;
+	iph = d + eo + 10;
+	if ((iph[0] >> 4) != 4)
+		return;
+	ihl = (iph[0] & 0x0f) * 4;
+	ipproto = iph[9];
+	nsip = get_unaligned_be32(iph + 12);		/* NAT'd src (pppoe-wan IP) */
+	ndip = get_unaligned_be32(iph + 16);
+	if (ndip != en75_tx_match_dip)			/* not our test flow */
+		return;
+	l4 = iph + ihl;
+	if (ipproto == IPPROTO_UDP || ipproto == IPPROTO_TCP) {
+		nsport = get_unaligned_be16(l4);	/* NAT'd src port (SNAT) */
+		ndport = get_unaligned_be16(l4 + 2);
+	}
+
+	/* GROUND-TRUTH log: the egress fields we cannot read from userspace.
+	 * ratelimited so the per-packet flood doesn't bury the COMMIT log. */
+	pr_info_ratelimited("XR500v TX-bind EGRESS slot=%u dmac=%pM smac=%pM eo=%d dp_bm=%02x sid=0x%04x\n",
+		en75_tx_bind_slot, dmac, smac, eo, dp_bm, sid);
+	pr_info_ratelimited("XR500v TX-bind EGRESS new=%08x:%u -> %08x:%u proto=%u ihl=%u\n",
+		nsip, nsport, ndip, ndport, ipproto, ihl);
+
+	spin_lock_bh(&ppe->lock);
+	for (b = 0; b < EN75_PPE_NUM_FLOWS; b++)
+		hlist_for_each_entry(fe, &ppe->foe_flow[b], list) {
+			cand = fe;
+			ncand++;
+		}
+	if (ncand != 1) {
+		spin_unlock_bh(&ppe->lock);
+		pr_info_ratelimited("XR500v TX-bind: ncand=%d (need 1), skip\n", ncand);
+		return;
+	}
+
+	/* base = the registered flow (carries the ORIG/match 5-tuple the engine
+	 * looks up + ib1 STATE=BIND/cah/ttl + ib2 sentinels), then overlay the
+	 * COMPLETE egress fields (OEM FoeBindToPpe): NAT'd new-tuple, real egress
+	 * MACs, pppoe session, EN751221 dvp, and the DSA dp so the engine re-inserts
+	 * the special tag for lan3. */
+	memcpy(&e, &cand->data, sizeof(e));
+	en75_foe_entry_set_ipv4_tuple(&e, true, htonl(nsip), htons(nsport),
+				      htonl(ndip), htons(ndport));
+	e.ipv4.l2.dest_mac_hi = get_unaligned_be32(dmac);
+	e.ipv4.l2.dest_mac_lo = get_unaligned_be16(dmac + 4);
+	e.ipv4.l2.src_mac_hi  = get_unaligned_be32(smac);
+	e.ipv4.l2.src_mac_lo  = get_unaligned_be16(smac + 4);
+	if (dp_bm & 0x3f)				/* DSA tag: set BEFORE pppoe */
+		en75_foe_entry_set_dsa(&e, __ffs(dp_bm & 0x3f), !!(dp_bm & 0x80));
+	if (sid)
+		en75_foe_entry_set_pppoe(&e, sid);	/* psn=1 + pppoe_id (+keeps DSA etype) */
+	e.ib1 |= BIT(20);	/* EN751221 ib1 bit20 = dvp (keep VPRI); OEM sets it on
+				 * routed binds. NOTE: mainline calls bit20 VLAN_TAG -- on
+				 * THIS chip it is dvp (hwnat-disasm/foe_fdb.h #else). */
+	/* build #45: dest_port tunable via ppe_flip_dp (stock recipe: upstream
+	 * LAN->WAN = 6 QDMA_HW, downstream WAN->LAN = 1 GSW). */
+	en75_foe_entry_set_pse_port(&e, en75_flip_dp);
+	/* build #59: ib2 PORT_MG/AG. OEM stock uses 0x3f (ib2=0x00fff0d0); Codex says
+	 * mainline mt7622 uses 0 for offload v>1 + Composer warns 0x3f (meter group)
+	 * can divert to CPU. ppe_port_mg0=1 -> use 0 to A/B. */
+	e.ipv4.ib2 &= ~(MTK_FOE_IB2_PORT_MG | MTK_FOE_IB2_PORT_AG);
+	if (!READ_ONCE(en75_ppe_port_mg0))
+		e.ipv4.ib2 |= FIELD_PREP(MTK_FOE_IB2_PORT_MG, 0x3f) |
+			      FIELD_PREP(MTK_FOE_IB2_PORT_AG, 0x3f);
+	/* tuple-order A/B for the engine LOOKUP (ppe_tuple_swab, live toggle):
+	 * 0 = network order (OEM PpeFillInL3Info), 1 = swab32 (engine FORWARD_BUILD). */
+	if (READ_ONCE(en75_ppe_tuple_swab)) {
+		e.ipv4.orig.src_ip  = swab32(e.ipv4.orig.src_ip);
+		e.ipv4.orig.dest_ip = swab32(e.ipv4.orig.dest_ip);
+		e.ipv4.orig.ports   = swab32(e.ipv4.orig.ports);
+	}
+	/* build #50: the engine NOW (bidirectional) materializes its keyed UNBIND in
+	 * DRAM, but the global en75_tx_bind_slot is set by the LAST RX crsn (wrong flow
+	 * under concurrency). FIND this egress flow's engine UNBIND by its INVARIANT
+	 * inner dst (dip survives SNAT) -- the engine stores the key swab32(network),
+	 * so match orig.dest_ip == swab32(ndip). PRESERVE that key (real ephemeral ports
+	 * + the exact byte layout the engine's lookup compares) and commit the rewrite
+	 * there. This is OEM PpeSetEntryBind: ib1+rewrite only, never the key. */
+	/* build #55: nf_ct_get(skb) returns NULL at the conduit TX (conntrack is gone
+	 * after pppoe/DSA), so #51's conntrack key failed (ports=0). Use the EGRESS frame
+	 * instead: dip (143.x) and dport (8080) are NAT-INVARIANT -> match the engine's
+	 * upstream UNBIND by dip + dport, no conntrack needed. The engine stores orig.ports
+	 * as swab32(net[sport,dport]) so high16(orig.ports) == swab16(dport). Prefer an
+	 * exact sport match (Linux NAT usually PRESERVES the source port -> nsport ==
+	 * ephemeral), else take any dip+dport entry (the lone live flow). PRESERVE the
+	 * engine's key + commit rewrite (OEM PpeSetEntryBind). */
+	{
+		u32 want_dip   = swab32(ndip);
+		u32 want_ports = swab32(((u32)nsport << 16) | ndport); /* if NAT kept sport */
+		u16 want_dphi  = swab16(ndport);		/* high16 of orig.ports */
+		int i, slot = -1, slot_loose = -1, rx;
+		int dipmatch = 0, st_hist[4] = {0, 0, 0, 0};
+		bool have_key = false;
+
+		/* build #58: the engine's LOOKUP slot for this flow (RX-descriptor
+		 * FOE_ENTRY_NUM recorded per-flow at RX), and its pre-NAT 5-tuple. */
+		rx = en75_ppe_rxslot_lookup(ndip, nsport, ndport);
+
+		if (READ_ONCE(en75_ppe_preserve_key)) {
+			for (i = 0; i < EN75_PPE_ENTRIES; i++) {
+				struct mtk_foe_entry *hwe = (struct mtk_foe_entry *)
+					((u8 *)ppe->foe_virt + (u32)i * EN75_FOE_ENTRY_SIZE);
+				u32 st, dp;
+
+				if (!hwe->ib1 || hwe->ipv4.orig.dest_ip != want_dip)
+					continue;
+				if ((hwe->ipv4.orig.ports >> 16) != want_dphi)	/* dport != 8080 */
+					continue;
+				st = FIELD_GET(MTK_FOE_IB1_STATE, hwe->ib1);
+				dp = FIELD_GET(MTK_FOE_IB2_DEST_PORT, hwe->ipv4.ib2);
+				if (st == MTK_FOE_STATE_INVALID)
+					continue;				/* free slot */
+				dipmatch++;
+				st_hist[st & 3]++;
+				if (st == MTK_FOE_STATE_BIND && dp == en75_flip_dp)
+					continue;			/* already our completed bind */
+				if (hwe->ipv4.orig.ports == want_ports) {
+					slot = i;			/* exact (sport preserved) */
+					e.ipv4.orig = hwe->ipv4.orig;
+					have_key = true;
+					break;
+				}
+				if (slot_loose < 0)
+					slot_loose = i;		/* first dip+dport match */
+			}
+			if (!have_key && slot_loose >= 0) {
+				struct mtk_foe_entry *hwe = (struct mtk_foe_entry *)
+					((u8 *)ppe->foe_virt + (u32)slot_loose * EN75_FOE_ENTRY_SIZE);
+				slot = slot_loose;
+				e.ipv4.orig = hwe->ipv4.orig;
+				have_key = true;
+			}
+		}
+		/* build #58: if the engine has not materialized a DRAM entry to copy the
+		 * exact key from (it's sporadic), RECONSTRUCT orig from the RX-recorded
+		 * pre-NAT tuple, in the engine byte order (swab32 of network). */
+		if (!have_key && rx >= 0) {
+			/* network order by default (the engine LOOKUP parser reads the real
+			 * frame bytes); ppe_tuple_swab=1 -> swab32 (the FORWARD_BUILD layout).
+			 * A/B the two at runtime since we cannot read the lookup byte order. */
+			e.ipv4.orig.src_ip  = en75_rx_ring[rx].sip;
+			e.ipv4.orig.dest_ip = en75_rx_ring[rx].dip;
+			e.ipv4.orig.ports   = ((u32)en75_rx_ring[rx].sport << 16) |
+					      en75_rx_ring[rx].dport;
+			if (READ_ONCE(en75_ppe_tuple_swab)) {
+				e.ipv4.orig.src_ip  = swab32(e.ipv4.orig.src_ip);
+				e.ipv4.orig.dest_ip = swab32(e.ipv4.orig.dest_ip);
+				e.ipv4.orig.ports   = swab32(e.ipv4.orig.ports);
+			}
+			have_key = true;
+		}
+		if (!have_key || rx < 0) {
+			spin_unlock_bh(&ppe->lock);
+			pr_info_ratelimited("XR500v TX-bind(#58): rx=%d scan_key=%d dip=%08x dport=%u (dipmatch=%d st[I/U/B/F]=%d/%d/%d/%d) -- retry\n",
+					    rx, have_key, ndip, ndport, dipmatch,
+					    st_hist[0], st_hist[1], st_hist[2], st_hist[3]);
+			return;
+		}
+		/* commit at the engine LOOKUP slot (RX descriptor) -- foedump proved this
+		 * is where the engine looks up, not the tuple-scan write slot. */
+		cand->hash = en75_rx_ring[rx].slot;
+		en75_foe_entry_commit(ppe, &e, en75_rx_ring[rx].slot);
+		pr_info_ratelimited("XR500v TX-bind(#58) commit LOOKUP slot=%u (scan_slot=%d key=%s) sip=%08x dip=%08x ports=%08x dp=%u ib2=%08x\n",
+			en75_rx_ring[rx].slot, slot, slot >= 0 ? "engine" : "RXrecon",
+			e.ipv4.orig.src_ip, e.ipv4.orig.dest_ip, e.ipv4.orig.ports,
+			en75_flip_dp, e.ipv4.ib2);
+		/* also mirror at the engine write-slot if it materialized + differs */
+		if (slot >= 0 && (u16)slot != en75_rx_ring[rx].slot)
+			en75_foe_entry_commit(ppe, &e, (u16)slot);
+		/* build #60 (Composer P1): the engine serves lookups CAH-first and never
+		 * re-reads our DRAM BIND. Flip the CACHED line to BIND in place so the
+		 * engine HITs it -- the DRAM BIND above supplies the rewrite. */
+		if (READ_ONCE(en75_ppe_cah_bind))
+			en75_ppe_cah_bind_one(ppe, en75_rx_ring[rx].slot,
+				swab32(((u32)en75_rx_ring[rx].sport << 16) |
+				       en75_rx_ring[rx].dport), en75_flip_dp);
+	}
+	WRITE_ONCE(en75_tx_bind_arm, false);		/* one commit per RX arm */
+	spin_unlock_bh(&ppe->lock);
+
+	pr_info_ratelimited("XR500v TX-bind COMMIT(#45 descr) slot=%u swab=%u ib1=%08x ib2=%08x etype=%04x sid=0x%04x dp_bm=%02x\n",
+		en75_tx_bind_slot, READ_ONCE(en75_ppe_tuple_swab), e.ib1, e.ipv4.ib2,
+		e.ipv4.l2.etype, sid, dp_bm);
+}
+
+void en75_ppe_flush_all(struct en75_ppe *ppe)
+{
+	struct en75_flow_entry *e;
+	struct hlist_node *n;
+	int i, removed = 0, freed = 0, kept = 0;
+
+	WRITE_ONCE(en75_ppe_offload_enabled, false);
+	WRITE_ONCE(en75_tx_bind_arm, false);
+	en75_tx_bind_slot = 0xffff;
+	memset(en75_rx_ring, 0, sizeof(en75_rx_ring));
+	en75_rx_ring_idx = 0;
+
+	spin_lock_bh(&ppe->lock);
+	for (i = 0; i < EN75_PPE_NUM_FLOWS; i++) {
+		hlist_for_each_entry_safe(e, n, &ppe->foe_flow[i], list) {
+			en75_foe_entry_clear_locked(ppe, e);
+			hlist_del_init(&e->list);
+			removed++;
+			if (!e->static_entry) {
+				kfree(e);
+				freed++;
+			} else {
+				kept++;
+			}
+		}
+	}
+	memset(ppe->foe_virt, 0, EN75_PPE_ENTRIES * EN75_FOE_ENTRY_SIZE);
+	memset(ppe->foe_check_time, 0,
+	       EN75_PPE_ENTRIES * sizeof(*ppe->foe_check_time));
+	dma_wmb();
+	spin_unlock_bh(&ppe->lock);
+	en75_ppe_cache_clean_all(ppe);
+	pr_info("XR500v PPE flow_clear: removed=%d freed=%d kept=%d FoE=%u entries zeroed\n",
+		removed, freed, kept, EN75_PPE_ENTRIES);
+}
+
+/* --- manual first-light test helpers (driven from module params) --- */
+
+static void en75_build_test_flow(struct mtk_foe_entry *e, __be32 sip, __be32 dip,
+				 __be16 sport, __be16 dport, u8 proto,
+				 const u8 *smac, const u8 *dmac,
+				 int dsa_port, bool passthrough, u8 pse_port)
+{
+	en75_foe_entry_prepare(e, MTK_PPE_PKT_TYPE_IPV4_HNAPT, proto,
+			       pse_port, smac, dmac);
+	en75_foe_entry_set_ipv4_tuple(e, false, sip, sport, dip, dport);
+	en75_foe_entry_set_ipv4_tuple(e, true, sip, sport, dip, dport);	/* no NAT in test */
+	if (dsa_port >= 0)
+		en75_foe_entry_set_dsa(e, dsa_port, passthrough);
+	en75_foe_entry_set_queue(e, dsa_port >= 0 ? 3 + dsa_port : 0);
+	en75_foe_entry_set_pse_port(e, pse_port);	/* 1=GDM1, 7=DISCARD (divert test) */
+	e->ib1 |= MTK_FOE_IB1_STATIC;		/* test flow is never aged */
+}
+
+/* direct commit at the SW hash (STATE=BIND): tests whether the engine HONORS a
+ * SW-written entry on a matching packet (HIT) -> validates egress/tag, no RX dep. */
+u32 en75_ppe_committest(struct en75_ppe *ppe, __be32 sip, __be32 dip,
+			__be16 sport, __be16 dport, u8 proto,
+			const u8 *smac, const u8 *dmac,
+			int dsa_port, bool passthrough, u8 pse_port)
+{
+	struct mtk_foe_entry e;
+	u32 hash;
+
+	en75_build_test_flow(&e, sip, dip, sport, dport, proto, smac, dmac,
+			     dsa_port, passthrough, pse_port);
+	hash = (en75_force_hash != 0xffffffff) ? (en75_force_hash & EN75_PPE_HASH_MASK)
+					       : en75_ppe_hash_entry(&e);
+	spin_lock_bh(&ppe->lock);
+	en75_foe_entry_commit(ppe, &e, hash);
+	spin_unlock_bh(&ppe->lock);
+	pr_info("XR500v PPE committest: hash=%u pse=%u dsa=%d pt=%d ib1=%08x ib2=%08x etype=%04x q=%lu\n",
+		hash, pse_port, dsa_port, passthrough, e.ib1, e.ipv4.ib2, e.ipv4.l2.etype,
+		FIELD_GET(MTK_FOE_IB2_QID, e.ipv4.ib2));
+	return hash;
+}
+
+/* register-only + arm the RX gate: tests the FORWARD_BUILD -> RX bind mechanism. */
+u32 en75_ppe_bindtest_register(struct en75_ppe *ppe, __be32 sip, __be32 dip,
+			       __be16 sport, __be16 dport, u8 proto,
+			       const u8 *smac, const u8 *dmac,
+			       int dsa_port, bool passthrough, u8 pse_port)
+{

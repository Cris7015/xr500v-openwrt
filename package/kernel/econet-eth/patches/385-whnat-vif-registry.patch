 /* ===================================================================== */
+/* WHNAT vif registry (F1): map mt76 AP netdevs <-> WHNAT vif index.       */
+/* The downstream half-offload mux (F2/F3) tags the FoE entry by vif index */
+/* and, on the force-to-CPU RX, resolves index->netdev to dev_queue_xmit   */
+/* the NAT'd frame to the right BSS. mt76 calls register/unregister via    */
+/* weak refs; the lookups stay inside econet-eth (same module).            */
+/* ===================================================================== */
+#define EN75_WHNAT_MAX_VIFS	16	/* = OEM HWNAT_WLAN_IF_MAXNUM */
+
+/* EXPORT_SYMBOL'd -- mt76 (separate module) calls these from add/remove_interface */
+void en75_whnat_register_vif(struct net_device *dev, int idx);
+void en75_whnat_unregister_vif(int idx);
+/* econet-eth-internal: flush on module exit + the F2/F3 lookups */
+void en75_whnat_flush_vifs(void);
+struct net_device *en75_whnat_vif_by_idx(int idx);	/* returns a HELD ref or NULL */
+int en75_whnat_idx_by_dev(const struct net_device *dev);
+int en75_whnat_idx_by_mac(const u8 *mac);

+static void en75_icmp_phase_tx(struct sk_buff *skb, int qid, u16 desc_i)
+{
+	struct en75_icmp_phase_sample found = { 0 };
+	bool matched = false;
+	unsigned long flags;
+	ktime_t tx_time;
+	u16 id, seq;
+	u8 type;
+	int i;
+
+	if (!READ_ONCE(en75_icmp_phase_probe))
+		return;
+
+	if (!en75_icmp_phase_parse_skb(skb, &type, &id, &seq) ||
+	    type != ICMP_ECHOREPLY)
+		return;
+
+	en75_icmp_phase_tx_seen++;
+	tx_time = ktime_get();
+
+	spin_lock_irqsave(&en75_icmp_phase_lock, flags);
+	for (i = 0; i < EN75_ICMP_PHASE_SLOTS; i++) {
+		struct en75_icmp_phase_sample *s;
+		unsigned int slot;
+
+		slot = (en75_icmp_phase_next - 1 - i) &
+		       (EN75_ICMP_PHASE_SLOTS - 1);
+		s = &en75_icmp_phase[slot];
+
+		if (!s->used || s->id != id || s->seq != seq)
+			continue;
+
+		s->used = false;
+		s->tx_time = tx_time;
+		s->tx_cpu = raw_smp_processor_id();
+		s->qtx = qid;
+		s->tx_desc = desc_i;
+		found = *s;
+		matched = true;
+		break;
+	}
+	spin_unlock_irqrestore(&en75_icmp_phase_lock, flags);
+
+	if (matched) {
+		int irq_poll_us = -1;
+		int poll_rx_us = -1;
+		int rx_tx_us = -1;
+		int irq_tx_us = -1;
+		int log_us;
+
+		en75_icmp_phase_tx_match++;
+
+		if (found.irq_time && found.poll_time)
+			irq_poll_us = (int)ktime_us_delta(found.poll_time,
+							  found.irq_time);
+		if (found.poll_time && found.rx_time)
+			poll_rx_us = (int)ktime_us_delta(found.rx_time,
+							 found.poll_time);
+		if (found.rx_time && found.tx_time)
+			rx_tx_us = (int)ktime_us_delta(found.tx_time,
+						       found.rx_time);
+		if (found.irq_time && found.tx_time)
+			irq_tx_us = (int)ktime_us_delta(found.tx_time,
+							found.irq_time);
+
+		log_us = READ_ONCE(en75_icmp_phase_log_us);
+		if (log_us >= 0 &&
+		    (log_us == 0 ||
+		     irq_poll_us >= log_us || poll_rx_us >= log_us ||
+		     rx_tx_us >= log_us || irq_tx_us >= log_us))
+			pr_info("XR500v ICMPPHASE id=%u seq=%u qrx=%u qtx=%u sport=%u desc=%u/%u cpu=%d/%d/%d/%d us=%d/%d/%d/%d hwi=%u cpui=%u irq_status=%08x irq_mask=%08x\n",
+				found.id, found.seq, found.qrx, found.qtx,
+				found.sport, found.rx_desc, found.tx_desc,
+				found.irq_cpu, found.poll_cpu, found.rx_cpu,
+				found.tx_cpu, irq_poll_us, poll_rx_us,
+				rx_tx_us, irq_tx_us, found.rx_hwi,
+				found.rx_cpui, found.irq_status,
+				found.irq_mask);
+	} else {
+		en75_icmp_phase_tx_miss++;
+	}
+}

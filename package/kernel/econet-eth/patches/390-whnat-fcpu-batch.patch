+static void en75_fcpu_batch_init(struct en75_fcpu_batch *batch)
+{
+	int i;
+
+	for (i = 0; i < EN75_FCPU_BATCH_MAX; i++) {
+		__skb_queue_head_init(&batch[i].queue);
+		batch[i].dev = NULL;
+		batch[i].put_dev = false;
+	}
+}
+
+static void en75_fcpu_batch_flush_one(struct en75_fcpu_batch *batch)
+{
+	struct sk_buff *skb;
+
+	if (!batch->dev)
+		return;
+
+	if (batch->queue.qlen > 1 &&
+	    (batch->dev->priv_flags & IFF_NO_QUEUE) &&
+	    !dev_nit_active(batch->dev)) {
+		struct sk_buff *head = NULL, *tail = NULL;
+		unsigned int dev_put_cnt = batch->queue.qlen;
+
+		while ((skb = __skb_dequeue(&batch->queue))) {
+			skb_reset_mac_header(skb);
+			if (!head)
+				head = skb;
+			else
+				tail->next = skb;
+			tail = skb;
+		}
+
+		tail->next = NULL;
+		dev_queue_xmit(head);
+
+		if (batch->put_dev) {
+			while (dev_put_cnt--)
+				dev_put(batch->dev);
+		}
+	} else {
+		while ((skb = __skb_dequeue(&batch->queue))) {
+			dev_queue_xmit(skb);
+			if (batch->put_dev)
+				dev_put(batch->dev);
+		}
+	}
+
+	batch->dev = NULL;
+	batch->put_dev = false;
+}
+
+static void en75_fcpu_batch_flush(struct en75_fcpu_batch *batch)
+{
+	int i;
+
+	for (i = 0; i < EN75_FCPU_BATCH_MAX; i++)
+		en75_fcpu_batch_flush_one(&batch[i]);
+}
+
+static void en75_fcpu_batch_queue(struct en75_fcpu_batch *batch,
+				  struct sk_buff *skb, bool put_dev)
+{
+	struct net_device *dev = skb->dev;
+	int free = -1;
+	int i;
+
+	for (i = 0; i < EN75_FCPU_BATCH_MAX; i++) {
+		if (batch[i].dev == dev && batch[i].put_dev == put_dev) {
+			__skb_queue_tail(&batch[i].queue, skb);
+			return;
+		}
+		if (!batch[i].dev && free < 0)
+			free = i;
+	}
+
+	if (free < 0) {
+		en75_fcpu_batch_flush(batch);
+		free = 0;
+	}
+
+	batch[free].dev = dev;
+	batch[free].put_dev = put_dev;
+	__skb_queue_tail(&batch[free].queue, skb);
+}

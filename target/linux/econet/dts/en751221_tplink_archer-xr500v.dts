/dts-v1/;

#include "en751221.dtsi"
#include <dt-bindings/gpio/gpio.h>

/ {
	model = "TP-Link Archer XR500v v1";
	compatible = "tplink,archer-xr500v", "econet,en751221";

	memory@0 {
		device_type = "memory";
		reg = <0x00000000 0x10000000>;
	};

	chosen {
		stdout-path = "/serial@1fbf0000:115200";
		/*
		 * UBI overlay is attached at preinit time by
		 * /lib/preinit/79_ubi_attach (see base-files), NOT via kernel
		 * cmdline ubi.mtd=. The kernel-time auto-attach was found to
		 * mismark OOB on this NAND via en75_bmt, breaking subsequent
		 * userspace ubiformat. Userspace ubiattach is consistent.
		 */
	};

	leds {
		compatible = "gpio-leds";

		led-2  { label = "green:gpon";     gpios = <&gpio 2  GPIO_ACTIVE_LOW>; linux,default-trigger = "default-on"; };
		led-7  { label = "green:wps";      gpios = <&gpio 7  GPIO_ACTIVE_LOW>; };
		led-11 { label = "green:usb";      gpios = <&gpio 11 GPIO_ACTIVE_LOW>; };
		led-12 { label = "green:wlan2g";   gpios = <&gpio 12 GPIO_ACTIVE_LOW>; };
		led-13 { label = "green:wlan5g";   gpios = <&gpio 13 GPIO_ACTIVE_LOW>; };
		led-24 { label = "red:alarm";      gpios = <&gpio 24 GPIO_ACTIVE_LOW>; };
		led-25 { label = "green:phone1";   gpios = <&gpio 25 GPIO_ACTIVE_LOW>; };
		led-26 { label = "green:phone2";   gpios = <&gpio 26 GPIO_ACTIVE_LOW>; };
		led-28 { label = "green:internet"; gpios = <&gpio 28 GPIO_ACTIVE_LOW>; };
	};
};

&nand {
	status = "okay";
	econet,bmt;
	/*
	 * Allow en75_bmt to write a Bad Block Table to the NAND reserve
	 * area on first boot. Without this property the driver gives up
	 * with "BBT not found" and falls back to per-boot OOB scanning,
	 * which conflicts with UBI's ECC parity in OOB and causes UBI
	 * to misdetect every PEB as bad after a write. With BBT, the
	 * bad-block status comes from the table not the OOB markers,
	 * so UBI persistence works across reboots.
	 */
	econet,can-write-factory-bbt;
	/*
	 * Provide an empty factory-badblocks list so en75_bmt's pub_init takes
	 * the "factory_badblocks given -> reconstruct BMT only" branch and
	 * SKIPS the destructive r_reconstruct_bbt() OOB scan. The OOB scan
	 * walks every block reading byte 0 raw and treats non-0xFF as bad,
	 * but byte 0 gets contaminated by UBI's writes so the scan reports
	 * more false bad blocks each boot. With empty factory-badblocks,
	 * user-area shift stays at 0 across reboots, which keeps the UBIFS
	 * volume's logical->physical mapping stable.
	 *
	 * Real factory bad blocks (if any) in the user area are handled by
	 * UBI itself (CONFIG_MTD_UBI_BEB_LIMIT) — UBI marks them on first
	 * write/erase failure and skips them for life of the volume.
	 */
	econet,factory-badblocks = <>;

	partitions {
		compatible = "fixed-partitions";
		#address-cells = <1>;
		#size-cells = <1>;

		/* XR500v partition layout (from /proc/mtd stock firmware) */

		partition@0 {
			label = "boot";
			reg = <0x0 0x40000>;
			read-only;
		};

		partition@40000 {
			label = "romfile";
			reg = <0x40000 0x40000>;
			read-only;
		};

		partition@80000 {
			label = "kernel";
			reg = <0x80000 0x300000>;
		};

		partition@380000 {
			/*
			 * Slot A rootfs holds the stock OEM squashfs (LZMA-compressed).
			 * Renamed from "rootfs" to "rootfs_stock" so OpenWrt's
			 * mtdsplit-support patch (drivers/mtd/mtdpart.c) does NOT match
			 * this partition by name — otherwise mtdsplit_squashfs runs on
			 * mtd3 (stock) and the global rootfs_found flag prevents it
			 * from running on mtd7 (rootfs1) where we actually need the
			 * overlay split.
			 */
			label = "rootfs_stock";
			reg = <0x380000 0x1000000>;
			read-only;
		};

		misc_partition: partition@1380000 {
			compatible = "nvmem-cells";
			label = "misc";
			reg = <0x1380000 0x480000>;
			#address-cells = <1>;
			#size-cells = <1>;
			read-only;

			/*
			 * Factory-programmed device data lives in this partition.
			 * Confirmed via `dd if=/dev/mtd_misc skip=0xF100 count=6`
			 * matching the same offset in the OEM stock dump:
			 *   0xF100: <ETH MAC, 6 bytes>
			 * The rest of the partition (most of it) is 0xFF padding.
			 */
			macaddr_misc_f100: macaddr@f100 {
				reg = <0xf100 0x6>;
			};

			/*
			 * iter36: MT7662 factory EEPROM (chip ID 0x7662 confirmado
			 * en byte 0). 512 bytes que contienen calibration data
			 * (TX power per-channel, etc). El driver mt76x2e la lee via
			 * nvmem-cells = <&eeprom_misc_e0000>; nvmem-cell-names = "eeprom".
			 * Sin esto, el driver usa defaults conservadores (TX=3dBm).
			 */
			eeprom_misc_e0000: eeprom@e0000 {
				reg = <0xe0000 0x200>;
			};
		};

		partition@1800000 {
			label = "kernel1";
			reg = <0x1800000 0x300000>;
		};

		partition@1b00000 {
			/*
			 * Slot B rootfs (raw squashfs).
			 * linux,rootfs marca esta partition como root device para
			 * mount_root. mtd-split-squashfs sigue creando una sub
			 * "rootfs_data" automáticamente post-squashfs end, pero a
			 * partir de iter35 NO la usamos: el overlay UBI vive en
			 * partition propia "openwrt_ubi" en el área libre
			 * 0x3000000-0x7000000 (confirmada vacía con dump completo).
			 * El preinit hook 79_ubi_attach ahora apunta a openwrt_ubi.
			 */
			label = "rootfs1";
			reg = <0x1b00000 0x1000000>;
			linux,rootfs;
		};

		partition@2b00000 {
			label = "others";
			reg = <0x2b00000 0x4e0000>;
		};

		partition@2fe0000 {
			label = "bootflag";
			reg = <0x2fe0000 0x20000>;
		};

		/*
		 * iter35: dedicated UBI partition in the unused free area.
		 *
		 * El stock OEM expone /dev/mtd0 = "ALL" de 0x07000000 (112MB)
		 * — eso es el espacio "user" del en75_bmt antes de su reserve
		 * area (922 user blocks * 128KB = ~115MB, OEM reporta 112MB).
		 * Las 9 particiones existentes suman 0x3000000 (48MB), dejando
		 * 0x3000000-0x7000000 (64MB) disponibles. Confirmado erased
		 * con dump completo el 2026-05-08 (16 chunks de 4MB todos
		 * hash md5 = 4MB de 0xff puro).
		 *
		 * Esta partition se provisiona con ubiformat/ubiattach/ubimkvol
		 * desde running OpenWrt (one-time per device); el preinit hook
		 * 79_ubi_attach la atachea cada boot.
		 */
		partition@3000000 {
			label = "openwrt_ubi";
			reg = <0x3000000 0x4000000>;
		};
	};
};


&gmac0 {
	status = "okay";
	nvmem-cells = <&macaddr_misc_f100>;
	nvmem-cell-names = "mac-address";
};

/*
 * Plan B (correct model, Caleb's dual-switch MDIO/MCM):
 * switch0 is the MCM MT7530 (mediatek,mt7530 + mediatek,mcm) hanging off the
 * SoC ethernet's MDIO bus at address 0x1f. It has 4 user GE ports (port@0..3)
 * and port@6 = CPU (trgmii to gmac0). The on-die switch is configured by
 * the bootloader for the cascade and is NOT a DSA device.
 * Internal PHYs of the MCM switch are auto-detected by the mt7530 driver.
 */
&switch0port0 {
	status = "disabled";
};

&switch0port1 {
	status = "okay";
	label = "lan4";
};

&switch0port2 {
	status = "okay";
	label = "lan3";
};

&switch0port3 {
	status = "okay";
	label = "lan2";
};

&switch0port4 {
	status = "okay";
	label = "lan1";
};

/*
 * iter57 v2: Enable PCIe (perdió status=okay al rewrite del dts)
 * pcie0 = port0 (no slot ahí)
 * pcie1 + slot1 = MT7662 WiFi card
 */

&pcie0 {
	status = "okay";
};

&pcie1 {
	status = "okay";
};

&slot1 {
	wifi@0,0 {
		/* MT7662 dual-band 802.11ac */
		compatible = "mediatek,mt76";
		reg = <0x0000 0 0 0 0>;
		nvmem-cells = <&eeprom_misc_e0000>, <&macaddr_misc_f100>;
		nvmem-cell-names = "eeprom", "mac-address";
	};
};

/* Plan B dual-switch: no port@5/phy overrides — the MCM switch auto-detects
 * its internal PHYs and the on-die cascade is bootloader-configured.
 */

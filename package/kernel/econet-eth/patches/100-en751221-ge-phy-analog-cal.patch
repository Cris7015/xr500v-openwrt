+	/* Restore original BMCR + a few regs */
+	if (reg0_temp >= 0)
+		phy_write(phydev, MII_BMCR, reg0_temp);
+	en751221_mmd_write(phydev, 0x1f, 0x0100, 0x0000);
+	if (dev1e_145_temp >= 0)
+		en751221_mmd_write(phydev, 0x1e, 0x0145, dev1e_145_temp);
+
+	phydev_info(phydev, "ITER58: GE PHY analog cal complete\n");
+}

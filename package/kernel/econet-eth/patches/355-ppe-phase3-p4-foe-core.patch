+static struct en75_ppe_diag_counters en75_ppe_diag = {
+	.first_slot = ATOMIC_INIT(-1),
+	.last_slot = ATOMIC_INIT(-1),
+};
+
+static void en75_ppe_diag_hist_inc(atomic_t *hist, u8 crsn)
+{
+	if (crsn < EN75_PPE_DIAG_CRSN_BUCKETS)
+		atomic_inc(&hist[crsn]);
+}
+
+static void en75_ppe_diag_note_slot(u16 hash)
+{
+	int old;
+
+	atomic_cmpxchg(&en75_ppe_diag.first_slot, -1, hash);
+	old = atomic_xchg(&en75_ppe_diag.last_slot, hash);
+	if (old >= 0 && old != hash)
+		atomic_inc(&en75_ppe_diag.slot_changes);
+}
+
+void en75_ppe_diag_sample(u16 hash, u8 crsn)
+{
+	atomic_inc(&en75_ppe_diag.pre_total);
+	en75_ppe_diag_hist_inc(en75_ppe_diag.pre_hist, crsn);
+	en75_ppe_diag_note_slot(hash);
+}
+
+void en75_ppe_diag_invalid(u16 hash, u8 crsn)
+{
+	atomic_inc(&en75_ppe_diag.invalid_hash);
+	en75_ppe_diag_note_slot(hash);
+}
+
+void en75_ppe_diag_rate_limited(u16 hash, u8 crsn)
+{
+	atomic_inc(&en75_ppe_diag.rate_limited);
+	en75_ppe_diag_hist_inc(en75_ppe_diag.limited_hist, crsn);
+	en75_ppe_diag_note_slot(hash);
+}
+
+void en75_ppe_diag_after_rate(u16 hash, u8 crsn)
+{
+	atomic_inc(&en75_ppe_diag.post_total);
+	en75_ppe_diag_hist_inc(en75_ppe_diag.post_hist, crsn);
+	en75_ppe_diag_note_slot(hash);
+}
+
+void en75_ppe_diag_gate_skip(u8 crsn)
+{
+	atomic_inc(&en75_ppe_diag.gate_skip);
+	en75_ppe_diag_hist_inc(en75_ppe_diag.gate_skip_hist, crsn);
+}
+
+void en75_ppe_diag_event(enum en75_ppe_diag_event event)
+{
+	switch (event) {
+	case EN75_PPE_DIAG_GATE_PASS:
+		atomic_inc(&en75_ppe_diag.gate_pass);
+		break;
+	case EN75_PPE_DIAG_PREBIND_PROMOTE:
+		atomic_inc(&en75_ppe_diag.prebind_promote);
+		break;
+	case EN75_PPE_DIAG_PREBIND_ARM:
+		atomic_inc(&en75_ppe_diag.prebind_arm);
+		break;
+	case EN75_PPE_DIAG_FLIP:
+		atomic_inc(&en75_ppe_diag.flip);
+		break;
+	case EN75_PPE_DIAG_RX_COMMIT:
+		atomic_inc(&en75_ppe_diag.rx_commit);
+		break;
+	case EN75_PPE_DIAG_NOBIND:
+		atomic_inc(&en75_ppe_diag.nobind);
+		break;
+	case EN75_PPE_DIAG_TX_ARM:
+		atomic_inc(&en75_ppe_diag.tx_arm);
+		break;
+	}
+}

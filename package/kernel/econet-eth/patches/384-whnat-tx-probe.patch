+/* patch 383: WHNAT TX probe (Phase 0 fail-fast).
+ * Build a synthetic broadcast frame with a recognizable "WHNATPROBE" marker,
+ * optionally insert the WiFi mux VLAN tag, and post it to the QDMA TX ring with
+ * the OEM WiFi msg (raw[0]=0x38 -> channel 7/queue 0; raw[1]=0x200000 -> WiFi
+ * fport, bit 21). If the SoC wires a QDMA->PCIe-MT7603 inject path, the chip
+ * transmits this over the air -- observe with a monitor sniffer on the AP's
+ * channel (the AP must be "wifi up"). set_imm ORs TX_IMMEDIATE_DONE live (the
+ * OEM sets it and we don't -- suspect #1: the WiFi egress yields no GDM "Done",
+ * so the QDMA must self-complete the descriptor). Nothing here touches the
+ * PPE/NAT: this isolates the single irreducible HW unknown. */
+int en75_whnat_tx_probe(struct en75_qdma *qdma, u16 vid, unsigned int tag,
+			bool set_imm, u32 msg0, u32 msg1)
+{
+	static const u8 src_mac[ETH_ALEN] = { 0x02, 'W', 'H', 'N', 'A', 'T' };
+	static unsigned int seq;
+	union desc_msg msg = { 0 };
+	struct sk_buff *skb;
+	char *pl;
+	u8 *p;
+	int ret;
+
+	if (!qdma)
+		return -ENODEV;
+
+	if (set_imm) {
+		struct qregs_qcfg qcfg = en75_rreg(&qdma->regs->qdma_cfg);
+
+		set_qregs_qcfg_tx_immediate_done(&qcfg, true);
+		en75_wreg(qcfg, &qdma->regs->qdma_cfg);
+	}
+
+	skb = netdev_alloc_skb(NULL, ETH_FRAME_LEN);
+	if (!skb)
+		return -ENOMEM;
+	skb_reserve(skb, NET_SKB_PAD);
+
+	p = skb_put(skb, 2 * ETH_ALEN);
+	eth_broadcast_addr(p);				/* dst = broadcast */
+	memcpy(p + ETH_ALEN, src_mac, ETH_ALEN);	/* src = 02:57:48:4e:41:54 */
+
+	if (tag == 1 || tag == 2) {			/* WiFi mux tag */
+		p = skb_put(skb, 4);
+		put_unaligned(htons(tag == 1 ? 0x5678 : ETH_P_8021Q),
+			      (__be16 *)p);
+		put_unaligned(htons(vid), (__be16 *)(p + 2));
+	}
+
+	p = skb_put(skb, 2);				/* inner ethertype */
+	put_unaligned(htons(ETH_P_IP), (__be16 *)p);
+
+	pl = skb_put(skb, 60);				/* payload + pad */
+	memset(pl, 0, 60);
+	scnprintf(pl, 60, "WHNATPROBE-%u", seq);
+
+	msg.raw[0] = msg0;
+	msg.raw[1] = msg1;
+
+	ret = en75_qdma_xmit(qdma, skb, &msg, 0);
+	pr_info("XR500v WHNAT probe seq=%u vid=%u tag=%u imm=%d msg=%08x/%08x -> ret=%d\n",
+		seq, vid, tag, set_imm, msg0, msg1, ret);
+	seq++;
+	if (ret < 0)
+		kfree_skb(skb);
+	return ret;
+}

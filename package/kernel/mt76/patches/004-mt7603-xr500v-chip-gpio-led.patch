+/* XR500v: the 2.4GHz panel LED is wired to MT7603 chip-internal GPIO12 and
+ * GPIO13 (both drive the same LED, active-low), reached only through the PCIe
+ * remap-2 window via mt7603_reg_map(). The pad the MAC LED block (0x80024000)
+ * targets is not routed to this board's LED, so drive the GPIOs directly.
+ */
+static void mt7603_gpio_led_init(struct mt7603_dev *dev)
+{
+	u32 addr, val;
+
+	/* PINMUX_SEL2: select GPIO function (0x2) for pads 12 and 13 */
+	addr = mt7603_reg_map(dev, MT_GPIO_PINMUX_SEL2);
+	val = mt76_rr(dev, addr);
+	val &= ~(MT_GPIO_PINMUX_SEL2_G12 | MT_GPIO_PINMUX_SEL2_G13);
+	val |= FIELD_PREP(MT_GPIO_PINMUX_SEL2_G12, 0x2) |
+	       FIELD_PREP(MT_GPIO_PINMUX_SEL2_G13, 0x2);
+	mt76_wr(dev, addr, val);
+
+	/* enable GPIO12/13 as outputs */
+	addr = mt7603_reg_map(dev, MT_GPIO_OE1_SET);
+	mt76_wr(dev, addr, MT_GPIO_LED_MASK);
+}
+
+static void mt7603_gpio_led_set(struct mt7603_dev *dev, bool on)
+{
+	u32 addr;
+
+	/* active-low: drive low = LED on */
+	if (on)
+		addr = mt7603_reg_map(dev, MT_GPIO_DOUT1_RESET);
+	else
+		addr = mt7603_reg_map(dev, MT_GPIO_DOUT1_SET);
+	mt76_wr(dev, addr, MT_GPIO_LED_MASK);
+}
+
+/* Return an error so the LED core falls through to software blink
+ * (led_blink_setup -> led_set_software_blink), whose timer then toggles our
+ * brightness_set ~1 Hz -> a real activity blink on chip GPIO12/13. The MAC
+ * LED block's hardware blink does not reach this board's pad.
+ */
+static int mt7603_gpio_led_set_blink(struct led_classdev *led_cdev,
+				     unsigned long *delay_on,
+				     unsigned long *delay_off)
+{
+	return -EINVAL;
+}

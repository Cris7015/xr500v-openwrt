+static bool en75_icmp_phase_parse_ip(const u8 *data, unsigned int len,
+				     u8 *type, u16 *id, u16 *seq)
+{
+	unsigned int ihl;
+	u16 frag;
+
+	if (len < 20)
+		return false;
+
+	if ((data[0] >> 4) != 4)
+		return false;
+
+	ihl = (data[0] & 0x0f) * 4;
+	if (ihl < 20 || len < ihl + 8)
+		return false;
+
+	if (data[9] != IPPROTO_ICMP)
+		return false;
+
+	frag = get_unaligned_be16(data + 6);
+	if (frag & (EN75_ICMP_IP_MF | EN75_ICMP_IP_OFFSET))
+		return false;
+
+	if (data[ihl] != ICMP_ECHO && data[ihl] != ICMP_ECHOREPLY)
+		return false;
+
+	*type = data[ihl];
+	*id = get_unaligned_be16(data + ihl + 4);
+	*seq = get_unaligned_be16(data + ihl + 6);
+
+	return true;
+}
+
+static bool en75_icmp_phase_parse_l2(const u8 *data, unsigned int len,
+				     unsigned int proto_off,
+				     u8 *type, u16 *id, u16 *seq)
+{
+	unsigned int off = proto_off + 2;
+	u16 proto;
+
+	if (len < proto_off + 2)
+		return false;
+
+	proto = get_unaligned_be16(data + proto_off);
+	while ((proto == ETH_P_8021Q || proto == ETH_P_8021AD ||
+		proto == 0x5678) &&
+	       len >= off + EN75_ICMP_VLAN_HLEN) {
+		proto = get_unaligned_be16(data + off + 2);
+		off += EN75_ICMP_VLAN_HLEN;
+	}
+
+	return proto == ETH_P_IP &&
+	       en75_icmp_phase_parse_ip(data + off, len - off,
+					type, id, seq);
+}
+
+static bool en75_icmp_phase_parse_skb(const struct sk_buff *skb,
+				      u8 *type, u16 *id, u16 *seq)
+{
+	const u8 *data = skb->data;
+	unsigned int len = skb_headlen(skb);
+
+	if (en75_icmp_phase_parse_l2(data, len, 12, type, id, seq))
+		return true;
+
+	if (en75_icmp_phase_parse_l2(data, len, 16, type, id, seq))
+		return true;
+
+	if (skb->protocol == htons(ETH_P_IP) &&
+	    en75_icmp_phase_parse_ip(data, len, type, id, seq))
+		return true;
+
+	return false;
+}
+
+static void en75_icmp_phase_rx(struct en75_q_rx *q, struct sk_buff *skb,
+			       u32 desc_i, u8 sport, u8 qid)
+{
+	struct en75_icmp_phase_sample *s;
+	unsigned long flags;
+	u16 id, seq;
+	u8 type;
+
+	if (!READ_ONCE(en75_icmp_phase_probe))
+		return;
+
+	if (!en75_icmp_phase_parse_skb(skb, &type, &id, &seq) ||
+	    type != ICMP_ECHO)
+		return;
+
+	en75_icmp_phase_rx_seen++;
+
+	spin_lock_irqsave(&en75_icmp_phase_lock, flags);
+	s = &en75_icmp_phase[en75_icmp_phase_next++ &
+			     (EN75_ICMP_PHASE_SLOTS - 1)];
+	*s = (struct en75_icmp_phase_sample) {
+		.used = true,
+		.id = id,
+		.seq = seq,
+		.rx_desc = desc_i,
+		.qrx = qid,
+		.sport = sport,
+		.irq_cpu = q->last_irq_cpu,
+		.poll_cpu = q->last_poll_cpu,
+		.rx_cpu = raw_smp_processor_id(),
+		.irq_status = q->last_irq_status,
+		.irq_mask = q->last_irq_mask,
+		.rx_hwi = q->last_rx_hwi,
+		.rx_cpui = q->last_rx_cpui,
+		.irq_time = q->last_irq_time,
+		.poll_time = q->last_poll_time,
+		.rx_time = ktime_get(),
+	};
+	spin_unlock_irqrestore(&en75_icmp_phase_lock, flags);
+}

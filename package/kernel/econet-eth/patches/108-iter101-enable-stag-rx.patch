--- a/econet_eth.c	2026-05-10 13:27:27.136460641 +0000
+++ b/econet_eth.c	2026-05-10 13:27:27.150290115 +0000
@@ -381,6 +381,17 @@
 
 	eth->debug = en75_debugfs_init(&debug_conf);
 
+	/*
+	 * iter102: Replicate OEM macEN7512STagEnable to enable hardware STAG
+	 * insertion on RX (switch -> CPU). All 4 writes needed; stag_en alone
+	 * insufficient. See gdm_regs.h: stag_en, fwd_cfg accessors.
+	 */
+	writel(1, &regs->port0.regs.stag_en);
+	writel(readl(&regs->port0.regs.fwd_cfg.word) | (1u << 24),
+	       &regs->port0.regs.fwd_cfg.word);
+	writel(0x81000001u, (u32 __iomem *)&regs->port0.regs.vlan);
+
+

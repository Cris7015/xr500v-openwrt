. /lib/functions/uci-defaults.sh

board_config_update

board=$(board_name)

case "$board" in
tplink,archer-xr500v)
	ucidef_set_interface_lan "lan1 lan2 lan3 lan4"
	ucidef_set_interface_wan "wan" "dhcp"
	;;
*)
	ucidef_set_interfaces_lan_wan "lan1 lan2 lan3 lan4" "wan"
	;;
esac

board_config_flush

exit 0

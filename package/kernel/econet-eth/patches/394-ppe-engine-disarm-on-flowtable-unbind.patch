+/* Symmetric teardown for en75_ppe_engine_arm. Called from FLOW_BLOCK_UNBIND
+ * when the LAST flowtable block goes away (toggle offload to none/sw, firewall
+ * reload). Without it the engine stays armed and GDM1_FWD(0x500) keeps steering
+ * ALL conduit ingress into a PPE whose FoE entries are stale/empty -> a black
+ * hole that persists until reboot (the en75_ppe_armed latch also makes any
+ * corrective re-arm a no-op). Reverse order of arm: de-steer GDM1 back to CPU
+ * FIRST so traffic falls back to the SW path, only THEN flush the FoE table and
+ * disable the engine -- never leave traffic steered into a torn-down engine. */
+void en75_ppe_engine_disarm(struct en75_ppe *ppe)
+{
+	if (!ppe || !en75_ppe_base)
+		return;
+	if (!READ_ONCE(en75_ppe_armed))		/* not armed -> no-op (symmetric guard) */
+		return;
+	en75_ppe_fe_rw(ppe, 0x500, true, 0x03f00000);	/* GDM1_FWD: steer back to CPU */
+	en75_ppe_flush_all(ppe);			/* invalidate FoE + clear offload_enabled */
+	en75_ppe_engine_set(false);			/* GLO_CFG.EN off */
+	WRITE_ONCE(en75_ppe_engine, false);
+	WRITE_ONCE(en75_ppe_armed, false);		/* clear latch -> next BIND re-arms clean */
+	pr_info("XR500v PPE: engine DISARMED (flowtable UNBIND, list empty) GDM1_FWD=0x%08x\n",
+		readl(ppe->fe_base + 0x500));
+}
+

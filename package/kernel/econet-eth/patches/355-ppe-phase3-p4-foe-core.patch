+/* ===================================================================== */
+/* Phase 5 (binding): attach + egress builders + foe_flow core + RX bind  */
+/* ===================================================================== */
+
+bool en75_ppe_offload_enabled;	/* RX hook is inert until a test/offload arms it */
+bool en75_ppe_rxdump;		/* diagnostic: dump crsn/ppe_entry on RX */
+bool en75_ppe_atomic;		/* build #41: one-shot atomic cache+DRAM dump from RX hook */
+bool en75_ppe_foedump;		/* diagnostic: dump the engine-built FoE entry */
+u32  en75_force_hash = 0xffffffff;  /* committest: if != ~0, commit at this slot (engine hash) */
+
+/* build #42 TX-hook (OEM FoeBindToPpe model): RX arms the slot, TX fills the
+ * COMPLETE entry from the egress packet and commits. See econet_ppe.h. */
+bool en75_ppe_tx_hook;		/* master enable */
+bool en75_tx_bind_arm;		/* set by RX hook, cleared by TX hook after commit */
+u32  en75_tx_match_dip;		/* network-order inner IPv4 dst that flags the test egress frame */
+u8   en75_ppe_tuple_swab;	/* build #44: 1 = store orig tuple swab32 (engine LOOKUP encoding) */
+bool en75_ppe_preserve_key = true;	/* build #48: keep the engine's UNBIND key, only add rewrite */
+bool en75_ppe_mirror_lookup;		/* build #56: also write BIND at the RX-descriptor lookup slot */
+bool en75_ppe_use_rxslot = true;	/* build #57: commit at the RX-recorded descriptor (lookup) slot */
+bool en75_ppe_port_mg0;			/* build #59: ib2 PORT_MG/AG=0 (vs OEM 0x3f) A/B */
+bool en75_ppe_cah_bind = true;		/* build #60: in-cache BIND (flip the CAH line) */
+bool en75_ppe_prebind = true;		/* build #61: OEM PREBIND handshake (preb=1, NOT state=BIND) */
+bool en75_ppe_oemregs;			/* build #61: OEM reg-config toggle (default OFF; PPE-block
+					 * GLO_CFG=0x763 has bit6 which HUNG the device in cont15 --
+					 * placeholder param, NOT wired this build; prebind is the lever) */
+
+/* build #57: per-flow RX->TX carry of the engine's LOOKUP slot (the RX-descriptor
+ * FOE_ENTRY_NUM). The RX hook records (pre-NAT tuple -> descriptor slot) for our
+ * test flow; the TX hook (post-NAT) looks it up by the NAT-invariant dst + dport
+ * and binds at THAT slot, where the engine actually looks up (foedump proved the
+ * tuple-scan write-slot is NOT the lookup slot). Ring is small + best-effort. */
+struct en75_rx_slot { u32 sip, dip; u16 sport, dport, slot; u8 valid; };
+static struct en75_rx_slot en75_rx_ring[32];
+static u8 en75_rx_ring_idx;
+
+void en75_ppe_rx_record(struct en75_ppe *ppe, struct sk_buff *skb, u16 hash)
+{
+	const u8 *d = skb->data, *iph, *l4;
+	unsigned int len = skb->len;
+	int eo = 0;
+	u8 ihl, proto, i;
+
+	if (!READ_ONCE(en75_ppe_tx_hook) || hash >= EN75_PPE_ENTRIES || len < 40)
+		return;
+	/* locate the IPv4 ethertype past the optional 4-byte MTK special tag / VLAN */
+	if (get_unaligned_be16(d + 12) == ETH_P_IP)
+		eo = 14;
+	else if (get_unaligned_be16(d + 16) == ETH_P_IP)
+		eo = 18;					/* 4-byte special tag at d[12] */
+	else if (get_unaligned_be16(d + 12) == ETH_P_8021Q &&
+		 get_unaligned_be16(d + 16) == ETH_P_IP)
+		eo = 18;
+	else
+		return;
+	iph = d + eo;
+	if ((iph[0] >> 4) != 4)
+		return;
+	proto = iph[9];
+	if (proto != IPPROTO_TCP && proto != IPPROTO_UDP)
+		return;
+	if (get_unaligned_be32(iph + 16) != en75_tx_match_dip)	/* only our test flow */
+		return;
+	ihl = (iph[0] & 0x0f) * 4;
+	l4 = iph + ihl;
+	i = en75_rx_ring_idx++ & 31;
+	en75_rx_ring[i].sip   = get_unaligned_be32(iph + 12);
+	en75_rx_ring[i].dip   = get_unaligned_be32(iph + 16);
+	en75_rx_ring[i].sport = get_unaligned_be16(l4);
+	en75_rx_ring[i].dport = get_unaligned_be16(l4 + 2);
+	en75_rx_ring[i].slot  = hash;
+	en75_rx_ring[i].valid = 1;
+	pr_info_ratelimited("XR500v RX-rec(#57) slot=%u eo=%d %08x:%u -> %08x:%u\n",
+		hash, eo, en75_rx_ring[i].sip, en75_rx_ring[i].sport,
+		en75_rx_ring[i].dip, en75_rx_ring[i].dport);
+}
+
+/* find the RX-record (ring index) for an egress flow, matched by the NAT-invariant
+ * dst+dport; prefer the entry whose sport matches (NAT preserved it). Returns the
+ * ring index (caller reads .slot/.sip/.sport) or -1. */
+static int en75_ppe_rxslot_lookup(u32 ndip, u16 nsport, u16 ndport)
+{
+	int i, idx = -1;
+
+	for (i = 0; i < 32; i++) {
+		if (!en75_rx_ring[i].valid || en75_rx_ring[i].dip != ndip ||
+		    en75_rx_ring[i].dport != ndport)
+			continue;
+		idx = i;
+		if (en75_rx_ring[i].sport == nsport)
+			break;				/* exact (sport preserved) */
+	}
+	return idx;
+}
+static u16 en75_tx_bind_slot;	/* the engine-reported FoE slot to bind (from RX) */
+
+/* build #43: FLIP-IN-PLACE (OEM model) -- patch the engine-built entry, not from-scratch */
+bool en75_ppe_flip;		/* master enable for the flip-in-place RX hook */
+u8   en75_flip_dp = 1;		/* ib2.dp egress port: 1=GSW(LAN switch), 2=GMAC(WAN) */
+/* build #68: act only when the engine ASKS for the bind (crsn=0x0f RATE_REACHED),
+ * like the OEM PpeRxHandler. Binding mid-build (crsn=0x0e) loses the race: the
+ * engine re-FORWARD_BUILDs over our BIND (~100ms fight, ppeV5/V6 2026-06-10). */
+bool en75_ppe_bind_on_rate;

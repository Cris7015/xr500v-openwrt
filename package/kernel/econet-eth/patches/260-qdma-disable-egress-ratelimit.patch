+		 en75_rreg(&qdma->regs->tx_limit_param));
+	en75_wreg(0U, &qdma->regs->tx_meter_cfg);
+	en75_wreg(0U, &qdma->regs->tx_limit_cfg);
+	en75_wreg(0U, &qdma->regs->tx_limit_param);

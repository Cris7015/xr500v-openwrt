+/* patch 379: exact-tuple lookup for the TC_SETUP_FT replace. The RX hook records
+ * (pre-NAT tuple -> engine LOOKUP slot); the flowtable gives us that same pre-NAT
+ * 5-tuple (the orig match), so the replace commits at THAT slot -- build #57: the
+ * engine looks up there, NOT at en75_ppe_hash_entry(). Args in host order.
+ * Returns the engine slot, or -1 if the flow hasn't been seen on RX yet. */
+int en75_ppe_ft_lookup_slot(u32 sip, u32 dip, u16 sport, u16 dport)
+{
+	int i;
+
+	for (i = 0; i < 32; i++)
+		if (en75_rx_ring[i].valid &&
+		    en75_rx_ring[i].sip == sip && en75_rx_ring[i].dip == dip &&
+		    en75_rx_ring[i].sport == sport && en75_rx_ring[i].dport == dport)
+			return en75_rx_ring[i].slot;
+	return -1;
+}
+/* patch 380 (Hito 2c): multi-flow RX bind for the flowtable. The TC_SETUP_FT replace
+ * REGISTERS each flow's entry (real-IP tuple + NAT rewrite) in foe_flow[]; when the
+ * engine FORWARD_BUILDs that flow's slot and reports it on RX, commit the matching
+ * registered entry at the engine's slot (build #43/RANK-1: from-scratch slots are
+ * ignored; only a commit at the engine's reported slot binds). Picks the registered
+ * entry whose orig pre-NAT 5-tuple matches THIS RX frame. Caller holds ppe->lock. */
+void en75_ppe_ft_rx_bind(struct en75_ppe *ppe, struct sk_buff *skb, u16 hash)
+{
+	const u8 *d = skb->data, *iph, *l4;
+	unsigned int len = skb->len;
+	struct en75_flow_entry *e;
+	struct hlist_node *n;
+	u32 sip, dip;
+	u16 sport, dport;
+	int eo = 0, po, b;
+	u8 ihl;
+
+	if (get_unaligned_be16(d + 12) == ETH_P_IP)
+		eo = 14;
+	else if (get_unaligned_be16(d + 16) == ETH_P_IP)
+		eo = 18;
+	else if (get_unaligned_be16(d + 12) == ETH_P_8021Q &&
+		 get_unaligned_be16(d + 16) == ETH_P_IP)
+		eo = 18;
+	else if (get_unaligned_be16(d + 16) == ETH_P_PPP_SES) {
+		po = 16;
+		if (len < po + 30 || get_unaligned_be16(d + po + 8) != 0x0021)
+			return;
+		eo = po + 10;
+	} else if (get_unaligned_be16(d + 12) == ETH_P_PPP_SES) {
+		po = 12;
+		if (len < po + 30 || get_unaligned_be16(d + po + 8) != 0x0021)
+			return;
+		eo = po + 10;
+	} else
+		return;
+	if (len < eo + 20)
+		return;
+	iph = d + eo;
+	if ((iph[0] >> 4) != 4 || (iph[9] != IPPROTO_TCP && iph[9] != IPPROTO_UDP))
+		return;
+	ihl = (iph[0] & 0x0f) * 4;
+	if (len < eo + ihl + 4)
+		return;
+	l4 = iph + ihl;
+	sip = get_unaligned_be32(iph + 12);
+	dip = get_unaligned_be32(iph + 16);
+	sport = get_unaligned_be16(l4);
+	dport = get_unaligned_be16(l4 + 2);
+
+	for (b = 0; b < EN75_PPE_NUM_FLOWS; b++)
+		hlist_for_each_entry_safe(e, n, &ppe->foe_flow[b], list) {
+			/* patch 380d: match by the host-order tuple stored at register time. */
+			if (e->ft_sip == sip && e->ft_dip == dip &&
+			    e->ft_sport == sport && e->ft_dport == dport) {
+				struct mtk_foe_entry *hwe = (struct mtk_foe_entry *)
+					((u8 *)ppe->foe_virt +
+					 (u32)hash * EN75_FOE_ENTRY_SIZE);
+				struct mtk_foe_entry fin = e->data;	/* the rewrite */
+
+				/* patch 380e PRESERVE_KEY (build #74, like en75_ppe_tx_bind): commit
+				 * the engine's EXACT orig key, NOT ours -- the engine LOOKUP only HITs
+				 * its own FORWARD_BUILD byte layout (op139..2d: our-order orig never
+				 * HIT -> re-build forever). Copy its RAW words + pre-swab32 so commit's
+				 * swab_all round-trips them byte-identical to the engine's own. */
+				fin.ipv4.orig = hwe->ipv4.orig;
+				if (READ_ONCE(en75_ppe_swab_all)) {
+					fin.ipv4.orig.src_ip  = swab32(fin.ipv4.orig.src_ip);
+					fin.ipv4.orig.dest_ip = swab32(fin.ipv4.orig.dest_ip);
+					fin.ipv4.orig.ports   = swab32(fin.ipv4.orig.ports);
+				}
+				e->hash = hash;
+				en75_foe_entry_commit(ppe, &fin, hash);
+				pr_info_ratelimited("XR500v FT(380) RX-bind slot=%u %08x:%u->%08x:%u (preserve-key)\n",
+						    hash, sip, sport, dip, dport);
+				return;
+			}
+		}
+}
+/* patch 380: FLOW_CLS_DESTROY -- unregister + free the entry with this cookie. */
+void en75_ppe_ft_unregister_cookie(struct en75_ppe *ppe, unsigned long cookie)
+{
+	struct en75_flow_entry *e, *found = NULL;
+	struct hlist_node *n;
+	int b;
+
+	spin_lock_bh(&ppe->lock);
+	for (b = 0; b < EN75_PPE_NUM_FLOWS && !found; b++)
+		hlist_for_each_entry_safe(e, n, &ppe->foe_flow[b], list)
+			if (e->cookie == cookie) {
+				found = e;
+				break;
+			}
+	spin_unlock_bh(&ppe->lock);
+	if (found) {
+		en75_foe_entry_unregister(ppe, found);
+		kfree(found);
+	}
+}

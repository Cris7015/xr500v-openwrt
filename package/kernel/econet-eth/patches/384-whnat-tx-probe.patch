+/* === patch 383: WHNAT TX probe params (Phase 0 fail-fast) ===
+ * Set the knobs, then fire one frame at the WiFi via the QDMA:
+ *   whnat_tx_vid  = mux VID (= target vif index), stamped if whnat_tx_tag != 0
+ *   whnat_tx_tag  = 0 none | 1 -> 0x5678/vid | 2 -> 0x8100/vid
+ *   whnat_tx_imm  = refused: TX_IMMEDIATE_DONE wedged/rebooted the F0 test box
+ *   whnat_tx_msg0 = TX msg word0 (default 0x38 = channel 7/queue 0)
+ *   whnat_tx_msg1 = TX msg word1 (default 0x200000 = WiFi fport, bit 21)
+ *   whnat_tx_da_hi/lo = optional unicast DA; zero means broadcast
+ *   echo 1 > whnat_tx_fire   -> shoot one frame; watch a monitor sniffer for the
+ *                               "WHNATPROBE" marker (AP must be wifi-up). */
+static unsigned int whnat_tx_vid;
+static unsigned int whnat_tx_tag;
+static bool whnat_tx_imm;
+static unsigned int whnat_tx_msg0 = 0x38;
+static unsigned int whnat_tx_msg1 = 0x200000;
+static unsigned int whnat_tx_da_hi;
+static unsigned int whnat_tx_da_lo;
+module_param(whnat_tx_vid, uint, 0644);
+module_param(whnat_tx_tag, uint, 0644);
+module_param(whnat_tx_imm, bool, 0644);
+module_param(whnat_tx_msg0, uint, 0644);
+module_param(whnat_tx_msg1, uint, 0644);
+module_param(whnat_tx_da_hi, uint, 0644);
+module_param(whnat_tx_da_lo, uint, 0644);
+
+static int whnat_tx_fire_set(const char *val, const struct kernel_param *kp)
+{
+	if (!en75_whnat_probe_qdma)
+		return -ENODEV;
+	return en75_whnat_tx_probe(en75_whnat_probe_qdma, (u16)whnat_tx_vid,
+				   whnat_tx_tag, whnat_tx_imm,
+				   whnat_tx_msg0, whnat_tx_msg1,
+				   whnat_tx_da_hi, whnat_tx_da_lo);
+}
+static const struct kernel_param_ops whnat_tx_fire_ops = {
+	.set = whnat_tx_fire_set,
+	.get = param_get_int,
+};
+static int whnat_tx_fire;
+module_param_cb(whnat_tx_fire, &whnat_tx_fire_ops, &whnat_tx_fire, 0644);
+

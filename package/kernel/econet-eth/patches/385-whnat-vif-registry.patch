+/* ===================================================================== */
+/* WHNAT vif registry (F1): mt76 AP netdev <-> WHNAT vif index.           */
+/* Models the OEM ppe_dev_register_hook()/DstPort[] table. Writers = mt76 */
+/* add/remove_interface (process ctx, holds mt76.mutex). Readers = the    */
+/* NAPI force-to-CPU downstream demux (F3) + en75_flow_offload_replace    */
+/* (F2). The array holds a netdev reference while a vif is registered so   */
+/* the stored pointer stays valid; en75_whnat_vif_by_idx() hands the      */
+/* reader an extra hold to dev_put() after dev_queue_xmit(), which closes  */
+/* the unregister-vs-xmit race. idx = mt76 mvif->idx (== OEM VirIfIdx).    */
+/* ===================================================================== */
+static struct net_device *en75_wifi_vif[EN75_WHNAT_MAX_VIFS];
+static DEFINE_SPINLOCK(en75_wifi_vif_lock);
+
+void en75_whnat_register_vif(struct net_device *dev, int idx)
+{
+	struct net_device *old = NULL;
+	unsigned long flags;
+
+	if (!dev || idx < 0 || idx >= EN75_WHNAT_MAX_VIFS)
+		return;
+
+	spin_lock_irqsave(&en75_wifi_vif_lock, flags);
+	if (en75_wifi_vif[idx] != dev) {
+		old = en75_wifi_vif[idx];	/* may be NULL */
+		dev_hold(dev);
+		en75_wifi_vif[idx] = dev;
+	}
+	spin_unlock_irqrestore(&en75_wifi_vif_lock, flags);
+
+	if (old)
+		dev_put(old);
+	pr_info("econet-eth: WHNAT vif[%d] = %s (%pM)\n",
+		idx, dev->name, dev->dev_addr);
+}
+/* _GPL: mt76 resolves these via symbol_get(), which only binds GPL-only symbols */
+EXPORT_SYMBOL_GPL(en75_whnat_register_vif);
+
+void en75_whnat_unregister_vif(int idx)
+{
+	struct net_device *old;
+	unsigned long flags;
+
+	if (idx < 0 || idx >= EN75_WHNAT_MAX_VIFS)
+		return;
+
+	spin_lock_irqsave(&en75_wifi_vif_lock, flags);
+	old = en75_wifi_vif[idx];
+	en75_wifi_vif[idx] = NULL;
+	spin_unlock_irqrestore(&en75_wifi_vif_lock, flags);
+
+	if (old) {
+		pr_info("econet-eth: WHNAT vif[%d] released (%s)\n", idx, old->name);
+		dev_put(old);
+	}
+}
+EXPORT_SYMBOL_GPL(en75_whnat_unregister_vif);
+
+/* drop every registered hold -- called from econet-eth module exit so we don't
+ * leak the netdev refs if mt76 is still loaded when this driver unloads. */
+void en75_whnat_flush_vifs(void)
+{
+	struct net_device *old[EN75_WHNAT_MAX_VIFS];
+	unsigned long flags;
+	int i;
+
+	spin_lock_irqsave(&en75_wifi_vif_lock, flags);
+	for (i = 0; i < EN75_WHNAT_MAX_VIFS; i++) {
+		old[i] = en75_wifi_vif[i];
+		en75_wifi_vif[i] = NULL;
+	}
+	spin_unlock_irqrestore(&en75_wifi_vif_lock, flags);
+
+	for (i = 0; i < EN75_WHNAT_MAX_VIFS; i++)
+		if (old[i])
+			dev_put(old[i]);
+}
+
+/* idx -> netdev with an EXTRA hold; the caller dev_put()s after dev_queue_xmit */
+struct net_device *en75_whnat_vif_by_idx(int idx)
+{
+	struct net_device *dev;
+	unsigned long flags;
+
+	if (idx < 0 || idx >= EN75_WHNAT_MAX_VIFS)
+		return NULL;
+
+	spin_lock_irqsave(&en75_wifi_vif_lock, flags);
+	dev = en75_wifi_vif[idx];
+	if (dev)
+		dev_hold(dev);
+	spin_unlock_irqrestore(&en75_wifi_vif_lock, flags);
+
+	return dev;
+}
+
+int en75_whnat_idx_by_dev(const struct net_device *dev)
+{
+	unsigned long flags;
+	int i, idx = -1;
+
+	if (!dev)
+		return -1;
+
+	spin_lock_irqsave(&en75_wifi_vif_lock, flags);
+	for (i = 0; i < EN75_WHNAT_MAX_VIFS; i++)
+		if (en75_wifi_vif[i] == dev) {
+			idx = i;
+			break;
+		}
+	spin_unlock_irqrestore(&en75_wifi_vif_lock, flags);
+
+	return idx;
+}
+
+/* match by source MAC: the flowtable hands the downstream egress smac, which
+ * equals the AP vif's dev_addr (verified on HW, cont32t). Used by F2 to spot a
+ * WiFi egress flow without needing the netdev pointer. */
+int en75_whnat_idx_by_mac(const u8 *mac)
+{
+	unsigned long flags;
+	int i, idx = -1;
+
+	if (!mac)
+		return -1;
+
+	spin_lock_irqsave(&en75_wifi_vif_lock, flags);
+	for (i = 0; i < EN75_WHNAT_MAX_VIFS; i++) {
+		struct net_device *d = en75_wifi_vif[i];
+
+		if (d && ether_addr_equal(d->dev_addr, mac)) {
+			idx = i;
+			break;
+		}
+	}
+	spin_unlock_irqrestore(&en75_wifi_vif_lock, flags);
+
+	return idx;
+}
+

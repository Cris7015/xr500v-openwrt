--- a/gsw/mt7530.c	2026-05-09 08:04:31.151458892 +0000
+++ b/gsw/mt7530.c	2026-05-09 08:04:31.165577348 +0000
@@ -1211,6 +1211,18 @@
  * Though it has the same PHY ID as other MT7530 implementations, the EN751221
  * implementation of requires specific PHY tuning.
  */
+static void en751221_pgsel_mmd_write(struct phy_device *phy, int devad,
+				     u32 regnum, u16 val)
+{
+	struct mii_bus *bus = phy->mdio.bus;
+	int port = phy->mdio.addr;
+	mdiobus_write(bus, port, 0x1F, 0x0000);  /* page-select 0 */
+	mdiobus_write(bus, port, 0x0D, devad);
+	mdiobus_write(bus, port, 0x0E, regnum);
+	mdiobus_write(bus, port, 0x0D, devad | 0x4000);
+	mdiobus_write(bus, port, 0x0E, val);
+}
+

+/* iter80: periodic MIB dump for diagnostics — port 2 (lan2) and port 6 (CPU/TRGMII) */
+#include <linux/timer.h>
+static struct mt7530_priv *en751221_dbg_priv;
+static struct timer_list en751221_dbg_timer;
+
+static void en751221_dbg_dump(struct timer_list *t)
+{
+	struct mt7530_priv *priv = en751221_dbg_priv;
+	u32 p2_rxu, p2_rxb, p2_rxm, p2_rxd, p2_rxbyte;
+	u32 p6_txu, p6_txb, p6_txm, p6_rxu, p6_rxd;
+
+	if (!priv)
+		goto resched;
+	/* MIB base = GSW_BASE + 0x4000, port stride 0x100 */
+	u32 rxu[7];
+	int i;
+	for (i = 0; i < 7; i++)
+		rxu[i] = mt7530_read(priv, 0x4000 + i*0x100 + 0x68);
+	p2_rxd = p2_rxm = p2_rxb = p2_rxbyte = 0;
+	p2_rxu = rxu[0]; p6_rxd = rxu[1]; p6_rxu = rxu[2];
+	p6_txu = rxu[3]; p6_txm = rxu[4]; p6_txb = rxu[5];
+	/* p6 reuse field for actual port 6 below */
+	p6_rxu = rxu[6];
+
+	u32 pmcr1 = mt7530_read(priv, 0x3100); u32 pmcr2 = mt7530_read(priv, 0x3200); u32 pmcr3 = mt7530_read(priv, 0x3300); u32 pmcr4 = mt7530_read(priv, 0x3400); u32 pmcr6 = mt7530_read(priv, 0x3600);
+	u32 pcr1 = mt7530_read(priv, 0x2104); u32 pvc1 = mt7530_read(priv, 0x2110); u32 psc1 = mt7530_read(priv, 0x210C);
+	dev_info(priv->dev, "P1ext PCR=%08x PVC=%08x PSC=%08x\n", pcr1, pvc1, psc1);
+	dev_info(priv->dev, "PMCR[p1=%08x p2=%08x p3=%08x p4=%08x p6=%08x] RXU[p0=%u p1=%u p2=%u p3=%u p4=%u p5=%u p6=%u]\n", pmcr1, pmcr2, pmcr3, pmcr4, pmcr6,
+		rxu[0], rxu[1], rxu[2], rxu[3], rxu[4], rxu[5], rxu[6]);
+
+resched:
+	mod_timer(&en751221_dbg_timer, jiffies + 5*HZ);
+}
+
+static void en751221_start_dbg_timer(struct mt7530_priv *priv)
+{
+	en751221_dbg_priv = priv;
+	timer_setup(&en751221_dbg_timer, en751221_dbg_dump, 0);
+	mod_timer(&en751221_dbg_timer, jiffies + 5*HZ);
+	dev_warn(priv->dev, "ITER80: MIB dump timer started\n");
+}
+
+void en751221_run_cal_at_probe(struct mt7530_priv *priv)
+{
+	struct phy_device dummy = {};
+	dummy.mdio.bus = priv->user_bus;
+	dummy.mdio.addr = 12;  /* unused — helpers force port=12 internally */
+	dev_warn(priv->dev, "ITER75: running GE PHY cal at probe time\n");
+	en751221_phy_analog_cal(&dummy);
+	if (0) en751221_trgmii_init(priv); /* iter87 skip iter76+77 */
+	if (0) en751221_p6_rx_cal(priv); /* iter86 skip */
+	en751221_fix_gdma1_fwd(priv);
+	/* iter84: force PCR/PSC for all user ports (1..4) — fabric-level enable */
+	{
+		int p;
+		for (p = 1; p <= 4; p++) {
+			mt7530_write(priv, 0x2004 + p * 0x100, 0x00ff0003); /* iter91: stock matrix=0xff (all ports) instead of 0x41 */
+			mt7530_write(priv, 0x200c + p * 0x100, 0x000fff10); /* PSC: enable SA learning + drop unknown */
+			mt7530_write(priv, 0x2010 + p * 0x100, 0x81008100); /* iter91: stock TPID both halves (was 0x81000000) */
+		}
+		dev_warn(priv->dev, "ITER84: forced PCR/PSC/PVC on user ports 1-4\n");
+	}
+	en751221_start_dbg_timer(priv);
+}
+EXPORT_SYMBOL_GPL(en751221_run_cal_at_probe);
+
+static void en751221_phy_analog_cal(struct phy_device *phydev)
+{
+	struct mii_bus *bus = phydev->mdio.bus;
+	const int port = 12;
+	int reg0_temp, dev1e_145_temp, retry, pair;
+
+	phydev_info(phydev, "ITER58: starting GE PHY analog cal\n"); do { int v0=en751221_mmd_read(phydev,0x1e,0x017b); int v1=en751221_mmd_read(phydev,0x1f,0x0001); int v2=en751221_mmd_read(phydev,0x01,0x0001); int c22_bmsr=mdiobus_read(bus, port, 1); int c22_phyid=mdiobus_read(bus, port, 2); int mmd_via_c22 = phy_read_mmd(phydev, 0x1e, 0x017b); int mmd_phyid = phy_read_mmd(phydev, 0x1, 0x2); phydev_warn(phydev,"PROBE: c45[1e_017b=0x%x 1f_0001=0x%x 01_0001=0x%x] c22[bmsr=0x%x phyid=0x%x]\n",v0,v1,v2,c22_bmsr,c22_phyid); phydev_warn(phydev,"PROBE2: mmd_via_c22[1e_017b]=0x%x mmd_phyid[1_2]=0x%x\n", mmd_via_c22, mmd_phyid);} while(0);
+
+	mdiobus_write(bus, port, 0x1f, 0x0000); /* page 0 */
+	reg0_temp = mdiobus_read(bus, port, MII_BMCR);
+	mdiobus_write(bus, port, MII_BMCR, 0x0140); /* AN dis, FD, 1G */
+
+	en751221_mmd_write(phydev, 0x1f, 0x0100, 0xc000);
+	dev1e_145_temp = en751221_mmd_read(phydev, 0x1e, 0x0145);
+	en751221_mmd_write(phydev, 0x1e, 0x0145, 0x1010);
+	en751221_mmd_write(phydev, 0x1e, 0x0185, 0x0000);
+
+	/* Rext cal — retry up to 5 times if needed */
+	for (retry = 0; retry < 5; retry++) {
+		if (en751221_phy_cal_rext(phydev) == 0)
+			break;
+		phydev_warn(phydev, "Rext cal retry %d\n", retry + 1);
+	}
+
+	/* R50 cal pairs A..D */
+	en751221_mmd_write(phydev, 0x1e, 0x00db, 0x1100);
+	en751221_mmd_write(phydev, 0x1e, 0x00dc, 0x0000);
+	for (pair = 0; pair < 4; pair++)
+		en751221_phy_cal_r50_pair(phydev, pair);
+	en751221_mmd_write(phydev, 0x1e, 0x00db, 0x0000);
+
+	/* Tx offset cal */
+	en751221_mmd_write(phydev, 0x1e, 0x00db, 0x0100);
+	en751221_mmd_write(phydev, 0x1e, 0x00dc, 0x0001);
+	en751221_mmd_write(phydev, 0x1e, 0x0096, 0x8000);
+	en751221_mmd_write(phydev, 0x1e, 0x003e, 0xf808);
+	for (pair = 0; pair < 4; pair++)
+		en751221_phy_cal_tx_offset_pair(phydev, pair);
+	en751221_mmd_write(phydev, 0x1e, 0x017d, 0);
+	en751221_mmd_write(phydev, 0x1e, 0x017e, 0);
+	en751221_mmd_write(phydev, 0x1e, 0x017f, 0);
+	en751221_mmd_write(phydev, 0x1e, 0x0180, 0);
+	en751221_mmd_write(phydev, 0x1e, 0x0181, 0);
+	en751221_mmd_write(phydev, 0x1e, 0x0182, 0);
+	en751221_mmd_write(phydev, 0x1e, 0x0183, 0);
+	en751221_mmd_write(phydev, 0x1e, 0x0184, 0);
+	en751221_mmd_write(phydev, 0x1e, 0x00db, 0);
+	en751221_mmd_write(phydev, 0x1e, 0x00dc, 0);
+	en751221_mmd_write(phydev, 0x1e, 0x003e, 0);
+	en751221_mmd_write(phydev, 0x1e, 0x00dd, 0);
+
+	/* Tx amp cal */
+	en751221_mmd_write(phydev, 0x1e, 0x00db, 0x1100);
+	en751221_mmd_write(phydev, 0x1e, 0x00dc, 0x0001);
+	en751221_mmd_write(phydev, 0x1e, 0x00e1, 0x0010);
+	en751221_mmd_write(phydev, 0x1e, 0x003e, 0xf808);
+	for (pair = 0; pair < 4; pair++)
+		en751221_phy_cal_tx_amp_pair(phydev, pair);
+	en751221_mmd_write(phydev, 0x1e, 0x017d, 0);
+	en751221_mmd_write(phydev, 0x1e, 0x017e, 0);
+	en751221_mmd_write(phydev, 0x1e, 0x017f, 0);
+	en751221_mmd_write(phydev, 0x1e, 0x0180, 0);
+	en751221_mmd_write(phydev, 0x1e, 0x0181, 0);
+	en751221_mmd_write(phydev, 0x1e, 0x0182, 0);
+	en751221_mmd_write(phydev, 0x1e, 0x0183, 0);
+	en751221_mmd_write(phydev, 0x1e, 0x0184, 0);
+	en751221_mmd_write(phydev, 0x1e, 0x00db, 0);
+	en751221_mmd_write(phydev, 0x1e, 0x00dc, 0);
+	en751221_mmd_write(phydev, 0x1e, 0x003e, 0);
+	en751221_mmd_write(phydev, 0x1e, 0x00dd, 0);
+
+	/* Rx offset cal — HW driven, single trigger */
+	{
+		int v;
+		en751221_mmd_write(phydev, 0x1e, 0x0096, 0x8000);
+		en751221_mmd_write(phydev, 0x1e, 0x0037, 0x0033);
+		v = en751221_mmd_read(phydev, 0x1e, 0x0039);
+		en751221_mmd_write(phydev, 0x1e, 0x0039, (v < 0 ? 0 : v) & ~0x4800);
+		v = en751221_mmd_read(phydev, 0x1f, 0x0107);
+		en751221_mmd_write(phydev, 0x1f, 0x0107, (v < 0 ? 0 : v) & ~0x1000);
+		v = en751221_mmd_read(phydev, 0x1e, 0x0171);
+		en751221_mmd_write(phydev, 0x1e, 0x0171, ((v < 0 ? 0 : v) & ~0x0180) | 0x0180);
+		v = en751221_mmd_read(phydev, 0x1e, 0x0039);
+		en751221_mmd_write(phydev, 0x1e, 0x0039, (v < 0 ? 0 : v) | 0x2000);
+		en751221_mmd_write(phydev, 0x1e, 0x0039, (v < 0 ? 0 : v) & ~0x2000);
+		mdelay(10);
+		v = en751221_mmd_read(phydev, 0x1e, 0x0171);
+		en751221_mmd_write(phydev, 0x1e, 0x0171, (v < 0 ? 0 : v) & ~0x0180);
+	}
+
+	/* Restore original BMCR + a few regs */
+	if (reg0_temp >= 0)
+		mdiobus_write(bus, port, MII_BMCR, reg0_temp);
+	en751221_mmd_write(phydev, 0x1f, 0x0100, 0x0000);
+	if (dev1e_145_temp >= 0)
+		en751221_mmd_write(phydev, 0x1e, 0x0145, dev1e_145_temp);
+
+	phydev_info(phydev, "ITER58: GE PHY analog cal complete\n");
+}
+/* === END ITER58_PHY_ANALOG_CAL === */

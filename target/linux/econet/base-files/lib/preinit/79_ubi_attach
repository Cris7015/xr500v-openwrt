#!/bin/sh
# 79_ubi_attach — attach UBI to openwrt_ubi partition (iter35+) AND
# pre-mount the UBIFS volume at /tmp/overlay before mount_root runs.
#
# Pre-iter35: la UBI vivía en sub-partition "rootfs_data" auto-derivada
# de rootfs1 (tras squashfs-split). Solo había 13MB.
# iter35+: UBI propia en partition "openwrt_ubi" (64MB en área libre
# 0x3000000-0x7000000). El nombre del volumen UBI sigue siendo
# "rootfs_data" para compatibilidad con fstools/mount_root sin
# patches.
#
# Kernel-time UBI auto-attach via `ubi.mtd=` cmdline triggers OOB-marker
# misinterpretation under en75_bmt-without-BBT and breaks subsequent userspace
# ubiformat. Userspace ubiattach via this hook is consistent.

attach_and_premount_ubifs_overlay() {
	local mtdnum
	mtdnum=$(grep '"openwrt_ubi"' /proc/mtd | cut -d: -f1 | tr -d 'mtd:')
	[ -n "$mtdnum" ] || { echo "[ubi-hook] no mtdnum (openwrt_ubi missing)" >/dev/console; return 0; }
	echo "[ubi-hook] mtdnum=$mtdnum (openwrt_ubi)" >/dev/console

	# Attach UBI if not already attached
	if [ ! -e /dev/ubi0_0 ]; then
		ubiattach -m "$mtdnum" -d 0 >/dev/console 2>&1 || {
			echo "[ubi-hook] ubiattach failed" >/dev/console
			return 0
		}
		# UBI attach is async-event-driven for /dev/ubi0_0 creation.
		# Force mdev to populate /dev from /sys, then wait.
		mdev -s 2>/dev/null
		local i=0
		while [ ! -e /dev/ubi0_0 ] && [ $i -lt 50 ]; do
			usleep 100000 2>/dev/null || sleep 1
			i=$((i + 1))
			# nudge mdev periodically in case events are pending
			[ $((i % 10)) -eq 0 ] && mdev -s 2>/dev/null
		done
	fi
	if [ ! -e /dev/ubi0_0 ]; then
		# Last resort: explicit mknod from /sys/class/ubi/ubi0_0/dev
		local devmajmin
		[ -r /sys/class/ubi/ubi0_0/dev ] && devmajmin=$(cat /sys/class/ubi/ubi0_0/dev)
		if [ -n "$devmajmin" ]; then
			local maj=${devmajmin%:*} min=${devmajmin#*:}
			mknod /dev/ubi0_0 c "$maj" "$min" 2>/dev/null
			echo "[ubi-hook] mknod ubi0_0 c $maj $min" >/dev/console
		fi
	fi
	[ -e /dev/ubi0_0 ] || { echo "[ubi-hook] /dev/ubi0_0 missing after mdev+mknod" >/dev/console; return 0; }
	echo "[ubi-hook] /dev/ubi0_0 exists" >/dev/console

	# UBIFS-warmup trick: the kernel-time UBIFS mount via mount_root fails
	# with -EINVAL when journal replay is needed. Mount + umount once here
	# triggers the journal replay so the volume is "clean" when mount_root
	# attempts its own mount. Then we leave /tmp/overlay non-existent so
	# mount_root's mkdir succeeds.
	mkdir -p /tmp/.ubifs_warmup
	mount -t ubifs ubi0:rootfs_data /tmp/.ubifs_warmup >/dev/console 2>&1
	local rc=$?
	echo "[ubi-hook] warmup mount RC=$rc" >/dev/console
	if [ "$rc" = "0" ]; then
		# ensure recovery committed before unmount
		sync
		umount /tmp/.ubifs_warmup >/dev/console 2>&1
		echo "[ubi-hook] warmup umount RC=$?" >/dev/console
	fi
	rmdir /tmp/.ubifs_warmup 2>/dev/null
}

boot_hook_add preinit_main attach_and_premount_ubifs_overlay

+/* SPDX-License-Identifier: GPL-2.0-only */
+/* XR500v PPE phase 3 P4: FoE V1 (80B, mt7622/netsys-v1 class) structs +
+ * accessors, ported ~verbatim from mainline drivers/net/ethernet/mediatek/
+ * mtk_ppe.h. V1 ONLY (offload_version=2 only flips port_mg=0); every
+ * netsys-v2/v3 arm is intentionally dropped. Entry size is hardcoded 80B. */
+#ifndef __ECONET_PPE_H
+#define __ECONET_PPE_H
+
+#include <linux/bitfield.h>
+#include <linux/if_ether.h>
+
+/* OEM hw_nat.ko runs 16384 entries: the static gPpeFoeNum=0x2000 in .data is
+ * only the compile default — init_module overrides it from module param
+ * FOE_NUM=16 -> 0x4000, allocs 0x50*0x4000=0x140000 and sets TB_CFG
+ * ENTRY_NUM=4 (= the live 0xffbc read). See GHIDRA-FOENUM-2026-06-10.md.
+ * The old "16K broke descriptor==slot" objection assumed the RX-descriptor
+ * entry_num is the FoE slot, debunked in build #24 (slot is tuple-scanned).
+ * Requires DTS ppe-foe region >= 0x140000 (bumped to 0x180000). */
+#define EN75_PPE_ENTRIES_SHIFT		4
+#define EN75_PPE_ENTRIES		(1024 << EN75_PPE_ENTRIES_SHIFT)	/* 16384 */
+#define EN75_PPE_FOE_NUM		EN75_PPE_ENTRIES	/* RX accept bound (OEM gPpeFoeNum) */
+#define EN75_PPE_HASH_MASK		(EN75_PPE_ENTRIES - 1)
+#define EN75_FOE_ENTRY_SIZE		80
+
+/* --- ib1 (V1) --- */
+#define MTK_FOE_IB1_UNBIND_TIMESTAMP	GENMASK(7, 0)
+#define MTK_FOE_IB1_UNBIND_PACKETS	GENMASK(23, 8)
+#define MTK_FOE_IB1_UNBIND_PREBIND	BIT(24)
+
+#define MTK_FOE_IB1_BIND_TIMESTAMP	GENMASK(14, 0)
+#define MTK_FOE_IB1_BIND_KEEPALIVE	BIT(15)
+#define MTK_FOE_IB1_BIND_VLAN_LAYER	GENMASK(18, 16)
+#define MTK_FOE_IB1_BIND_PPPOE		BIT(19)
+#define MTK_FOE_IB1_BIND_VLAN_TAG	BIT(20)
+#define MTK_FOE_IB1_BIND_PKT_SAMPLE	BIT(21)
+#define MTK_FOE_IB1_BIND_CACHE		BIT(22)
+#define MTK_FOE_IB1_BIND_TUNNEL_DECAP	BIT(23)
+#define MTK_FOE_IB1_BIND_TTL		BIT(24)
+
+#define MTK_FOE_IB1_PACKET_TYPE		GENMASK(27, 25)
+#define MTK_FOE_IB1_STATE		GENMASK(29, 28)
+#define MTK_FOE_IB1_UDP			BIT(30)
+#define MTK_FOE_IB1_STATIC		BIT(31)
+
+enum {
+	MTK_PPE_PKT_TYPE_IPV4_HNAPT = 0,
+	MTK_PPE_PKT_TYPE_IPV4_ROUTE = 1,
+	MTK_PPE_PKT_TYPE_BRIDGE = 2,
+	MTK_PPE_PKT_TYPE_IPV4_DSLITE = 3,
+	MTK_PPE_PKT_TYPE_IPV6_ROUTE_3T = 4,
+	MTK_PPE_PKT_TYPE_IPV6_ROUTE_5T = 5,
+	MTK_PPE_PKT_TYPE_IPV6_6RD = 7,
+};
+
+/* --- ib2 (V1) --- */
+#define MTK_FOE_IB2_QID			GENMASK(3, 0)
+#define MTK_FOE_IB2_PSE_QOS		BIT(4)
+#define MTK_FOE_IB2_DEST_PORT		GENMASK(7, 5)
+#define MTK_FOE_IB2_MULTICAST		BIT(8)
+#define MTK_FOE_IB2_PORT_MG		GENMASK(17, 12)
+#define MTK_FOE_IB2_PORT_AG		GENMASK(23, 18)
+#define MTK_FOE_IB2_DSCP		GENMASK(31, 24)
+
+enum {
+	MTK_FOE_STATE_INVALID,
+	MTK_FOE_STATE_UNBIND,
+	MTK_FOE_STATE_BIND,
+	MTK_FOE_STATE_FIN
+};
+
+struct mtk_foe_mac_info {
+	u16 vlan1;
+	u16 etype;
+
+	u32 dest_mac_hi;
+
+	u16 vlan2;
+	u16 dest_mac_lo;
+
+	u32 src_mac_hi;
+
+	u16 pppoe_id;
+	u16 src_mac_lo;
+
+	/* unused on V1 (kept so the struct overlays the 80B entry the same way) */
+	u16 minfo;
+	u16 winfo;
+	u32 w3info;
+	u32 amsdu;
+};
+
+struct mtk_foe_bridge {
+	u8 dest_mac[ETH_ALEN];
+	u8 src_mac[ETH_ALEN];
+	u16 vlan;
+
+	struct {} key_end;
+
+	u32 ib2;
+
+	struct mtk_foe_mac_info l2;
+};
+
+struct mtk_ipv4_tuple {
+	u32 src_ip;
+	u32 dest_ip;
+	union {
+		struct {
+			u16 dest_port;
+			u16 src_port;
+		};
+		struct {
+			u8 protocol;
+			u8 _pad[3]; /* fill with 0xa5a5a5 */
+		};
+		u32 ports;
+	};
+};
+
+struct mtk_foe_ipv4 {
+	struct mtk_ipv4_tuple orig;
+
+	u32 ib2;
+
+	struct mtk_ipv4_tuple new;
+
+	u16 timestamp;
+	u16 _rsv0[3];
+
+	u32 udf_tsid;
+
+	struct mtk_foe_mac_info l2;
+};
+
+struct mtk_foe_entry {
+	u32 ib1;
+
+	union {
+		struct mtk_foe_bridge bridge;
+		struct mtk_foe_ipv4 ipv4;
+		u32 data[19];	/* V1 = 80 bytes = ib1 + 19 words */
+	};
+};
+
+enum {
+	MTK_PPE_CPU_REASON_TTL_EXCEEDED			= 0x02,
+	MTK_PPE_CPU_REASON_NO_FLOW			= 0x07,
+	MTK_PPE_CPU_REASON_UN_HIT			= 0x0d,
+	MTK_PPE_CPU_REASON_HIT_UNBIND			= 0x0e,
+	MTK_PPE_CPU_REASON_HIT_UNBIND_RATE_REACHED	= 0x0f,
+	/* build #61: HNAT_V2 prebind handshake notify (OEM frame_engine.h:419,
+	 * HIT_PRE_BIND). The engine emits this for an entry whose udib1.preb=1 on the
+	 * next matching packet; ONLY then does the OEM flip state=UNBIND->BIND. */
+	MTK_PPE_CPU_REASON_HIT_PRE_BIND			= 0x1a,
+	MTK_PPE_CPU_REASON_PPE_BYPASS			= 0x1e,
+};
+
+/* On the EN751221, RX of a steered-but-unbound flow comes up as NO_FLOW(0x07),
+ * NOT mainline's HIT_UNBIND_RATE_REACHED(0x0f) -- verified on hardware. The RX
+ * bind hook (P5) must treat 0x07 (and 0x0f) as the bind trigger. */
+
+/* econet_ppe.c (P4) — note: commit/test_commit take struct en75_ppe* (defined below) */
+struct en75_ppe;
+int en75_foe_entry_prepare(struct mtk_foe_entry *entry, int type, int l4proto,
+			   u8 pse_port, const u8 *src_mac, const u8 *dest_mac);
+int en75_foe_entry_set_ipv4_tuple(struct mtk_foe_entry *entry, bool egress,
+				  __be32 src_addr, __be16 src_port,
+				  __be32 dest_addr, __be16 dest_port);
+void en75_foe_entry_set_pse_port(struct mtk_foe_entry *entry, u8 port);
+u32 en75_ppe_hash_entry(struct mtk_foe_entry *e);
+void en75_foe_entry_commit(struct en75_ppe *ppe, struct mtk_foe_entry *entry, u16 hash);
+u32 en75_ppe_test_commit(struct en75_ppe *ppe);
+
+/* ===================================================================== */
+/* Phase 5 (binding): foe_flow registration + RX bind + egress builders   */
+/* ===================================================================== */
+#include <linux/spinlock.h>
+#include <linux/list.h>
+#include <linux/jiffies.h>
+#include <linux/types.h>
+
+#define EN75_PPE_HASH_OFFSET	2				/* mt7622/V1 hash_offset=2 */
+#define EN75_PPE_NUM_FLOWS	(EN75_PPE_ENTRIES / EN75_PPE_HASH_OFFSET) /* 8192 */
+#define EN75_PPE_GLO_CFG	0x200
+#define EN75_FE_TS_OFF		0x0010	/* FE free-running 15-bit timestamp (CONFIRM HW) */
+
+struct device;
+struct net_device;
+struct sk_buff;
+
+/* one offloaded flow: the prepared 80B FoE template + its HW slot once bound */
+struct en75_flow_entry {
+	struct hlist_node	list;		/* foe_flow[hash>>1] bucket linkage   */
+	struct mtk_foe_entry	data;		/* 80B FoE template (NAT-aware)       */
+	u16			hash;		/* 0xffff until check_skb binds it    */
+	unsigned long		cookie;		/* tc flow cookie (patch 359)         */
+	bool			static_entry;	/* test entry: never RX-cleared       */
+};
+
+struct en75_ppe {
+	struct device		*dev;
+	void __iomem		*base;		/* PPE reg block (eth->regs->ppe)     */
+	void __iomem		*fe_base;	/* FE reg block  (eth->regs->fe)      */
+	void			*foe_virt;	/* 16384*80B coherent FoE table       */
+	dma_addr_t		foe_phys;
+	struct net_device	*conduit;	/* GDM1 / eth0                        */
+	spinlock_t		lock;		/* protects foe_flow + HW FoE writes  */
+	struct hlist_head	*foe_flow;	/* [EN75_PPE_NUM_FLOWS]               */
+	u16			*foe_check_time;/* [EN75_PPE_ENTRIES] jiffies rate-lim*/
+};
+
+/* the global flag the RX hook in econet_qdma.c tests (default false = inert) */
+extern bool en75_ppe_offload_enabled;
+/* diagnostic: when true, the RX path logs crsn/ppe_entry/sport (rate-limited) */
+extern bool en75_ppe_rxdump;
+/* build #41: one-shot atomic dump (DRAM[slot] + 16 CAH lines data-words) from the RX
+ * hook, to catch our flow IN the cache at the crsn=15 instant (no userspace race) */
+extern bool en75_ppe_atomic;
+/* diagnostic: dump the raw engine-built FoE entry at the reported slot (to RE the
+ * engine's exact tuple layout/endianness vs our en75_foe_entry_set_ipv4_tuple) */
+extern bool en75_ppe_foedump;
+void en75_ppe_dump_slot(struct en75_ppe *ppe, u16 hash);
+/* dump the 16 CAH cache lines (RA_HWNAT FoeDumpCacheEntry) -- confirms whether
+ * the engine builds unbind entries into the cache instead of the DRAM table */
+void en75_ppe_dump_cache(struct en75_ppe *ppe);
+/* enable/disable+flush the PPE lookup cache (A/B for the cache hypothesis) */
+void en75_ppe_cache_set(struct en75_ppe *ppe, bool on);
+/* scan the whole DRAM FoE table, log non-zero entries (descriptor-slot vs
+ * table-slot mismatch diagnostic: find which slot the engine really used) */
+void en75_ppe_scan_table(struct en75_ppe *ppe);
+/* #25 fill+flip bind: find each registered flow's engine-built UNBIND entry by
+ * matching L4 ports, then flip it to BIND in place (sidesteps descriptor-slot +
+ * IP-encoding blockers). Returns #flows bound. Trigger via ppe_bindscan param. */
+int en75_ppe_bind_by_scan(struct en75_ppe *ppe);
+/* committest override: commit at this exact slot (the engine's reported hash) */
+extern u32 en75_force_hash;
+
+/* CDMA1_VLAN_CTRL: offset from fe_base (=0xBFB50400). OEM sets 0x81000001 =
+ * (TPID 0x8100 << 16) | urx(1) to POP the switch special tag on RX so the PPE
+ * can parse the inner frame. The mainline-equiv of MTK_CDMQ_STAG_EN. */
+#define EN75_CDMA1_VLAN_CTRL	0x400
+void en75_ppe_set_vlan_ctrl(struct en75_ppe *ppe, u32 val);
+
+/* generic FE register peek/poke (fe_base + off) for OEM-vs-OpenWrt diffing */
+void en75_ppe_fe_rw(struct en75_ppe *ppe, u32 off, bool write, u32 val);
+
+/* patch 356 */
+struct en75_ppe *en75_ppe_attach(struct device *dev, void __iomem *base,
+				 void __iomem *fe_base, void *foe_virt,
+				 dma_addr_t foe_phys, struct net_device *conduit);
+
+/* patch 357 — foe_flow core */
+int  en75_foe_entry_register(struct en75_ppe *ppe, struct en75_flow_entry *e);
+void en75_foe_entry_unregister(struct en75_ppe *ppe, struct en75_flow_entry *e);
+void en75_ppe_flush_all(struct en75_ppe *ppe);
+void __en75_ppe_check_skb(struct en75_ppe *ppe, struct sk_buff *skb, u16 hash, u8 crsn);
+
+enum en75_ppe_diag_event {
+	EN75_PPE_DIAG_GATE_PASS,
+	EN75_PPE_DIAG_PREBIND_PROMOTE,
+	EN75_PPE_DIAG_PREBIND_ARM,
+	EN75_PPE_DIAG_FLIP,
+	EN75_PPE_DIAG_RX_COMMIT,
+	EN75_PPE_DIAG_NOBIND,
+	EN75_PPE_DIAG_TX_ARM,
+};
+
+void en75_ppe_diag_sample(u16 hash, u8 crsn);
+void en75_ppe_diag_invalid(u16 hash, u8 crsn);
+void en75_ppe_diag_rate_limited(u16 hash, u8 crsn);
+void en75_ppe_diag_after_rate(u16 hash, u8 crsn);
+void en75_ppe_diag_gate_skip(u8 crsn);
+void en75_ppe_diag_event(enum en75_ppe_diag_event event);
+void en75_ppe_diag_dump(void);
+void en75_ppe_diag_reset(void);
+
+/* patch 357 — egress builders (V1) */
+void en75_foe_entry_set_dsa(struct mtk_foe_entry *entry, int port, bool passthrough);
+void en75_foe_entry_set_queue(struct mtk_foe_entry *entry, unsigned int queue);
+void en75_foe_entry_set_pppoe(struct mtk_foe_entry *entry, int sid);
+void en75_foe_entry_set_vlan(struct mtk_foe_entry *entry, int vid);
+
+/* patch 357 — manual first-light tests (driven by module params) */
+u32  en75_ppe_committest(struct en75_ppe *ppe, __be32 sip, __be32 dip,
+			 __be16 sport, __be16 dport, u8 proto,
+			 const u8 *smac, const u8 *dmac,
+			 int dsa_port, bool passthrough, u8 pse_port);
+u32  en75_ppe_bindtest_register(struct en75_ppe *ppe, __be32 sip, __be32 dip,
+				__be16 sport, __be16 dport, u8 proto,
+				const u8 *smac, const u8 *dmac,
+				int dsa_port, bool passthrough, u8 pse_port);
+
+/* ===================================================================== */
+/* TX-hook (build #42): OEM FoeBindToPpe model -- fill the COMPLETE entry  */
+/* from the EGRESS packet (real BRAS MAC, pppoe session-id, NAT'd tuple,   */
+/* DSA dp from the MTK tag) in the TX path, then commit BIND. The RX hook  */
+/* only ARMS the slot; the TX hook materializes the bind, exactly like the */
+/* OEM (PpeTxHandler->FoeBindToPpe). This tests "incomplete entry -> engine */
+/* rejects" AND is the production fix. EN751221 ib1 bit20=dvp (foe_fdb.h). */
+/* ===================================================================== */
+extern bool en75_ppe_tx_hook;	/* master enable for the TX bind hook       */
+extern bool en75_tx_bind_arm;	/* RX hook armed a pending TX commit        */
+extern u32  en75_tx_match_dip;	/* inner IPv4 dst (network order) of test flow */
+extern bool en75_ppe_flip;	/* build #43: flip-in-place the engine-built entry */
+extern u8   en75_flip_dp;	/* ib2.dp egress port for the flip (1=GSW,2=GMAC)  */
+extern u8   en75_ppe_tuple_swab;/* build #44: 1=store orig tuple swab32 (engine LOOKUP order) */
+extern u8   en75_ppe_cache_mode;/* build #46: 0=per-line 1=global clean-all 2=in-cache 3=both */
+extern bool en75_ppe_preserve_key;/* build #48: TX-bind keeps engine's UNBIND key, only adds rewrite */
+extern bool en75_ppe_mirror_lookup;/* build #56: also write BIND at the RX-descriptor lookup slot */
+extern bool en75_ppe_use_rxslot; /* build #57: commit at the per-flow RX-recorded lookup slot */
+extern bool en75_ppe_port_mg0;	 /* build #59: ib2 PORT_MG/AG=0 (vs OEM 0x3f) A/B */
+extern bool en75_ppe_cah_bind;	 /* build #60: in-cache BIND (flip the CAH line) */
+extern bool en75_ppe_prebind;	 /* build #61: OEM PREBIND handshake (preb=1, wait HIT_PRE_BIND, then state=BIND) */
+extern bool en75_ppe_bind_on_rate; /* build #68: bind ONLY on crsn=0x0f (RATE_REACHED), OEM timing */
+extern bool en75_ppe_oemregs;	 /* build #61: replicate OEM engine reg config (GLO_CFG/FLOW_CFG/aging) */
+/* build #61: called from the RX call-site when crsn==HIT_PRE_BIND(0x1a) -- the
+ * engine's handshake that it staged the prebind; flip the slot UNBIND->BIND. */
+void en75_ppe_prebind_promote(struct en75_ppe *ppe, u16 hash);
+void en75_ppe_rx_record(struct en75_ppe *ppe, struct sk_buff *skb, u16 hash);
+void en75_ppe_tx_bind(struct en75_ppe *ppe, struct sk_buff *skb);
+void en75_ppe_cache_clean_all(struct en75_ppe *ppe);
+void en75_ppe_cah_scan(struct en75_ppe *ppe);	/* build #47: dump all 1024 CAH lines */
+
+/* hot-path guard: cheap flag checks before the (rare) parse+commit. Call from
+ * en75_dev_xmit AFTER skb_linearize (so skb->data is contiguous to parse).
+ * build #52: the EN751221 engine AUTO-binds the FoE entry to state=2 (ib2=0, no
+ * egress) WITHOUT ever raising crsn=HIT_UNBIND, so the RX-hook arm (tx_bind_arm)
+ * starved and the tx_hook never fired. The OEM PpeTxHandler instead runs on EVERY
+ * post-routing egress packet. Match that: fire on tx_hook set, regardless of arm.
+ * We scan 8192 slots per call, so throttle to ~20/s (binding a flow once suffices;
+ * a bound flow HW-forwards and never reaches the conduit TX again). */
+static inline void en75_ppe_tx_maybe_bind(struct en75_ppe *ppe, struct sk_buff *skb)
+{
+	static unsigned long en75_tx_bind_last;	/* 0 = never fired (jiffies starts <0) */
+	unsigned long now = jiffies;
+
+	if (!ppe || !READ_ONCE(en75_ppe_tx_hook))
+		return;
+	/* fire on first-ever call (!last avoids the INITIAL_JIFFIES<0 wrap that made
+	 * time_after_eq(now,0) false until uptime>300s) or once per ~50ms thereafter. */
+	if (READ_ONCE(en75_tx_bind_arm) || !en75_tx_bind_last ||
+	    time_after(now, en75_tx_bind_last + HZ / 20)) {
+		en75_tx_bind_last = now ? now : 1;
+		en75_ppe_tx_bind(ppe, skb);
+	}
+}
+
+/* rate-limited RX bind trigger (mainline mtk_ppe_check_skb) */
+static inline void en75_ppe_check_skb(struct en75_ppe *ppe, struct sk_buff *skb, u16 hash, u8 crsn)
+{
+	u16 now, diff;
+
+	/* hash == EN75_PPE_HASH_MASK (0x3fff) is the engine's INVALID-slot marker,
+	 * not a real entry -- reject it (>= not >) so we never bind into slot 16383. */
+	if (!ppe)
+		return;
+	en75_ppe_diag_sample(hash, crsn);
+	if (hash >= EN75_PPE_HASH_MASK) {
+		en75_ppe_diag_invalid(hash, crsn);
+		return;
+	}
+	now = (u16)jiffies;
+	diff = now - ppe->foe_check_time[hash];
+	if (diff < HZ / 10) {
+		en75_ppe_diag_rate_limited(hash, crsn);
+		return;
+	}
+	ppe->foe_check_time[hash] = now;
+	en75_ppe_diag_after_rate(hash, crsn);
+	__en75_ppe_check_skb(ppe, skb, hash, crsn);
+}
+
+#endif /* __ECONET_PPE_H */
--- /dev/null
+++ b/econet_ppe.c
@@ -0,0 +1,1683 @@
+// SPDX-License-Identifier: GPL-2.0-only
+/* XR500v PPE phase 3 P4: FoE V1 entry builders + commit, ported from mainline
+ * mtk_ppe.c. V1 / offload_version=2 only (port_mg=0); IPv4 HNAPT/ROUTE only for
+ * now (the cases the XR500v router path needs). The FoE table itself is the one
+ * phase-1a already allocated (16384 * 80B coherent); this just builds + commits
+ * entries into it. Indexing uses the 80B stride, NOT an array of (oversized)
+ * structs. */
+#include "econet_ppe.h"
+#include <linux/atomic.h>
+#include <linux/dma-mapping.h>
+#include <linux/delay.h>
+#include <linux/etherdevice.h>
+#include <linux/io.h>
+#include <linux/ip.h>
+#include <linux/slab.h>
+#include <linux/swab.h>
+#include <linux/unaligned.h>
+#if IS_ENABLED(CONFIG_NF_CONNTRACK)
+#include <net/netfilter/nf_conntrack.h>
+#endif
+
+/* PPE register offsets within the block (same as econet_eth.c phase 1a) */
+#define EN75_PPE_TB_USED		0x224	/* GENMASK(13,0) = used-entry count */
+#define EN75_PPE_PPE_TB_CFG_OFF		0x21c	/* TB_CFG; bit16=1 -> 1024 CAH lines */
+#define EN75_PPE_CACHE_CTL		0x320	/* CAH_CTRL */
+#define EN75_PPE_CACHE_CTL_EN		BIT(0)	/* cache enable */
+#define EN75_PPE_CACHE_CTL_CLEAR	BIT(9)	/* invalidate-all pulse */
+/* CAH (FoE lookup cache) sw-access regs, ppe->base-relative (RA_HWNAT
+ * frame_engine.h: CAH_LINE_RW=0x328, CAH_RDATA=0x330; req bit = CAH_CTRL[8],
+ * cmd = CAH_CTRL[13:12], OFFSET_RW = CAH_LINE_RW[23:16], line = [14:0]). */
+#define EN75_PPE_CAH_LINE_RW		0x328
+#define EN75_PPE_CAH_RDATA		0x330
+#define EN75_PPE_CAH_REQ		BIT(8)
+#define EN75_PPE_CAH_CMD_SHIFT		12
+#define EN75_PPE_CAH_OFFRW_ENTRYNUM	0x1f
+#define EN75_PPE_CAH_LINES		16
+/* EN751221-SPECIFIC CAH protocol (RE'd from OEM PpeCleanCache751221/FoeDumpCacheData
+ * by Codex -- the MT7620 bit9-pulse flush does NOTHING here). CAH_CTRL[14:12]=cmd
+ * (4=clean-all, 2=read), [8]=go/trigger. A gate at PPE+0x334[0] must be lowered
+ * around the op and restored. */
+#define EN75_PPE_CAH_GATE		0x334	/* = CAH_EN_CFG: real enable/config (0x33=on) */
+#define EN75_PPE_CAH_TAG_SRH		0x324	/* search: [15:0]=idx in, [30:16]=matched line out */
+#define EN75_PPE_CAH_WDATA		0x32c
+#define EN75_PPE_CAH_CLEAN_ALL		0x4100	/* cmd=4 (clean-all) | BIT(8) trigger */
+#define EN75_PPE_CAH_READ_CMD		0x2100	/* cmd=2 (read) | BIT(8) trigger */
+
+/* EN751221 CAH cache flush: the real coherency op. Replaces the bogus bit9 pulse. */
+/* WORKFLOW RE FINDING (verified 3x from OEM PpeSetCacheEbl@0xc6fc): the EN751221
+ * CAH enable/disable register is PPE+0x334 (0x33=EN|cfg on enable), NOT CAH_CTRL
+ * 0x320 -- the 0x320 bit0/bit9 path is the MT7620 branch and a NO-OP on this die.
+ * Our old "flush" wrote 0x4100 to 0x320 but SET 0x334 bit0 at start+end, i.e. it
+ * RE-ENABLED the cache it claimed to flush, so the stale UNBIND survived ->
+ * crsn=15 forever, AND our cache-off A/B test (0x320) never actually disabled it.
+ * Fix: clear 0x334 bit0 = REAL cache OFF -> the engine reads every lookup from the
+ * coherent DRAM FoE table -> our BIND at slot=hash is honored next packet (OEM
+ * PpeSetEntryBind = 1 store, zero cache ops, because the cache is off/evicted). */
+/* issue a CAH sw-access command (cmd in [14:12]) + trigger, poll done. */
+static inline bool en75_cah_cmd(struct en75_ppe *ppe, u32 cmd)
+{
+	int n = 100000;
+
+	writel((cmd << 12) | BIT(8), ppe->base + EN75_PPE_CACHE_CTL);
+	while (n-- && (readl(ppe->base + EN75_PPE_CACHE_CTL) & BIT(8)))
+		udelay(1);
+	return !(readl(ppe->base + EN75_PPE_CACHE_CTL) & BIT(8));
+}
+
+/* SURGICAL evict (OEM ppeCacheClearOne@0x105a0): the engine FORWARD_BUILDs an
+ * UNBIND into the CAH and KEEPS serving that cached line even after we write a
+ * BIND to DRAM[idx] and even after clearing 0x334 bit0 (disable != evict). So:
+ * search the CAH for entry idx -> matched line -> read its meta word ->
+ * invalidate (state bits[17:16]=0) -> write back. Next lookup of idx cache-misses
+ * -> engine re-reads DRAM -> our BIND -> HIT. Needs the cache ENABLED (0x334&1). */
+static void en75_ppe_cah_clear_one(struct en75_ppe *ppe, u16 idx)
+{
+	u32 en = readl(ppe->base + EN75_PPE_CAH_GATE), t, line, sel, meta;
+
+	if (!(en & BIT(0)))
+		return;
+	writel(en & ~BIT(0), ppe->base + EN75_PPE_CAH_GATE);		/* gate down */
+	t = readl(ppe->base + EN75_PPE_CAH_TAG_SRH);
+	writel((t & ~0xffffu) | idx, ppe->base + EN75_PPE_CAH_TAG_SRH);
+	if (en75_cah_cmd(ppe, 0)) {					/* search idx */
+		line = (readl(ppe->base + EN75_PPE_CAH_TAG_SRH) >> 16) & 0x7fff;
+		sel = line | (0x1fu << 16);				/* meta word */
+		writel(sel, ppe->base + EN75_PPE_CAH_LINE_RW);
+		if (en75_cah_cmd(ppe, 2)) {				/* read meta */
+			meta = readl(ppe->base + EN75_PPE_CAH_RDATA) & 0xfffcffffu;
+			writel(meta, ppe->base + EN75_PPE_CAH_WDATA);	/* state->invalid */
+			writel(sel, ppe->base + EN75_PPE_CAH_LINE_RW);
+			en75_cah_cmd(ppe, 3);				/* write back */
+		}
+	}
+	writel(readl(ppe->base + EN75_PPE_CAH_GATE) | BIT(0),
+	       ppe->base + EN75_PPE_CAH_GATE);				/* gate up */
+}
+
+/* THE last move (fallback #2): the engine serves lookups from the CAH cache and
+ * never re-reads our DRAM BIND (DRAM-write+flush+disable+evict all fail). So bind
+ * IN the cache: search idx -> matched line -> flip the CACHED entry's ib1 word0 to
+ * state=BIND (+ ib2 word4 DEST_PORT=pse), KEEPING the engine's own cached tuple
+ * (words 1-3) which matches its lookup by construction. Engine HITs from cache. */
+static u32 en75_cah_read_word(struct en75_ppe *ppe, u32 line, u32 word)
+{
+	writel(line | (word << 16), ppe->base + EN75_PPE_CAH_LINE_RW);
+	return en75_cah_cmd(ppe, 2) ? readl(ppe->base + EN75_PPE_CAH_RDATA) : 0;
+}
+
+static void en75_cah_write_word(struct en75_ppe *ppe, u32 line, u32 word, u32 v)
+{
+	writel(v, ppe->base + EN75_PPE_CAH_WDATA);
+	writel(line | (word << 16), ppe->base + EN75_PPE_CAH_LINE_RW);
+	en75_cah_cmd(ppe, 3);
+}
+
+/* build #60: flip a CAH line's cached entry to BIND in place -- word0 ib1 state ->
+ * BIND, word4 ib2 DEST_PORT -> pse -- KEEPING the engine's own cached tuple. The
+ * engine HITs against the cached line so this bypasses DRAM + byte-order + the
+ * FORWARD_BUILD race entirely (Composer P1). */
+static void en75_cah_flip_line(struct en75_ppe *ppe, u32 line, u8 pse)
+{
+	u32 v = en75_cah_read_word(ppe, line, 0);
+
+	v &= ~MTK_FOE_IB1_STATE;
+	v |= FIELD_PREP(MTK_FOE_IB1_STATE, MTK_FOE_STATE_BIND) |
+	     MTK_FOE_IB1_BIND_CACHE | MTK_FOE_IB1_BIND_TTL;
+	en75_cah_write_word(ppe, line, 0, v);
+	v = en75_cah_read_word(ppe, line, 4);
+	v &= ~(MTK_FOE_IB2_DEST_PORT | MTK_FOE_IB2_PORT_AG);
+	v |= FIELD_PREP(MTK_FOE_IB2_DEST_PORT, pse) |
+	     FIELD_PREP(MTK_FOE_IB2_PORT_AG, 0x3f);
+	en75_cah_write_word(ppe, line, 4, v);
+}
+
+/* build #60: IN-CACHE BIND (Composer P1). Find the CAH line holding this flow and
+ * flip it to BIND in place. Try search-by-idx (the RX-descriptor FOE_ENTRY_NUM);
+ * if the CAH is tuple-hash-keyed (search misses), SCAN all lines and match word3
+ * (orig.ports) == want_ports (or its dport half). want_ports is in the engine's
+ * cached byte order (swab32 of network). TB_CFG[16]=1 -> up to 1024 lines. */
+static void en75_ppe_cah_bind_one(struct en75_ppe *ppe, u16 idx, u32 want_ports, u8 pse)
+{
+	u32 en = readl(ppe->base + EN75_PPE_CAH_GATE), t, tagrd;
+	u32 lines = (readl(ppe->base + EN75_PPE_PPE_TB_CFG_OFF) & BIT(16)) ? 1024 : 16;
+	int line = -1, i, scanned = 0;
+	u16 want_dphi = want_ports >> 16;		/* swab16(dport), NAT-invariant */
+
+	if (!(en & BIT(0)))
+		return;
+	writel(en & ~BIT(0), ppe->base + EN75_PPE_CAH_GATE);		/* gate down */
+
+	/* 1) search-by-idx (cheap) */
+	t = readl(ppe->base + EN75_PPE_CAH_TAG_SRH);
+	writel((t & ~0xffffu) | idx, ppe->base + EN75_PPE_CAH_TAG_SRH);
+	if (en75_cah_cmd(ppe, 0)) {
+		u32 l = (readl(ppe->base + EN75_PPE_CAH_TAG_SRH) >> 16) & 0x7fff;
+
+		tagrd = en75_cah_read_word(ppe, l, 0x1f);
+		if ((tagrd & 0x3fff) == idx)
+			line = (int)l;
+	}
+	/* 2) fallback: scan lines, match orig.ports (word3) */
+	if (line < 0) {
+		for (i = 0; i < (int)lines; i++) {
+			u32 meta = en75_cah_read_word(ppe, i, 0x1f);
+			u32 ib1, ports;
+
+			if (((meta >> 16) & 3) == 0)		/* invalid line */
+				continue;
+			scanned++;
+			ib1 = en75_cah_read_word(ppe, i, 0);
+			if (FIELD_GET(MTK_FOE_IB1_STATE, ib1) == MTK_FOE_STATE_BIND)
+				continue;			/* already bound */
+			ports = en75_cah_read_word(ppe, i, 3);
+			if (ports == want_ports || (ports >> 16) == want_dphi ||
+			    (ports & 0xffff) == want_dphi) {
+				line = i;
+				break;
+			}
+		}
+	}
+	if (line >= 0)
+		en75_cah_flip_line(ppe, (u32)line, pse);
+	writel(readl(ppe->base + EN75_PPE_CAH_GATE) | BIT(0),
+	       ppe->base + EN75_PPE_CAH_GATE);				/* gate up */
+	pr_info_ratelimited("XR500v CAH-bind(#60) idx=%u want_ports=%08x lines=%u scanned=%d line=%d dp=%u\n",
+			    idx, want_ports, lines, scanned, line, pse);
+}
+
+/* build #46: OEM PpeCleanCache751221 GLOBAL clean-all -- the real publish op (RE
+ * workflow, 4 agents). gate down (clear 0x334 bit0) -> CAH_CTRL=0x4100 (cmd4
+ * clean-all + go) -> gate up. Evicts EVERY cached line so the engine re-reads the
+ * coherent DRAM FoE table on its next lookup. Replaces cah_clear_one, whose
+ * per-entry tag-search never matched our flow (the long-standing CAH wall). */
+void en75_ppe_cache_clean_all(struct en75_ppe *ppe)
+{
+	u32 en = readl(ppe->base + EN75_PPE_CAH_GATE);
+
+	if (!(en & BIT(0))) {			/* cache OFF -> enable, else the flush is a no-op */
+		writel(0x33, ppe->base + EN75_PPE_CAH_GATE);
+		en = readl(ppe->base + EN75_PPE_CAH_GATE);
+	}
+	writel(en & ~BIT(0), ppe->base + EN75_PPE_CAH_GATE);	/* gate down */
+	en75_cah_cmd(ppe, 4);					/* CAH_CTRL = 0x4100 */
+	writel(en | BIT(0), ppe->base + EN75_PPE_CAH_GATE);	/* gate up */
+}
+
+/* build #46: live A/B of the cache publish strategy (no reflash): 0=per-line clear
+ * (old), 1=global clean-all (OEM), 2=in-cache bind, 3=clean-all+in-cache. */
+u8 en75_ppe_cache_mode = 1;
+
+static void en75_ppe_cache_publish(struct en75_ppe *ppe, u16 hash, u8 dp)
+{
+	struct mtk_foe_entry *hwe = (struct mtk_foe_entry *)
+		((u8 *)ppe->foe_virt + (u32)hash * EN75_FOE_ENTRY_SIZE);
+	u32 wp = hwe->ipv4.orig.ports;		/* committed entry's L4 ports */
+
+	switch (READ_ONCE(en75_ppe_cache_mode)) {
+	case 1:
+		en75_ppe_cache_clean_all(ppe);
+		break;
+	case 2:
+		en75_ppe_cah_bind_one(ppe, hash, wp, dp);
+		break;
+	case 3:
+		en75_ppe_cache_clean_all(ppe);
+		en75_ppe_cah_bind_one(ppe, hash, wp, dp);
+		break;
+	default:
+		en75_ppe_cah_clear_one(ppe, hash);
+		break;
+	}
+}
+
+/* build #47 (Codex gpt-5.5 xhigh): the CAH has 1024 lines when TB_CFG bit16 is set
+ * (our 0x14fbb has it) -- not 16. Dump ALL 1024 lines with their meta (entry#+state)
+ * + tuple words so we can find which line/entry# the engine ACTUALLY caches our flow
+ * at (match by L4 ports), vs the descriptor-reported slot. meta=word0x1f: [17:16]=
+ * state(1=valid,2=dirty,3=lock), [13:0]=entry#. words 0..4 = ib1/sip/dip/ports/ib2. */
+void en75_ppe_cah_scan(struct en75_ppe *ppe)
+{
+	u32 gate = readl(ppe->base + EN75_PPE_CAH_GATE);
+	int line, found = 0;
+
+	if (!(gate & BIT(0)))				/* need cache enabled for sw access */
+		writel(0x33, ppe->base + EN75_PPE_CAH_GATE);
+	writel(readl(ppe->base + EN75_PPE_CAH_GATE) & ~BIT(0),
+	       ppe->base + EN75_PPE_CAH_GATE);		/* gate down (sw access) */
+	pr_info("XR500v CAH scan (1024 lines, valid only):\n");
+	for (line = 0; line < 1024; line++) {
+		u32 w[5], meta;
+		int i;
+
+		writel((line & 0x7fff) | (0x1fu << 16),
+		       ppe->base + EN75_PPE_CAH_LINE_RW);
+		meta = en75_cah_cmd(ppe, 2) ? readl(ppe->base + EN75_PPE_CAH_RDATA) : 0;
+		if (!(meta & 0x30000))			/* state==invalid -> skip */
+			continue;
+		for (i = 0; i < 5; i++) {
+			writel((line & 0x7fff) | ((u32)i << 16),
+			       ppe->base + EN75_PPE_CAH_LINE_RW);
+			w[i] = en75_cah_cmd(ppe, 2) ?
+			       readl(ppe->base + EN75_PPE_CAH_RDATA) : 0;
+		}
+		if (++found <= 90)
+			pr_info("  cah[%d] entry=%u st=%u ib1=%08x sip=%08x dip=%08x ports=%08x ib2=%08x\n",
+				line, meta & 0x3fff, (meta >> 16) & 3,
+				w[0], w[1], w[2], w[3], w[4]);
+	}
+	writel(gate | BIT(0), ppe->base + EN75_PPE_CAH_GATE);	/* gate up (cache on) */
+	pr_info("XR500v CAH scan: %d valid lines\n", found);
+}
+
+/* --- entry builders (V1) --- */
+
+int en75_foe_entry_prepare(struct mtk_foe_entry *entry, int type, int l4proto,
+			   u8 pse_port, const u8 *src_mac, const u8 *dest_mac)
+{
+	struct mtk_foe_mac_info *l2;
+	u32 ports_pad, val;
+
+	memset(entry, 0, sizeof(*entry));
+
+	/* offload_version=2 -> port_mg=0 (mainline: >1 ? 0 : 0x3f) */
+	val = FIELD_PREP(MTK_FOE_IB1_STATE, MTK_FOE_STATE_BIND) |
+	      FIELD_PREP(MTK_FOE_IB1_PACKET_TYPE, type) |
+	      FIELD_PREP(MTK_FOE_IB1_UDP, l4proto == IPPROTO_UDP) |
+	      MTK_FOE_IB1_BIND_CACHE | MTK_FOE_IB1_BIND_TTL;
+	entry->ib1 = val;
+
+	/* OEM PpeSetForcePortInfo/PpeUpdateDp always write PORT_MG=PORT_AG=0x3f (the
+	 * 6-bit "no meter/account group" sentinel). We were writing MG=0 (= real
+	 * meter group 0, which can rate-limit/divert-to-CPU) and AG=0x1f. */
+	val = FIELD_PREP(MTK_FOE_IB2_DEST_PORT, pse_port) |
+	      FIELD_PREP(MTK_FOE_IB2_PORT_MG, 0x3f) |
+	      FIELD_PREP(MTK_FOE_IB2_PORT_AG, 0x3f);
+
+	if (is_multicast_ether_addr(dest_mac))
+		val |= MTK_FOE_IB2_MULTICAST;
+
+	ports_pad = 0xa5a5a500 | (l4proto & 0xff);
+	if (type == MTK_PPE_PKT_TYPE_IPV4_ROUTE)
+		entry->ipv4.orig.ports = ports_pad;
+
+	entry->ipv4.ib2 = val;
+	l2 = &entry->ipv4.l2;
+
+	l2->dest_mac_hi = get_unaligned_be32(dest_mac);
+	l2->dest_mac_lo = get_unaligned_be16(dest_mac + 4);
+	l2->src_mac_hi = get_unaligned_be32(src_mac);
+	l2->src_mac_lo = get_unaligned_be16(src_mac + 4);
+	l2->etype = ETH_P_IP;
+
+	return 0;
+}
+
+int en75_foe_entry_set_ipv4_tuple(struct mtk_foe_entry *entry, bool egress,
+				  __be32 src_addr, __be16 src_port,
+				  __be32 dest_addr, __be16 dest_port)
+{
+	int type = FIELD_GET(MTK_FOE_IB1_PACKET_TYPE, entry->ib1);
+	struct mtk_ipv4_tuple *t;
+
+	if (type == MTK_PPE_PKT_TYPE_IPV4_HNAPT && egress)
+		t = &entry->ipv4.new;
+	else
+		t = &entry->ipv4.orig;
+
+	t->src_ip = be32_to_cpu(src_addr);
+	t->dest_ip = be32_to_cpu(dest_addr);
+
+	if (type == MTK_PPE_PKT_TYPE_IPV4_ROUTE)
+		return 0;
+
+	t->src_port = be16_to_cpu(src_port);
+	t->dest_port = be16_to_cpu(dest_port);
+
+	return 0;
+}
+
+void en75_foe_entry_set_pse_port(struct mtk_foe_entry *entry, u8 port)
+{
+	u32 *ib2 = &entry->ipv4.ib2;
+
+	*ib2 &= ~MTK_FOE_IB2_DEST_PORT;
+	*ib2 |= FIELD_PREP(MTK_FOE_IB2_DEST_PORT, port) | MTK_FOE_IB2_PSE_QOS;
+}
+
+static void en75_foe_entry_set_oem_bind_meta(struct mtk_foe_entry *entry)
+{
+	u8 port = FIELD_GET(MTK_FOE_IB2_DEST_PORT, entry->ipv4.ib2);
+
+	entry->ib1 &= ~MTK_FOE_IB1_BIND_VLAN_LAYER;
+	entry->ib1 |= FIELD_PREP(MTK_FOE_IB1_BIND_VLAN_LAYER, 1);
+
+	/* OEM hwnat_set_rule_according_to_state writes byte 0x28 and halfword 0x2c
+	 * for IPv4 HNAPT bind entries before setting ib1.vlan_layer=1. */
+	entry->ipv4.udf_tsid &= ~0xff;
+	entry->ipv4.udf_tsid |= port + 6;
+	entry->ipv4.l2.vlan1 = 0x8000 | port;
+	entry->ipv4.ib2 |= MTK_FOE_IB2_PSE_QOS;
+}
+
+u32 en75_ppe_hash_entry(struct mtk_foe_entry *e)
+{
+	u32 hv1, hv2, hv3, hash;
+
+	/* IPv4 HNAPT/ROUTE only */
+	hv1 = e->ipv4.orig.ports;
+	hv2 = e->ipv4.orig.dest_ip;
+	hv3 = e->ipv4.orig.src_ip;
+
+	hash = (hv1 & hv2) | ((~hv1) & hv3);
+	hash = (hash >> 24) | ((hash & 0xffffff) << 8);
+	hash ^= hv1 ^ hv2 ^ hv3;
+	hash ^= hash >> 16;
+	hash <<= 1;			/* hash_offset=2 -> ffs(2)-1 = 1 */
+	hash &= EN75_PPE_ENTRIES - 1;
+
+	return hash;
+}
+
+/* --- commit into the HW FoE table (80B stride) --- */
+
+/* patch 358: EN751221 FE free-running 15-bit timestamp that the PPE aging
+ * scanner keys on (mainline mtk_eth_timestamp). Offset is a HW must-confirm. */
+static u16 en75_eth_timestamp(struct en75_ppe *ppe)
+{
+	return readl(ppe->fe_base + EN75_FE_TS_OFF) & MTK_FOE_IB1_BIND_TIMESTAMP;
+}
+
+void en75_foe_entry_commit(struct en75_ppe *ppe, struct mtk_foe_entry *entry, u16 hash)
+{
+	struct mtk_foe_entry *hwe =
+		(struct mtk_foe_entry *)((u8 *)ppe->foe_virt + hash * EN75_FOE_ENTRY_SIZE);
+	u16 timestamp = en75_eth_timestamp(ppe);
+
+	entry->ib1 &= ~MTK_FOE_IB1_BIND_TIMESTAMP;
+	entry->ib1 |= FIELD_PREP(MTK_FOE_IB1_BIND_TIMESTAMP, timestamp);
+	if (!READ_ONCE(en75_ppe_prebind))
+		en75_foe_entry_set_oem_bind_meta(entry);
+	/* build #46: OEM PpeSetEntryBind sets bfib1.cah=1 + ttl=DFL_FOE_TTL_REGEN on
+	 * every bind; without cah the engine won't cache/forward the bound entry. */
+	entry->ib1 |= MTK_FOE_IB1_BIND_CACHE | MTK_FOE_IB1_BIND_TTL;
+
+	/* build #61: OEM PREBIND model -- commit the COMPLETE entry but as UNBIND + preb=1
+	 * (bit24, == the BIND_TTL bit we just set), NOT state=BIND. On this chip the HW owns
+	 * the state field of dynamic entries and ignores a SW-forced BIND; preb is a request
+	 * and the HW state-machine does the UNBIND->BIND transition itself, confirming via
+	 * crsn=HIT_PRE_BIND(0x1a) where en75_ppe_prebind_promote() finalizes it. Matches the
+	 * OEM PpeSetEntryBind (CONFIG_RA_HW_NAT_PREBIND: sets udib1.preb=1, never state=BIND). */
+	if (READ_ONCE(en75_ppe_prebind)) {
+		entry->ib1 &= ~MTK_FOE_IB1_STATE;
+		entry->ib1 |= FIELD_PREP(MTK_FOE_IB1_STATE, MTK_FOE_STATE_UNBIND) |
+			      MTK_FOE_IB1_UNBIND_PREBIND;
+	}
+
+	/* data first, then ib1 LAST so HW never sees STATE=BIND with a half-
+	 * written tuple (the table is dma_alloc_coherent -> dma_wmb suffices). */
+	memcpy(&hwe->data, &entry->data, EN75_FOE_ENTRY_SIZE - sizeof(hwe->ib1));
+	wmb();
+	hwe->ib1 = entry->ib1;
+	dma_wmb();
+
+	/* EN751221 CAH flush (NOT the MT7620 bit9 pulse, which does nothing here)
+	 * so the engine re-reads DRAM for this slot and serves our BIND instead of
+	 * its cached UNBIND -- the fix for the crsn=HIT_UNBIND coherency wall. */
+	/* build #40 (OEM ppeCacheClearOne@0x105a0 disasm): the OEM does NOT bind-flip
+	 * the cache -- it INVALIDATES the stale cached UNBIND (clears the cache-line
+	 * state meta[17:16]) so the engine cache-misses and RE-READS DRAM, where our
+	 * committed BIND now sits. cah_clear_one is an exact port (no bogus tag verify).
+	 * Build #36 tried this with the SWAB tuple in DRAM (mismatch); now the DRAM BIND
+	 * holds the CORRECT network-order tuple (rank-1), so re-read -> match -> HIT. */
+	/* build #46: publish via ppe_cache_mode (default 1 = OEM global clean-all). */
+	en75_ppe_cache_publish(ppe, hash,
+			       FIELD_GET(MTK_FOE_IB2_DEST_PORT, entry->ipv4.ib2));
+}
+
+/* --- P4 self-test: hand-build one IPv4 HNAPT entry, commit it, return the
+ * slot + the live TB_USED so a debugfs poke can confirm the 80B layout takes. */
+u32 en75_ppe_test_commit(struct en75_ppe *ppe)
+{
+	static const u8 smac[ETH_ALEN] = { 0x02, 0, 0, 0, 0, 0x01 };
+	static const u8 dmac[ETH_ALEN] = { 0x02, 0, 0, 0, 0, 0x02 };
+	struct mtk_foe_entry e;
+	struct mtk_foe_entry *hwe;
+	u32 hash, tb_before, tb_after;
+
+	tb_before = readl(ppe->base + EN75_PPE_TB_USED) & 0x3fff;
+
+	en75_foe_entry_prepare(&e, MTK_PPE_PKT_TYPE_IPV4_HNAPT, IPPROTO_TCP,
+			       1 /* GDM1 */, smac, dmac);
+	/* orig 5-tuple 10.0.0.1:1000 -> 10.0.0.2:2000 ; egress same (no NAT) */
+	en75_foe_entry_set_ipv4_tuple(&e, false, htonl(0x0a000001), htons(1000),
+				      htonl(0x0a000002), htons(2000));
+	en75_foe_entry_set_ipv4_tuple(&e, true, htonl(0x0a000001), htons(1000),
+				      htonl(0x0a000002), htons(2000));
+	hash = en75_ppe_hash_entry(&e);
+	en75_foe_entry_commit(ppe, &e, hash);
+
+	tb_after = readl(ppe->base + EN75_PPE_TB_USED) & 0x3fff;
+	hwe = (struct mtk_foe_entry *)((u8 *)ppe->foe_virt + hash * EN75_FOE_ENTRY_SIZE);
+
+	/* read the slot straight back out of the coherent FoE table -> validates
+	 * the 80B struct overlay landed exactly as intended (no /dev/mem needed).
+	 * expected: ib1=2140xxxx (xxxx=live FE timestamp now) ib2=007c0020
+	 *           orig/new=0a000001/0a000002:07d003e8
+	 *           dmac=020000000002 smac=020000000001 etype=0800 */
+	pr_info("XR500v PPE P4: committed test entry at hash=%u, TB_USED %u->%u\n",
+		hash, tb_before, tb_after);
+	pr_info("XR500v PPE P4 rb: ib1=%08x ib2=%08x orig=%08x/%08x:%08x new=%08x/%08x:%08x\n",
+		hwe->ib1, hwe->ipv4.ib2,
+		hwe->ipv4.orig.src_ip, hwe->ipv4.orig.dest_ip, hwe->ipv4.orig.ports,
+		hwe->ipv4.new.src_ip, hwe->ipv4.new.dest_ip, hwe->ipv4.new.ports);
+	pr_info("XR500v PPE P4 rb: dmac=%08x%04x smac=%08x%04x etype=%04x\n",
+		hwe->ipv4.l2.dest_mac_hi, hwe->ipv4.l2.dest_mac_lo,
+		hwe->ipv4.l2.src_mac_hi, hwe->ipv4.l2.src_mac_lo,
+		hwe->ipv4.l2.etype);
+	return hash;
+}

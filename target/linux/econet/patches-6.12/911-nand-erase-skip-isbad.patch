Subject: mtd/nand: skip nanddev_isbad gate in nanddev_erase

--- a/drivers/mtd/nand/core.c	2026-05-07 06:27:53.778090767 +0000
+++ b/drivers/mtd/nand/core.c	2026-05-07 06:28:50.150623546 +0000
@@ -259,8 +259,13 @@
  */
 static int nanddev_erase(struct nand_device *nand, const struct nand_pos *pos)
 {
-	if (nanddev_isbad(nand, pos) || nanddev_isreserved(nand, pos)) {
-		pr_warn("attempt to erase a bad/reserved block @%llx\n",
+	/*
+	 * Skip nanddev_isbad gate: en75_bmt/UBI stacks accumulate non-0xFF
+	 * residue in OOB[0..1] from prior writes, mis-flagging healthy blocks.
+	 * Truly bad blocks fail at nand->ops->erase below; UBI handles -EIO.
+	 */
+	if (nanddev_isreserved(nand, pos)) {
+		pr_warn("attempt to erase a reserved block @%llx\n",
 			nanddev_pos_to_offs(nand, pos));
 		return -EIO;
 	}

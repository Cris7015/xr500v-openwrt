@@ -0,0 +1,460 @@
+// SPDX-License-Identifier: GPL-2.0-only
+/* XR500v PPE phase 3 P4: FoE V1 entry builders + commit, ported from mainline
+ * mtk_ppe.c. V1 / offload_version=2 only (port_mg=0); IPv4 HNAPT/ROUTE only for
+ * now (the cases the XR500v router path needs). The FoE table itself is the one
+ * phase-1a already allocated (16384 * 80B coherent); this just builds + commits
+ * entries into it. Indexing uses the 80B stride, NOT an array of (oversized)
+ * structs. */
+#include "econet_ppe.h"
+#include <linux/dma-mapping.h>
+#include <linux/etherdevice.h>
+#include <linux/io.h>
+#include <linux/ip.h>
+#include <linux/slab.h>
+#include <linux/unaligned.h>
+
+/* PPE register offsets within the block (same as econet_eth.c phase 1a) */
+#define EN75_PPE_TB_USED		0x224	/* GENMASK(13,0) = used-entry count */
+#define EN75_PPE_CACHE_CTL		0x320
+#define EN75_PPE_CACHE_CTL_CLEAR	BIT(9)
+
+/* --- entry builders (V1) --- */
+
+int en75_foe_entry_prepare(struct mtk_foe_entry *entry, int type, int l4proto,
+			   u8 pse_port, const u8 *src_mac, const u8 *dest_mac)
+{
+	struct mtk_foe_mac_info *l2;
+	u32 ports_pad, val;
+
+	memset(entry, 0, sizeof(*entry));
+
+	/* offload_version=2 -> port_mg=0 (mainline: >1 ? 0 : 0x3f) */
+	val = FIELD_PREP(MTK_FOE_IB1_STATE, MTK_FOE_STATE_BIND) |
+	      FIELD_PREP(MTK_FOE_IB1_PACKET_TYPE, type) |
+	      FIELD_PREP(MTK_FOE_IB1_UDP, l4proto == IPPROTO_UDP) |
+	      MTK_FOE_IB1_BIND_CACHE | MTK_FOE_IB1_BIND_TTL;
+	entry->ib1 = val;
+
+	val = FIELD_PREP(MTK_FOE_IB2_DEST_PORT, pse_port) |
+	      FIELD_PREP(MTK_FOE_IB2_PORT_MG, 0) |
+	      FIELD_PREP(MTK_FOE_IB2_PORT_AG, 0x1f);
+
+	if (is_multicast_ether_addr(dest_mac))
+		val |= MTK_FOE_IB2_MULTICAST;
+
+	ports_pad = 0xa5a5a500 | (l4proto & 0xff);
+	if (type == MTK_PPE_PKT_TYPE_IPV4_ROUTE)
+		entry->ipv4.orig.ports = ports_pad;
+
+	entry->ipv4.ib2 = val;
+	l2 = &entry->ipv4.l2;
+
+	l2->dest_mac_hi = get_unaligned_be32(dest_mac);
+	l2->dest_mac_lo = get_unaligned_be16(dest_mac + 4);
+	l2->src_mac_hi = get_unaligned_be32(src_mac);
+	l2->src_mac_lo = get_unaligned_be16(src_mac + 4);
+	l2->etype = ETH_P_IP;
+
+	return 0;
+}
+
+int en75_foe_entry_set_ipv4_tuple(struct mtk_foe_entry *entry, bool egress,
+				  __be32 src_addr, __be16 src_port,
+				  __be32 dest_addr, __be16 dest_port)
+{
+	int type = FIELD_GET(MTK_FOE_IB1_PACKET_TYPE, entry->ib1);
+	struct mtk_ipv4_tuple *t;
+
+	if (type == MTK_PPE_PKT_TYPE_IPV4_HNAPT && egress)
+		t = &entry->ipv4.new;
+	else
+		t = &entry->ipv4.orig;
+
+	t->src_ip = be32_to_cpu(src_addr);
+	t->dest_ip = be32_to_cpu(dest_addr);
+
+	if (type == MTK_PPE_PKT_TYPE_IPV4_ROUTE)
+		return 0;
+
+	t->src_port = be16_to_cpu(src_port);
+	t->dest_port = be16_to_cpu(dest_port);
+
+	return 0;
+}
+
+void en75_foe_entry_set_pse_port(struct mtk_foe_entry *entry, u8 port)
+{
+	u32 *ib2 = &entry->ipv4.ib2;
+
+	*ib2 &= ~MTK_FOE_IB2_DEST_PORT;
+	*ib2 |= FIELD_PREP(MTK_FOE_IB2_DEST_PORT, port);
+}
+
+u32 en75_ppe_hash_entry(struct mtk_foe_entry *e)
+{
+	u32 hv1, hv2, hv3, hash;
+
+	/* IPv4 HNAPT/ROUTE only */
+	hv1 = e->ipv4.orig.ports;
+	hv2 = e->ipv4.orig.dest_ip;
+	hv3 = e->ipv4.orig.src_ip;
+
+	hash = (hv1 & hv2) | ((~hv1) & hv3);
+	hash = (hash >> 24) | ((hash & 0xffffff) << 8);
+	hash ^= hv1 ^ hv2 ^ hv3;
+	hash ^= hash >> 16;
+	hash <<= 1;			/* hash_offset=2 -> ffs(2)-1 = 1 */
+	hash &= EN75_PPE_ENTRIES - 1;
+
+	return hash;
+}
+
+/* --- commit into the HW FoE table (80B stride) --- */
+
+/* patch 358: EN751221 FE free-running 15-bit timestamp that the PPE aging
+ * scanner keys on (mainline mtk_eth_timestamp). Offset is a HW must-confirm. */
+static u16 en75_eth_timestamp(struct en75_ppe *ppe)
+{
+	return readl(ppe->fe_base + EN75_FE_TS_OFF) & MTK_FOE_IB1_BIND_TIMESTAMP;
+}
+
+void en75_foe_entry_commit(struct en75_ppe *ppe, struct mtk_foe_entry *entry, u16 hash)
+{
+	struct mtk_foe_entry *hwe =
+		(struct mtk_foe_entry *)((u8 *)ppe->foe_virt + hash * EN75_FOE_ENTRY_SIZE);
+	u16 timestamp = en75_eth_timestamp(ppe);
+	u32 cc;
+
+	entry->ib1 &= ~MTK_FOE_IB1_BIND_TIMESTAMP;
+	entry->ib1 |= FIELD_PREP(MTK_FOE_IB1_BIND_TIMESTAMP, timestamp);
+
+	/* data first, then ib1 LAST so HW never sees STATE=BIND with a half-
+	 * written tuple (the table is dma_alloc_coherent -> dma_wmb suffices). */
+	memcpy(&hwe->data, &entry->data, EN75_FOE_ENTRY_SIZE - sizeof(hwe->ib1));
+	wmb();
+	hwe->ib1 = entry->ib1;
+	dma_wmb();
+
+	/* flush the PPE lookup cache so the engine re-reads the table for this
+	 * slot (mainline mtk_ppe_cache_clear: set then clear CACHE_CTL.CLEAR). */
+	cc = readl(ppe->base + EN75_PPE_CACHE_CTL);
+	writel(cc | EN75_PPE_CACHE_CTL_CLEAR, ppe->base + EN75_PPE_CACHE_CTL);
+	writel(cc & ~EN75_PPE_CACHE_CTL_CLEAR, ppe->base + EN75_PPE_CACHE_CTL);
+}
+
+/* --- P4 self-test: hand-build one IPv4 HNAPT entry, commit it, return the
+ * slot + the live TB_USED so a debugfs poke can confirm the 80B layout takes. */
+u32 en75_ppe_test_commit(struct en75_ppe *ppe)
+{
+	static const u8 smac[ETH_ALEN] = { 0x02, 0, 0, 0, 0, 0x01 };
+	static const u8 dmac[ETH_ALEN] = { 0x02, 0, 0, 0, 0, 0x02 };
+	struct mtk_foe_entry e;
+	struct mtk_foe_entry *hwe;
+	u32 hash, tb_before, tb_after;
+
+	tb_before = readl(ppe->base + EN75_PPE_TB_USED) & 0x3fff;
+
+	en75_foe_entry_prepare(&e, MTK_PPE_PKT_TYPE_IPV4_HNAPT, IPPROTO_TCP,
+			       1 /* GDM1 */, smac, dmac);
+	/* orig 5-tuple 10.0.0.1:1000 -> 10.0.0.2:2000 ; egress same (no NAT) */
+	en75_foe_entry_set_ipv4_tuple(&e, false, htonl(0x0a000001), htons(1000),
+				      htonl(0x0a000002), htons(2000));
+	en75_foe_entry_set_ipv4_tuple(&e, true, htonl(0x0a000001), htons(1000),
+				      htonl(0x0a000002), htons(2000));
+	hash = en75_ppe_hash_entry(&e);
+	en75_foe_entry_commit(ppe, &e, hash);
+
+	tb_after = readl(ppe->base + EN75_PPE_TB_USED) & 0x3fff;
+	hwe = (struct mtk_foe_entry *)((u8 *)ppe->foe_virt + hash * EN75_FOE_ENTRY_SIZE);
+
+	/* read the slot straight back out of the coherent FoE table -> validates
+	 * the 80B struct overlay landed exactly as intended (no /dev/mem needed).
+	 * expected: ib1=2140xxxx (xxxx=live FE timestamp now) ib2=007c0020
+	 *           orig/new=0a000001/0a000002:07d003e8
+	 *           dmac=020000000002 smac=020000000001 etype=0800 */
+	pr_info("XR500v PPE P4: committed test entry at hash=%u, TB_USED %u->%u\n",
+		hash, tb_before, tb_after);
+	pr_info("XR500v PPE P4 rb: ib1=%08x ib2=%08x orig=%08x/%08x:%08x new=%08x/%08x:%08x\n",
+		hwe->ib1, hwe->ipv4.ib2,
+		hwe->ipv4.orig.src_ip, hwe->ipv4.orig.dest_ip, hwe->ipv4.orig.ports,
+		hwe->ipv4.new.src_ip, hwe->ipv4.new.dest_ip, hwe->ipv4.new.ports);
+	pr_info("XR500v PPE P4 rb: dmac=%08x%04x smac=%08x%04x etype=%04x\n",
+		hwe->ipv4.l2.dest_mac_hi, hwe->ipv4.l2.dest_mac_lo,
+		hwe->ipv4.l2.src_mac_hi, hwe->ipv4.l2.src_mac_lo,
+		hwe->ipv4.l2.etype);
+	return hash;
+}
+
+/* ===================================================================== */
+/* Phase 5 (binding): attach + egress builders + foe_flow core + RX bind  */
+/* ===================================================================== */
+
+bool en75_ppe_offload_enabled;	/* RX hook is inert until a test/offload arms it */
+bool en75_ppe_rxdump;		/* diagnostic: dump crsn/ppe_entry on RX */
+
+/* write CDMA1_VLAN_CTRL (fe_base+0x400). 0x81000001 = OEM value that pops the
+ * MT7530 special tag on RX so the PPE can parse the inner IPv4 frame. */
+void en75_ppe_set_vlan_ctrl(struct en75_ppe *ppe, u32 val)
+{
+	u32 old = readl(ppe->fe_base + EN75_CDMA1_VLAN_CTRL);
+
+	writel(val, ppe->fe_base + EN75_CDMA1_VLAN_CTRL);
+	pr_info("XR500v PPE vlan_ctrl: CDMA1_VLAN_CTRL %08x -> %08x (rb=%08x)\n",
+		old, val, readl(ppe->fe_base + EN75_CDMA1_VLAN_CTRL));
+}
+
+void en75_ppe_fe_rw(struct en75_ppe *ppe, u32 off, bool write, u32 val)
+{
+	u32 old = readl(ppe->fe_base + (off & 0xfffc));
+
+	if (write) {
+		writel(val, ppe->fe_base + (off & 0xfffc));
+		pr_info("XR500v PPE fe[%04x]: %08x -> %08x (rb=%08x)\n",
+			off & 0xfffc, old, val, readl(ppe->fe_base + (off & 0xfffc)));
+	} else {
+		pr_info("XR500v PPE fe[%04x] = %08x\n", off & 0xfffc, old);
+	}
+}
+
+/* patch 356: allocate the per-eth PPE state (struct + foe_flow + rate-limit). */
+struct en75_ppe *en75_ppe_attach(struct device *dev, void __iomem *base,
+				 void __iomem *fe_base, void *foe_virt,
+				 dma_addr_t foe_phys, struct net_device *conduit)
+{
+	struct en75_ppe *ppe = devm_kzalloc(dev, sizeof(*ppe), GFP_KERNEL);
+
+	if (!ppe)
+		return NULL;
+	ppe->dev = dev;
+	ppe->base = base;
+	ppe->fe_base = fe_base;
+	ppe->foe_virt = foe_virt;
+	ppe->foe_phys = foe_phys;
+	ppe->conduit = conduit;
+	spin_lock_init(&ppe->lock);
+	ppe->foe_flow = devm_kcalloc(dev, EN75_PPE_NUM_FLOWS,
+				     sizeof(*ppe->foe_flow), GFP_KERNEL);
+	ppe->foe_check_time = devm_kcalloc(dev, EN75_PPE_ENTRIES,
+					   sizeof(*ppe->foe_check_time), GFP_KERNEL);
+	if (!ppe->foe_flow || !ppe->foe_check_time)
+		return NULL;
+	return ppe;
+}
+
+/* --- V1 egress builders (mainline mtk_foe_entry_set_*; IPv4 l2 only) --- */
+
+void en75_foe_entry_set_dsa(struct mtk_foe_entry *entry, int port, bool passthrough)
+{
+	struct mtk_foe_mac_info *l2 = &entry->ipv4.l2;
+
+	l2->etype = BIT(port) & 0x3f;		/* DP bitmap GENMASK(5,0) */
+	if (passthrough)
+		l2->etype |= BIT(7);		/* XR500v: cascaded 2nd MT7530 passthrough */
+	if (!(entry->ib1 & MTK_FOE_IB1_BIND_VLAN_LAYER))
+		entry->ib1 |= FIELD_PREP(MTK_FOE_IB1_BIND_VLAN_LAYER, 1);
+	else
+		l2->etype |= BIT(8);
+	entry->ib1 &= ~MTK_FOE_IB1_BIND_VLAN_TAG;
+}
+
+void en75_foe_entry_set_queue(struct mtk_foe_entry *entry, unsigned int queue)
+{
+	u32 *ib2 = &entry->ipv4.ib2;
+
+	*ib2 &= ~MTK_FOE_IB2_QID;
+	*ib2 |= FIELD_PREP(MTK_FOE_IB2_QID, queue);
+	*ib2 |= MTK_FOE_IB2_PSE_QOS;
+}
+
+void en75_foe_entry_set_pppoe(struct mtk_foe_entry *entry, int sid)
+{
+	struct mtk_foe_mac_info *l2 = &entry->ipv4.l2;
+
+	if (!(entry->ib1 & MTK_FOE_IB1_BIND_VLAN_LAYER) ||
+	    (entry->ib1 & MTK_FOE_IB1_BIND_VLAN_TAG))
+		l2->etype = ETH_P_PPP_SES;
+	entry->ib1 |= MTK_FOE_IB1_BIND_PPPOE;
+	l2->pppoe_id = sid;
+}
+
+void en75_foe_entry_set_vlan(struct mtk_foe_entry *entry, int vid)
+{
+	struct mtk_foe_mac_info *l2 = &entry->ipv4.l2;
+
+	switch (FIELD_GET(MTK_FOE_IB1_BIND_VLAN_LAYER, entry->ib1)) {
+	case 0:
+		entry->ib1 |= MTK_FOE_IB1_BIND_VLAN_TAG |
+			      FIELD_PREP(MTK_FOE_IB1_BIND_VLAN_LAYER, 1);
+		l2->vlan1 = vid;
+		return;
+	case 1:
+		if (!(entry->ib1 & MTK_FOE_IB1_BIND_VLAN_TAG)) {
+			l2->vlan1 = vid;
+			l2->etype |= BIT(8);
+		} else {
+			l2->vlan2 = vid;
+			entry->ib1 += FIELD_PREP(MTK_FOE_IB1_BIND_VLAN_LAYER, 1);
+		}
+		return;
+	default:
+		return;
+	}
+}
+
+/* --- foe_flow registration + RX bind (mainline mtk_ppe.c core, V1/IPv4) --- */
+
+/* match the orig 5-tuple (12B after ib1) + the UDP bit */
+static bool en75_flow_entry_match(struct en75_flow_entry *e, struct mtk_foe_entry *hwe)
+{
+	if ((hwe->ib1 ^ e->data.ib1) & MTK_FOE_IB1_UDP)
+		return false;
+	return !memcmp(&e->data.data, &hwe->data,
+		       offsetof(struct mtk_foe_entry, ipv4.ib2) - sizeof(hwe->ib1));
+}
+
+/* caller holds ppe->lock; invalidate the HW slot this flow was bound to */
+static void en75_foe_entry_clear_locked(struct en75_ppe *ppe, struct en75_flow_entry *e)
+{
+	if (e->hash != 0xffff) {
+		struct mtk_foe_entry *hwe =
+			(struct mtk_foe_entry *)((u8 *)ppe->foe_virt +
+						 (u32)e->hash * EN75_FOE_ENTRY_SIZE);
+		u32 cc;
+
+		hwe->ib1 &= ~MTK_FOE_IB1_STATE;
+		hwe->ib1 |= FIELD_PREP(MTK_FOE_IB1_STATE, MTK_FOE_STATE_INVALID);
+		dma_wmb();
+		cc = readl(ppe->base + EN75_PPE_CACHE_CTL);
+		writel(cc | EN75_PPE_CACHE_CTL_CLEAR, ppe->base + EN75_PPE_CACHE_CTL);
+		writel(cc & ~EN75_PPE_CACHE_CTL_CLEAR, ppe->base + EN75_PPE_CACHE_CTL);
+	}
+	e->hash = 0xffff;
+}
+
+/* register a prepared flow into the SW bucket; NO HW write (mainline
+ * mtk_foe_entry_commit). The RX hook binds it on the first matching packet. */
+int en75_foe_entry_register(struct en75_ppe *ppe, struct en75_flow_entry *e)
+{
+	u32 hash = en75_ppe_hash_entry(&e->data);
+
+	e->hash = 0xffff;
+	spin_lock_bh(&ppe->lock);
+	hlist_add_head(&e->list, &ppe->foe_flow[hash / EN75_PPE_HASH_OFFSET]);
+	spin_unlock_bh(&ppe->lock);
+	return 0;
+}
+
+void en75_foe_entry_unregister(struct en75_ppe *ppe, struct en75_flow_entry *e)
+{
+	spin_lock_bh(&ppe->lock);
+	en75_foe_entry_clear_locked(ppe, e);
+	hlist_del_init(&e->list);
+	spin_unlock_bh(&ppe->lock);
+}
+
+/* RX path: a steered-but-unbound flow missed; if the engine FORWARD_BUILD'd a
+ * parsed unbind entry at 'hash', match it to a registered flow and bind it. */
+void __en75_ppe_check_skb(struct en75_ppe *ppe, struct sk_buff *skb, u16 hash)
+{
+	struct mtk_foe_entry *hwe =
+		(struct mtk_foe_entry *)((u8 *)ppe->foe_virt + (u32)hash * EN75_FOE_ENTRY_SIZE);
+	struct hlist_head *head = &ppe->foe_flow[hash / EN75_PPE_HASH_OFFSET];
+	struct en75_flow_entry *e;
+	struct hlist_node *n;
+	bool found = false;
+
+	spin_lock_bh(&ppe->lock);
+	if (FIELD_GET(MTK_FOE_IB1_STATE, hwe->ib1) == MTK_FOE_STATE_BIND)
+		goto out;	/* engine already bound this slot */
+	hlist_for_each_entry_safe(e, n, head, list) {
+		if (found || !en75_flow_entry_match(e, hwe)) {
+			if (e->hash != 0xffff && !e->static_entry)
+				en75_foe_entry_clear_locked(ppe, e);
+			continue;
+		}
+		e->hash = hash;				/* raw engine slot */
+		en75_foe_entry_commit(ppe, &e->data, hash);
+		found = true;
+	}
+out:
+	spin_unlock_bh(&ppe->lock);
+}
+
+void en75_ppe_flush_all(struct en75_ppe *ppe)
+{
+	struct en75_flow_entry *e;
+	struct hlist_node *n;
+	int i;
+
+	spin_lock_bh(&ppe->lock);
+	for (i = 0; i < EN75_PPE_NUM_FLOWS; i++) {
+		hlist_for_each_entry_safe(e, n, &ppe->foe_flow[i], list) {
+			en75_foe_entry_clear_locked(ppe, e);
+			hlist_del_init(&e->list);
+			if (!e->static_entry)
+				kfree(e);
+		}
+	}
+	spin_unlock_bh(&ppe->lock);
+}
+
+/* --- manual first-light test helpers (driven from module params) --- */
+
+static void en75_build_test_flow(struct mtk_foe_entry *e, __be32 sip, __be32 dip,
+				 __be16 sport, __be16 dport, u8 proto,
+				 const u8 *smac, const u8 *dmac,
+				 int dsa_port, bool passthrough, u8 pse_port)
+{
+	en75_foe_entry_prepare(e, MTK_PPE_PKT_TYPE_IPV4_HNAPT, proto,
+			       pse_port, smac, dmac);
+	en75_foe_entry_set_ipv4_tuple(e, false, sip, sport, dip, dport);
+	en75_foe_entry_set_ipv4_tuple(e, true, sip, sport, dip, dport);	/* no NAT in test */
+	if (dsa_port >= 0)
+		en75_foe_entry_set_dsa(e, dsa_port, passthrough);
+	en75_foe_entry_set_queue(e, dsa_port >= 0 ? 3 + dsa_port : 0);
+	en75_foe_entry_set_pse_port(e, pse_port);	/* 1=GDM1, 7=DISCARD (divert test) */
+	e->ib1 |= MTK_FOE_IB1_STATIC;		/* test flow is never aged */
+}
+
+/* direct commit at the SW hash (STATE=BIND): tests whether the engine HONORS a
+ * SW-written entry on a matching packet (HIT) -> validates egress/tag, no RX dep. */
+u32 en75_ppe_committest(struct en75_ppe *ppe, __be32 sip, __be32 dip,
+			__be16 sport, __be16 dport, u8 proto,
+			const u8 *smac, const u8 *dmac,
+			int dsa_port, bool passthrough, u8 pse_port)
+{
+	struct mtk_foe_entry e;
+	u32 hash;
+
+	en75_build_test_flow(&e, sip, dip, sport, dport, proto, smac, dmac,
+			     dsa_port, passthrough, pse_port);
+	hash = en75_ppe_hash_entry(&e);
+	spin_lock_bh(&ppe->lock);
+	en75_foe_entry_commit(ppe, &e, hash);
+	spin_unlock_bh(&ppe->lock);
+	pr_info("XR500v PPE committest: hash=%u pse=%u dsa=%d pt=%d ib1=%08x ib2=%08x etype=%04x q=%lu\n",
+		hash, pse_port, dsa_port, passthrough, e.ib1, e.ipv4.ib2, e.ipv4.l2.etype,
+		FIELD_GET(MTK_FOE_IB2_QID, e.ipv4.ib2));
+	return hash;
+}
+
+/* register-only + arm the RX gate: tests the FORWARD_BUILD -> RX bind mechanism. */
+u32 en75_ppe_bindtest_register(struct en75_ppe *ppe, __be32 sip, __be32 dip,
+			       __be16 sport, __be16 dport, u8 proto,
+			       const u8 *smac, const u8 *dmac,
+			       int dsa_port, bool passthrough, u8 pse_port)
+{
+	struct en75_flow_entry *fe = kzalloc(sizeof(*fe), GFP_KERNEL);
+	u32 hash;
+
+	if (!fe)
+		return 0xffff;
+	en75_build_test_flow(&fe->data, sip, dip, sport, dport, proto, smac, dmac,
+			     dsa_port, passthrough, pse_port);
+	fe->static_entry = true;
+	en75_foe_entry_register(ppe, fe);
+	hash = en75_ppe_hash_entry(&fe->data);
+	WRITE_ONCE(en75_ppe_offload_enabled, true);
+	pr_info("XR500v PPE bindtest: registered flow sw-hash=%u, RX bind armed\n", hash);
+	return hash;
+}

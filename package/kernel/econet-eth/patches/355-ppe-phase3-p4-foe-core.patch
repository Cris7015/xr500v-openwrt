+struct en75_ppe_diag_counters {
+	atomic_t pre_total;
+	atomic_t post_total;
+	atomic_t rate_limited;
+	atomic_t invalid_hash;
+	atomic_t gate_pass;
+	atomic_t gate_skip;
+	atomic_t prebind_promote;
+	atomic_t prebind_arm;
+	atomic_t flip;
+	atomic_t rx_commit;
+	atomic_t nobind;
+	atomic_t tx_arm;
+	atomic_t first_slot;
+	atomic_t last_slot;
+	atomic_t slot_changes;
+	atomic_t pre_hist[EN75_PPE_DIAG_CRSN_BUCKETS];
+	atomic_t post_hist[EN75_PPE_DIAG_CRSN_BUCKETS];
+	atomic_t limited_hist[EN75_PPE_DIAG_CRSN_BUCKETS];
+	atomic_t gate_skip_hist[EN75_PPE_DIAG_CRSN_BUCKETS];
+};

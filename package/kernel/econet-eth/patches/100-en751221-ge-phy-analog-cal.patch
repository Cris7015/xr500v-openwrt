diff -urN orig/econet-eth-2026.02.13~c2f855cf/gsw/mt7530.c patched/gsw/mt7530.c
--- a/gsw/mt7530.c	2026-02-13 15:07:32.000000000 +0000
+++ b/gsw/mt7530.c	2026-05-08 13:45:45.022021248 +0000
@@ -463,6 +463,493 @@
 	core_set(priv, CORE_TRGMII_GSW_CLK_CG, REG_TRGMIICK_EN);
 }
 
+/* === ITER58_PHY_ANALOG_CAL + ITER59_C45_BYPASS ============================================
+ * GE PHY analog calibration ported from cjdelisle/EN751221-Linux26 SDK
+ * (kernel 2.6 tcetherphy_7512.c lines 8569+).
+ *
+ * Without this calibration, the PHY auto-negotiates link UP but TX signal
+ * is electrically out of spec (wrong impedance, amplitude, offset).  Frames
+ * get corrupted at the physical layer, so the receiving end (SoC GMAC via
+ * TRGMII for our switch port@6) drops them and cdm_rxcpu stays at 0.
+ *
+ * Cal sequence per PHY:
+ *   1. Rext cal — calibrates external reference resistor (sweep zcal_ctrl
+ *      until comparator flips, store result)
+ *   2. R50 cal — calibrates 50-ohm termination per pair A/B/C/D
+ *   3. Tx offset cal — calibrates DAC offset per pair
+ *   4. Tx amp cal — calibrates TX amplitude per pair
+ *   5. Rx offset cal — HW-driven, single trigger
+ */
+
+#define EN_ANACAL_INIT       0x01
+#define EN_ANACAL_ERROR      0xFD
+#define EN_ANACAL_SATURATION 0xFE
+#define EN_ANACAL_FINISH     0xFF
+
+#define EN_DAC_IN_0V         0x000
+#define EN_DAC_IN_2V         0x0f0
+
+static const u8 ZCAL_TO_R50ohm_TBL_100[64] = {
+	127, 127, 127, 127, 127, 127, 126, 123, 120, 117, 114, 112, 110, 107, 105, 103,
+	101, 99,  97,  79,  77,  75,  74,  72,  70,  69,  67,  66,  65,  47,  46,  45,
+	43,  42,  41,  40,  39,  38,  37,  36,  34,  34,  33,  32,  15,  14,  13,  12,
+	11,  10,  10,  9,   8,   7,   7,   6,   5,   4,   4,   3,   2,   2,   1,   1,
+};
+
+/* iter59: ITER59_C45_BYPASS — direct C45 helpers
+ *
+ * phy_read_mmd / phy_write_mmd in mainline Linux fall back to Clause 22
+ * emulation (writes to regs 13/14 of the PHY) when phydev->is_c45 is
+ * false.  The EN751221 GE PHY does not implement MMD via regs 13/14;
+ * its analog cal MMD bank can only be reached through the switch's
+ * PHY_IAC controller in Clause 45 mode.  The driver already registers
+ * read_c45 / write_c45 callbacks on priv->user_bus, so we just call
+ * mdiobus_c45_read / mdiobus_c45_write directly — that path drives
+ * mt7531_ind_c45_phy_read / mt7531_ind_c45_phy_write on EN751221, which
+ * issue native C45 frames on PHY_IAC.
+ */
+static int en751221_mmd_read(struct phy_device *phydev, int devad, u32 regnum)
+{
+	return mdiobus_c45_read(phydev->mdio.bus, phydev->mdio.addr,
+				devad, regnum);
+}
+
+static int en751221_mmd_write(struct phy_device *phydev, int devad,
+			      u32 regnum, u16 val)
+{
+	return mdiobus_c45_write(phydev->mdio.bus, phydev->mdio.addr,
+				 devad, regnum, val);
+}
+
+static u8 en751221_anacal_wait(struct phy_device *phydev, u32 delay)
+{
+	int v;
+
+	en751221_mmd_write(phydev, 0x1e, 0x017c, 0x0001); /* da_calin_flag high */
+	udelay(delay);
+	v = en751221_mmd_read(phydev, 0x1e, 0x017b);
+	en751221_mmd_write(phydev, 0x1e, 0x017c, 0x0000); /* da_calin_flag low */
+	if (v < 0)
+		return 0;
+	return (u8)(v & 0x1);
+}
+
+/* Returns 0 on success, 1 if cal needs retry (caller should loop) */
+static int en751221_phy_cal_rext(struct phy_device *phydev)
+{
+	u8 status, zcal_ctrl, cnt = 0;
+	int polarity, comp_init, v;
+
+	en751221_mmd_write(phydev, 0x1e, 0x00db, 0x1110);
+	en751221_mmd_write(phydev, 0x1e, 0x00dc, 0x0000);
+	en751221_mmd_write(phydev, 0x1e, 0x00e1, 0x0000);
+
+	zcal_ctrl = 0x20;
+	en751221_mmd_write(phydev, 0x1e, 0x00e0, zcal_ctrl);
+
+	status = en751221_anacal_wait(phydev, 100);
+	if (status == 0) {
+		phydev_warn(phydev, "Rext cal: initial wait fail\n");
+		en751221_mmd_write(phydev, 0x1e, 0x00db, 0x0000);
+		return 1;
+	}
+
+	v = en751221_mmd_read(phydev, 0x1e, 0x017a);
+	comp_init = (v >> 8) & 0x1;
+	polarity = comp_init ? -1 : 1;
+
+	while (status < EN_ANACAL_ERROR) {
+		cnt++;
+		zcal_ctrl += polarity;
+		en751221_mmd_write(phydev, 0x1e, 0x00e0, zcal_ctrl);
+		status = en751221_anacal_wait(phydev, 100);
+
+		if (status == 0) {
+			status = EN_ANACAL_ERROR;
+			break;
+		}
+		v = en751221_mmd_read(phydev, 0x1e, 0x017a);
+		if (((v >> 8) & 0x1) != comp_init) {
+			status = EN_ANACAL_FINISH;
+			break;
+		}
+		if (zcal_ctrl == 0x3F || zcal_ctrl == 0x00) {
+			status = EN_ANACAL_SATURATION;
+			break;
+		}
+	}
+
+	if (status == EN_ANACAL_ERROR) {
+		zcal_ctrl = 0x20;
+		en751221_mmd_write(phydev, 0x1e, 0x00e0, zcal_ctrl);
+		en751221_mmd_write(phydev, 0x1e, 0x00db, 0x0000);
+		return 1;
+	}
+
+	en751221_mmd_write(phydev, 0x1e, 0x00e0, zcal_ctrl);
+	en751221_mmd_write(phydev, 0x1e, 0x00e0, ((u16)zcal_ctrl << 8) | zcal_ctrl);
+	en751221_mmd_write(phydev, 0x1f, 0x0115, (zcal_ctrl & 0x3f) >> 3);
+	en751221_mmd_write(phydev, 0x1e, 0x00db, 0x0000);
+
+	phydev_info(phydev, "Rext cal done (cnt=%d zcal=0x%02x)\n", cnt, zcal_ctrl);
+	return 0;
+}
+
+static void en751221_phy_cal_r50_pair(struct phy_device *phydev, int pair)
+{
+	u8 status, zcal_ctrl, cnt = 0;
+	int polarity, comp_init, v;
+	u16 dev1e_e0_r5;
+
+	zcal_ctrl = 0x20;
+	v = en751221_mmd_read(phydev, 0x1e, 0x00e0);
+	dev1e_e0_r5 = (v < 0 ? 0 : v) & ~0x003f;
+	en751221_mmd_write(phydev, 0x1e, 0x00e0, dev1e_e0_r5 | zcal_ctrl);
+
+	switch (pair) {
+	case 0:
+		en751221_mmd_write(phydev, 0x1e, 0x00db, 0x1101);
+		en751221_mmd_write(phydev, 0x1e, 0x00dc, 0x0000);
+		break;
+	case 1:
+		en751221_mmd_write(phydev, 0x1e, 0x00db, 0x1100);
+		en751221_mmd_write(phydev, 0x1e, 0x00dc, 0x1000);
+		break;
+	case 2:
+		en751221_mmd_write(phydev, 0x1e, 0x00db, 0x1100);
+		en751221_mmd_write(phydev, 0x1e, 0x00dc, 0x0100);
+		break;
+	default:
+		en751221_mmd_write(phydev, 0x1e, 0x00db, 0x1100);
+		en751221_mmd_write(phydev, 0x1e, 0x00dc, 0x0010);
+		break;
+	}
+
+	status = en751221_anacal_wait(phydev, 20);
+	if (status == 0) {
+		phydev_warn(phydev, "R50 pair %c: initial wait fail\n", 'A' + pair);
+		return;
+	}
+
+	v = en751221_mmd_read(phydev, 0x1e, 0x017a);
+	comp_init = (v >> 8) & 0x1;
+	polarity = comp_init ? -1 : 1;
+
+	while (status < EN_ANACAL_ERROR) {
+		cnt++;
+		zcal_ctrl += polarity;
+		en751221_mmd_write(phydev, 0x1e, 0x00e0, dev1e_e0_r5 | zcal_ctrl);
+		status = en751221_anacal_wait(phydev, 20);
+		if (status == 0) {
+			status = EN_ANACAL_ERROR;
+			break;
+		}
+		v = en751221_mmd_read(phydev, 0x1e, 0x017a);
+		if (((v >> 8) & 0x1) != comp_init) {
+			status = EN_ANACAL_FINISH;
+			break;
+		}
+		if (zcal_ctrl == 0x3F || zcal_ctrl == 0x00) {
+			status = EN_ANACAL_SATURATION;
+			break;
+		}
+	}
+
+	if (status == EN_ANACAL_ERROR)
+		return;
+
+	zcal_ctrl = ZCAL_TO_R50ohm_TBL_100[zcal_ctrl] - 2;
+
+	switch (pair) {
+	case 0:
+		v = en751221_mmd_read(phydev, 0x1e, 0x0174) & ~0x7f00;
+		en751221_mmd_write(phydev, 0x1e, 0x0174,
+			      v | (((u16)zcal_ctrl << 8) & 0xff00) | 0x8000);
+		break;
+	case 1:
+		v = en751221_mmd_read(phydev, 0x1e, 0x0174) & ~0x007f;
+		en751221_mmd_write(phydev, 0x1e, 0x0174,
+			      v | (zcal_ctrl & 0x00ff) | 0x0080);
+		break;
+	case 2:
+		v = en751221_mmd_read(phydev, 0x1e, 0x0175) & ~0x7f00;
+		en751221_mmd_write(phydev, 0x1e, 0x0175,
+			      v | (((u16)zcal_ctrl << 8) & 0xff00) | 0x8000);
+		break;
+	default:
+		v = en751221_mmd_read(phydev, 0x1e, 0x0175) & ~0x007f;
+		en751221_mmd_write(phydev, 0x1e, 0x0175,
+			      v | (zcal_ctrl & 0x00ff) | 0x0080);
+		break;
+	}
+	phydev_info(phydev, "R50 pair %c done (cnt=%d zcal=0x%02x)\n",
+		    'A' + pair, cnt, zcal_ctrl);
+}
+
+static void en751221_phy_cal_tx_offset_pair(struct phy_device *phydev, int pair)
+{
+	static const u16 dac_in_regs[4][2] = {
+		{ 0x017d, 0x0181 },
+		{ 0x017e, 0x0182 },
+		{ 0x017f, 0x0183 },
+		{ 0x0180, 0x0184 },
+	};
+	static const u16 dd_bits[4]   = { 0x1000, 0x0100, 0x0010, 0x0001 };
+	static const u16 ofs_regs[4]  = { 0x0172, 0x0172, 0x0173, 0x0173 };
+	static const u8  ofs_shifts[4] = { 8, 0, 8, 0 };
+	int polarity, comp_init, tx_offset_temp, v;
+	u16 reg_temp, mask, cal_temp;
+	u8 status, cnt = 0;
+
+	tx_offset_temp = 0;
+
+	en751221_mmd_write(phydev, 0x1e, 0x00dd, dd_bits[pair]);
+	en751221_mmd_write(phydev, 0x1e, dac_in_regs[pair][0], 0x8000 | EN_DAC_IN_0V);
+	en751221_mmd_write(phydev, 0x1e, dac_in_regs[pair][1], 0x8000 | EN_DAC_IN_0V);
+
+	mask = 0x3f << ofs_shifts[pair];
+	v = en751221_mmd_read(phydev, 0x1e, ofs_regs[pair]);
+	reg_temp = (v < 0 ? 0 : v) & ~mask;
+	en751221_mmd_write(phydev, 0x1e, ofs_regs[pair],
+		      reg_temp | ((u16)tx_offset_temp << ofs_shifts[pair]));
+
+	status = en751221_anacal_wait(phydev, 20);
+	if (status == 0) {
+		phydev_warn(phydev, "Tx offset pair %c: initial wait fail\n", 'A' + pair);
+		return;
+	}
+
+	v = en751221_mmd_read(phydev, 0x1e, 0x017a);
+	comp_init = (v >> 8) & 0x1;
+	polarity = comp_init ? -1 : 1;
+
+	while (status < EN_ANACAL_ERROR) {
+		cnt++;
+		tx_offset_temp += polarity;
+		if (tx_offset_temp >= 0)
+			cal_temp = tx_offset_temp;
+		else
+			cal_temp = (1 << 5) | abs(tx_offset_temp);
+		en751221_mmd_write(phydev, 0x1e, ofs_regs[pair],
+			      reg_temp | ((u16)cal_temp << ofs_shifts[pair]));
+		status = en751221_anacal_wait(phydev, 20);
+		if (status == 0) {
+			status = EN_ANACAL_ERROR;
+			break;
+		}
+		v = en751221_mmd_read(phydev, 0x1e, 0x017a);
+		if (((v >> 8) & 0x1) != comp_init) {
+			status = EN_ANACAL_FINISH;
+			break;
+		}
+		if (tx_offset_temp == -31 || tx_offset_temp == 31) {
+			status = EN_ANACAL_SATURATION;
+			break;
+		}
+	}
+
+	if (status == EN_ANACAL_ERROR) {
+		tx_offset_temp = 0;
+		en751221_mmd_write(phydev, 0x1e, ofs_regs[pair],
+			      reg_temp | ((u16)tx_offset_temp << ofs_shifts[pair]));
+		return;
+	}
+	phydev_info(phydev, "Tx offset pair %c done (cnt=%d val=0x%02x)\n",
+		    'A' + pair, cnt, cal_temp);
+}
+
+static void en751221_phy_cal_tx_amp_pair(struct phy_device *phydev, int pair)
+{
+	static const u16 dac_in_regs[4][2] = {
+		{ 0x017d, 0x0181 },
+		{ 0x017e, 0x0182 },
+		{ 0x017f, 0x0183 },
+		{ 0x0180, 0x0184 },
+	};
+	static const u16 dd_bits[4]      = { 0x1000, 0x0100, 0x0010, 0x0001 };
+	static const u16 amp_regs[4]     = { 0x0012, 0x0017, 0x0019, 0x0021 };
+	static const u16 amp_regs_100[4] = { 0x0016, 0x0018, 0x0020, 0x0022 };
+	static const u16 mask_a          = 0xfc00;
+	static const u16 mask_bcd        = 0x3f00;
+	static const u8 amp_shifts[4]    = { 10, 8, 8, 8 };
+	int polarity, comp_init, v;
+	u8 status, tx_amp_temp, cnt = 0;
+	u16 reg_temp, mask;
+
+	tx_amp_temp = 0x20;
+
+	en751221_mmd_write(phydev, 0x1e, 0x00dd, dd_bits[pair]);
+	en751221_mmd_write(phydev, 0x1e, dac_in_regs[pair][0], 0x8000 | EN_DAC_IN_2V);
+	en751221_mmd_write(phydev, 0x1e, dac_in_regs[pair][1], 0x8000 | EN_DAC_IN_2V);
+
+	mask = (pair == 0) ? mask_a : mask_bcd;
+	v = en751221_mmd_read(phydev, 0x1e, amp_regs[pair]);
+	reg_temp = (v < 0 ? 0 : v) & ~mask;
+	en751221_mmd_write(phydev, 0x1e, amp_regs[pair],
+		      reg_temp | ((u16)tx_amp_temp << amp_shifts[pair]));
+
+	status = en751221_anacal_wait(phydev, 20);
+	if (status == 0) {
+		phydev_warn(phydev, "Tx amp pair %c: initial wait fail\n", 'A' + pair);
+		return;
+	}
+
+	v = en751221_mmd_read(phydev, 0x1e, 0x017a);
+	comp_init = (v >> 8) & 0x1;
+	polarity = comp_init ? -1 : 1;
+
+	while (status < EN_ANACAL_ERROR) {
+		cnt++;
+		tx_amp_temp += polarity;
+		en751221_mmd_write(phydev, 0x1e, amp_regs[pair],
+			      reg_temp | ((u16)tx_amp_temp << amp_shifts[pair]));
+		status = en751221_anacal_wait(phydev, 100);
+		if (status == 0) {
+			status = EN_ANACAL_ERROR;
+			break;
+		}
+		v = en751221_mmd_read(phydev, 0x1e, 0x017a);
+		if (((v >> 8) & 0x1) != comp_init) {
+			status = EN_ANACAL_FINISH;
+			v = en751221_mmd_read(phydev, 0x1e, amp_regs[pair]);
+			reg_temp = (v < 0 ? 0 : v) & ~0xff00;
+			en751221_mmd_write(phydev, 0x1e, amp_regs[pair],
+				      reg_temp | (((u16)(tx_amp_temp + 0x2)) << amp_shifts[pair]));
+			break;
+		}
+		if (tx_amp_temp == 0x3f || tx_amp_temp == 0x00) {
+			status = EN_ANACAL_SATURATION;
+			break;
+		}
+	}
+
+	if (status == EN_ANACAL_ERROR) {
+		tx_amp_temp = 0x20;
+		en751221_mmd_write(phydev, 0x1e, amp_regs[pair],
+			      reg_temp | ((u16)tx_amp_temp << amp_shifts[pair]));
+		return;
+	}
+
+	v = en751221_mmd_read(phydev, 0x1e, amp_regs_100[pair]);
+	reg_temp = (v < 0 ? 0 : v) & ~0x003f;
+	if (status == EN_ANACAL_SATURATION || tx_amp_temp == 0)
+		en751221_mmd_write(phydev, 0x1e, amp_regs_100[pair], reg_temp | 0x0010);
+	else
+		en751221_mmd_write(phydev, 0x1e, amp_regs_100[pair],
+			      reg_temp | (tx_amp_temp + 14));
+
+	v = en751221_mmd_read(phydev, 0x1e, amp_regs_100[pair]);
+	reg_temp = (v < 0 ? 0 : v) & ~0xff00;
+	if (status == EN_ANACAL_SATURATION || tx_amp_temp == 0)
+		en751221_mmd_write(phydev, 0x1e, amp_regs_100[pair],
+			      reg_temp | (0x4 << amp_shifts[pair]));
+	else
+		en751221_mmd_write(phydev, 0x1e, amp_regs_100[pair],
+			      reg_temp | (((u16)(tx_amp_temp + 0x9)) << amp_shifts[pair]));
+
+	phydev_info(phydev, "Tx amp pair %c done (cnt=%d val=0x%02x)\n",
+		    'A' + pair, cnt, tx_amp_temp);
+}
+
+static void en751221_phy_analog_cal(struct phy_device *phydev)
+{
+	int reg0_temp, dev1e_145_temp, retry, pair;
+
+	phydev_info(phydev, "ITER58: starting GE PHY analog cal\n");
+
+	phy_write(phydev, 0x1f, 0x0000); /* page 0 */
+	reg0_temp = phy_read(phydev, MII_BMCR);
+	phy_write(phydev, MII_BMCR, 0x0140); /* AN dis, FD, 1G */
+
+	en751221_mmd_write(phydev, 0x1f, 0x0100, 0xc000);
+	dev1e_145_temp = en751221_mmd_read(phydev, 0x1e, 0x0145);
+	en751221_mmd_write(phydev, 0x1e, 0x0145, 0x1010);
+	en751221_mmd_write(phydev, 0x1e, 0x0185, 0x0000);
+
+	/* Rext cal — retry up to 5 times if needed */
+	for (retry = 0; retry < 5; retry++) {
+		if (en751221_phy_cal_rext(phydev) == 0)
+			break;
+		phydev_warn(phydev, "Rext cal retry %d\n", retry + 1);
+	}
+
+	/* R50 cal pairs A..D */
+	en751221_mmd_write(phydev, 0x1e, 0x00db, 0x1100);
+	en751221_mmd_write(phydev, 0x1e, 0x00dc, 0x0000);
+	for (pair = 0; pair < 4; pair++)
+		en751221_phy_cal_r50_pair(phydev, pair);
+	en751221_mmd_write(phydev, 0x1e, 0x00db, 0x0000);
+
+	/* Tx offset cal */
+	en751221_mmd_write(phydev, 0x1e, 0x00db, 0x0100);
+	en751221_mmd_write(phydev, 0x1e, 0x00dc, 0x0001);
+	en751221_mmd_write(phydev, 0x1e, 0x0096, 0x8000);
+	en751221_mmd_write(phydev, 0x1e, 0x003e, 0xf808);
+	for (pair = 0; pair < 4; pair++)
+		en751221_phy_cal_tx_offset_pair(phydev, pair);
+	en751221_mmd_write(phydev, 0x1e, 0x017d, 0);
+	en751221_mmd_write(phydev, 0x1e, 0x017e, 0);
+	en751221_mmd_write(phydev, 0x1e, 0x017f, 0);
+	en751221_mmd_write(phydev, 0x1e, 0x0180, 0);
+	en751221_mmd_write(phydev, 0x1e, 0x0181, 0);
+	en751221_mmd_write(phydev, 0x1e, 0x0182, 0);
+	en751221_mmd_write(phydev, 0x1e, 0x0183, 0);
+	en751221_mmd_write(phydev, 0x1e, 0x0184, 0);
+	en751221_mmd_write(phydev, 0x1e, 0x00db, 0);
+	en751221_mmd_write(phydev, 0x1e, 0x00dc, 0);
+	en751221_mmd_write(phydev, 0x1e, 0x003e, 0);
+	en751221_mmd_write(phydev, 0x1e, 0x00dd, 0);
+
+	/* Tx amp cal */
+	en751221_mmd_write(phydev, 0x1e, 0x00db, 0x1100);
+	en751221_mmd_write(phydev, 0x1e, 0x00dc, 0x0001);
+	en751221_mmd_write(phydev, 0x1e, 0x00e1, 0x0010);
+	en751221_mmd_write(phydev, 0x1e, 0x003e, 0xf808);
+	for (pair = 0; pair < 4; pair++)
+		en751221_phy_cal_tx_amp_pair(phydev, pair);
+	en751221_mmd_write(phydev, 0x1e, 0x017d, 0);
+	en751221_mmd_write(phydev, 0x1e, 0x017e, 0);
+	en751221_mmd_write(phydev, 0x1e, 0x017f, 0);
+	en751221_mmd_write(phydev, 0x1e, 0x0180, 0);
+	en751221_mmd_write(phydev, 0x1e, 0x0181, 0);
+	en751221_mmd_write(phydev, 0x1e, 0x0182, 0);
+	en751221_mmd_write(phydev, 0x1e, 0x0183, 0);
+	en751221_mmd_write(phydev, 0x1e, 0x0184, 0);
+	en751221_mmd_write(phydev, 0x1e, 0x00db, 0);
+	en751221_mmd_write(phydev, 0x1e, 0x00dc, 0);
+	en751221_mmd_write(phydev, 0x1e, 0x003e, 0);
+	en751221_mmd_write(phydev, 0x1e, 0x00dd, 0);
+
+	/* Rx offset cal — HW driven, single trigger */
+	{
+		int v;
+		en751221_mmd_write(phydev, 0x1e, 0x0096, 0x8000);
+		en751221_mmd_write(phydev, 0x1e, 0x0037, 0x0033);
+		v = en751221_mmd_read(phydev, 0x1e, 0x0039);
+		en751221_mmd_write(phydev, 0x1e, 0x0039, (v < 0 ? 0 : v) & ~0x4800);
+		v = en751221_mmd_read(phydev, 0x1f, 0x0107);
+		en751221_mmd_write(phydev, 0x1f, 0x0107, (v < 0 ? 0 : v) & ~0x1000);
+		v = en751221_mmd_read(phydev, 0x1e, 0x0171);
+		en751221_mmd_write(phydev, 0x1e, 0x0171, ((v < 0 ? 0 : v) & ~0x0180) | 0x0180);
+		v = en751221_mmd_read(phydev, 0x1e, 0x0039);
+		en751221_mmd_write(phydev, 0x1e, 0x0039, (v < 0 ? 0 : v) | 0x2000);
+		en751221_mmd_write(phydev, 0x1e, 0x0039, (v < 0 ? 0 : v) & ~0x2000);
+		mdelay(10);
+		v = en751221_mmd_read(phydev, 0x1e, 0x0171);
+		en751221_mmd_write(phydev, 0x1e, 0x0171, (v < 0 ? 0 : v) & ~0x0180);

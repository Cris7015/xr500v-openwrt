#!/bin/sh
# 79_ubi_attach — attach UBI to openwrt_ubi partition (iter35+) AND
# pre-mount the UBIFS volume at /tmp/overlay before mount_root runs.
#
# Pre-iter35: the UBI lived in a "rootfs_data" sub-partition auto-derived
# from rootfs1 (after squashfs-split). Only 13MB was available.
# iter35+: dedicated UBI in the "openwrt_ubi" partition (64MB in the free
# area 0x3000000-0x7000000). The UBI volume name is still
# "rootfs_data" for compatibility with fstools/mount_root without
# patches.
#
# Kernel-time UBI auto-attach via `ubi.mtd=` cmdline triggers OOB-marker
# misinterpretation under en75_bmt-without-BBT and breaks subsequent userspace
# ubiformat. Userspace ubiattach via this hook is consistent.

attach_and_premount_ubifs_overlay() {
	local mtdnum
	mtdnum=$(grep '"openwrt_ubi"' /proc/mtd | cut -d: -f1 | tr -d 'mtd:')
	[ -n "$mtdnum" ] || { echo "[ubi-hook] no mtdnum (openwrt_ubi missing)" >/dev/console; return 0; }
	echo "[ubi-hook] mtdnum=$mtdnum (openwrt_ubi)" >/dev/console

	# Attach UBI. On a factory-fresh / web-flashed / wiped unit the partition
	# holds no valid UBI yet, so ubiattach fails -> format it and attach the
	# fresh UBI (first-boot auto-provision). Without this the overlay falls
	# back to a RAM-only tmpfs and configuration does not persist.
	if [ ! -d /sys/class/ubi/ubi0 ]; then
		if ! ubiattach -m "$mtdnum" -d 0 >/dev/console 2>&1; then
			echo "[ubi-hook] no valid UBI -> ubiformat (first provision)" >/dev/console
			ubiformat "/dev/mtd$mtdnum" -y >/dev/console 2>&1
			ubiattach -m "$mtdnum" -d 0 >/dev/console 2>&1 || {
				echo "[ubi-hook] ubiattach failed after format" >/dev/console
				return 0
			}
		fi
	fi

	# Create the rootfs_data volume if the (freshly formatted) UBI has none yet.
	if [ ! -d /sys/class/ubi/ubi0_0 ]; then
		# ubimkvol talks to the /dev/ubi0 control node, but the mknod loop
		# below only runs afterwards -> create that node here first.
		if [ ! -e /dev/ubi0 ] && [ -r /sys/class/ubi/ubi0/dev ]; then
			dm=$(cat /sys/class/ubi/ubi0/dev)
			mknod /dev/ubi0 c "${dm%:*}" "${dm#*:}" 2>/dev/null
			echo "[ubi-hook] mknod ubi0 c ${dm%:*} ${dm#*:} (for mkvol)" >/dev/console
		fi
		echo "[ubi-hook] no rootfs_data volume -> ubimkvol (first provision)" >/dev/console
		ubimkvol /dev/ubi0 -N rootfs_data -m >/dev/console 2>&1 || {
			echo "[ubi-hook] ubimkvol failed" >/dev/console
			return 0
		}
	fi
	# ubiattach is a SYNCHRONOUS ioctl: by the time it returns, /sys/class/ubi/*
	# already exists. Create the device nodes straight from sysfs. (This busybox
	# has no usleep and no mdev, and there is no devtmpfs -> the old loop fell
	# back to 'sleep 1' x50 = ~50s wasted.)
	for n in ubi0 ubi0_0; do
		if [ ! -e /dev/$n ] && [ -r /sys/class/ubi/$n/dev ]; then
			dm=$(cat /sys/class/ubi/$n/dev)
			mknod /dev/$n c "${dm%:*}" "${dm#*:}" 2>/dev/null
			echo "[ubi-hook] mknod $n c ${dm%:*} ${dm#*:}" >/dev/console
		fi
	done
	# belt-and-braces: a few short retries in case sysfs lags briefly
	local i=0
	while [ ! -e /dev/ubi0_0 ] && [ $i -lt 3 ]; do sleep 1; i=$((i + 1)); done
	[ -e /dev/ubi0_0 ] || { echo "[ubi-hook] /dev/ubi0_0 missing" >/dev/console; return 0; }
	echo "[ubi-hook] /dev/ubi0_0 exists (fast-path)" >/dev/console

	# UBIFS-warmup trick: the kernel-time UBIFS mount via mount_root fails
	# with -EINVAL when journal replay is needed. Mount + umount once here
	# triggers the journal replay so the volume is "clean" when mount_root
	# attempts its own mount. Then we leave /tmp/overlay non-existent so
	# mount_root's mkdir succeeds.
	mkdir -p /tmp/.ubifs_warmup
	mount -t ubifs ubi0:rootfs_data /tmp/.ubifs_warmup >/dev/console 2>&1
	local rc=$?
	echo "[ubi-hook] warmup mount RC=$rc" >/dev/console
	if [ "$rc" = "0" ]; then
		# ensure recovery committed before unmount
		sync
		umount /tmp/.ubifs_warmup >/dev/console 2>&1
		echo "[ubi-hook] warmup umount RC=$?" >/dev/console
	fi
	rmdir /tmp/.ubifs_warmup 2>/dev/null
}

boot_hook_add preinit_main attach_and_premount_ubifs_overlay

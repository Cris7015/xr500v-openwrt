--- econet-eth-2026.02.13~c2f855cf.orig/econet_ppe.c
+++ econet-eth-2026.02.13~c2f855cf/econet_ppe.c
@@ -367,8 +367,14 @@ void en75_foe_entry_set_pse_port(struct
 {
 	u32 *ib2 = &entry->ipv4.ib2;
 
-	*ib2 &= ~MTK_FOE_IB2_DEST_PORT;
-	*ib2 |= FIELD_PREP(MTK_FOE_IB2_DEST_PORT, port) | MTK_FOE_IB2_PSE_QOS;
+	*ib2 &= ~(MTK_FOE_IB2_DEST_PORT | MTK_FOE_IB2_PSE_QOS);
+	*ib2 |= FIELD_PREP(MTK_FOE_IB2_DEST_PORT, port);
+	/* patch 367: fqos/PSE_QOS only for the QDMA/PON path. OEM dp=1
+	 * (switch egress) binds are ib2=0x00FFF020 (fqos=0); only dp=6
+	 * upstream uses 0x00FFF0D0 (fqos=1). With fqos=1 on dp=1 the
+	 * forward detours via the QoS engine, which has no path here. */
+	if (port == 6)
+		*ib2 |= MTK_FOE_IB2_PSE_QOS;
 }
 
 static void en75_foe_entry_set_oem_bind_meta(struct mtk_foe_entry *entry)
@@ -382,8 +388,13 @@ static void en75_foe_entry_set_oem_bind_
 	 * for IPv4 HNAPT bind entries before setting ib1.vlan_layer=1. */
 	entry->ipv4.udf_tsid &= ~0xff;
 	entry->ipv4.udf_tsid |= port + 6;
-	entry->ipv4.l2.vlan1 = 0x8000 | port;
-	entry->ipv4.ib2 |= MTK_FOE_IB2_PSE_QOS;
+	/* patch 367: the old "halfword 0x2c = vlan1" Ghidra reading used the
+	 * backwards lane model; 0x2c is the ETYPE/special-tag halfword and
+	 * clobbering it here wrote 0x8000|port into the inserted tag's TCI
+	 * lane while re-forcing fqos -- both poisoned every dp=1 bind
+	 * (ib2=0x..030 instead of OEM 0x..020, tag [00 84 80 01] instead of
+	 * [00 84 00 00]). The egress l2/ib2 are now authored exclusively by
+	 * set_dsa/set_vlan/set_pppoe/set_pse_port in the bind builders. */
 }
 
 u32 en75_ppe_hash_entry(struct mtk_foe_entry *e)
@@ -463,10 +474,18 @@ void en75_foe_entry_commit(struct en75_p
 			 * Swap the halves of data words 6 (new.ports), 12
 			 * ([vlan2|dmac_lo]) and 14 ([pppoe|smac_lo]); the orig key
 			 * words stay raw (preserve-key copies the engine's own).
-			 * NOTE [vlan1|etype] (data word 10) is NOT swapped: OEM
-			 * live w11=0x00040000 = vlan1 in the HIGH half, and the
-			 * captured VTAG steering (VID=vlan1) worked as stored. */
-			if (i == 6 || i == 12 || i == 14)
+			 * patch 367: data word 10 ([vlan1|etype]) IS a mixed-u16
+			 * word like its siblings and needs the same swap. The old
+			 * "vlan1 in the HIGH half" reading of OEM w11=0x00040000
+			 * was backwards: the OEM upstream bind w11=0x0101000a only
+			 * decodes coherently as etype=0x0101 (BIT(0)|BIT(8), the
+			 * mainline set_dsa "DSA bitmap + VLAN present" encoding)
+			 * + vlan1=0x000a (Movistar GPON VID 10) -- so the HIGH
+			 * half is ETYPE (the special-tag halfword) and the low one
+			 * vlan1. Without this swap every set_dsa bitmap landed in
+			 * the engine's vlan1 (TCI) lane and no special tag was
+			 * built, so dp=1 frames died at the on-die switch. */
+			if (i == 6 || i == 10 || i == 12 || i == 14)
 				v = (v << 16) | (v >> 16);
 			dw[i] = swab32(v);
 		}
@@ -1094,6 +1113,10 @@ void en75_foe_entry_set_dsa(struct mtk_f
 		entry->ib1 |= FIELD_PREP(MTK_FOE_IB1_BIND_VLAN_LAYER, 1);
 	else
 		l2->etype |= BIT(8);
+	/* patch 367: the base entry is memcpy'd from the engine's UNBIND, so
+	 * vlan1 may carry stale bytes; the inserted tag is [etype:vlan1] and
+	 * the SW tagger zeroes tag[2:3] for untagged xmit -- match it. */
+	l2->vlan1 = 0;
 	entry->ib1 &= ~MTK_FOE_IB1_BIND_VLAN_TAG;
 }
 
@@ -1103,10 +1126,9 @@ void en75_foe_entry_set_queue(struct mtk
 
 	*ib2 &= ~MTK_FOE_IB2_QID;
 	*ib2 |= FIELD_PREP(MTK_FOE_IB2_QID, queue);
-	/* build #62: OEM ib2 -- switch-egress (dp=1, GSW) uses PSE_QOS=0 (0x..020);
-	 * only QDMA/GPON upstream (dp=6) uses PSE_QOS=1 (0x..0d0). We were always
-	 * forcing PSE_QOS=1 (-> 0x..030), wrong for our nested-DSA switch egress. */
-	*ib2 |= MTK_FOE_IB2_PSE_QOS;
+	/* build #62/patch 367: OEM ib2 -- switch-egress (dp=1, GSW) uses
+	 * PSE_QOS=0 (0x..020); only QDMA/GPON upstream (dp=6) uses PSE_QOS=1
+	 * (0x..0d0). fqos now follows the pse port (set_pse_port), not here. */
 }
 

+static void en75_rxstat_note_poll(int done)
+{
+	atomic64_t *bucket;
+
+	atomic64_inc(&en75_rxstat_poll_count);
+	if (!done)
+		return;
+
+	atomic64_add(done, &en75_rxstat_total_frames);
+
+	if (done <= 1)
+		bucket = &en75_rxstat_hist_1;
+	else if (done <= 2)
+		bucket = &en75_rxstat_hist_2;
+	else if (done <= 4)
+		bucket = &en75_rxstat_hist_4;
+	else if (done <= 8)
+		bucket = &en75_rxstat_hist_8;
+	else if (done <= 16)
+		bucket = &en75_rxstat_hist_16;
+	else if (done <= 32)
+		bucket = &en75_rxstat_hist_32;
+	else
+		bucket = &en75_rxstat_hist_64p;
+
+	atomic64_inc(bucket);
+}

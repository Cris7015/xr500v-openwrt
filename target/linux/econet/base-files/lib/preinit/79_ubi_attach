#!/bin/sh
# 79_ubi_attach — attach UBI to rootfs_data partition AND pre-mount the UBIFS
# volume at /tmp/overlay before mount_root runs.
#
# Kernel-time UBI auto-attach via `ubi.mtd=` cmdline triggers OOB-marker
# misinterpretation under en75_bmt-without-BBT and breaks subsequent userspace
# ubiformat. Userspace ubiattach via this hook is consistent.
#
# The pre-mount at /tmp/overlay sidesteps a bug where fstools mount_root
# fails to mount UBIFS with -EINVAL post-reboot, even though
# `mount -t ubifs ubi0:rootfs_data /target` works manually. With /tmp/overlay
# already mounted by us, mount_root proceeds to the overlayfs pivot.

attach_and_premount_ubifs_overlay() {
	local mtdnum
	mtdnum=$(grep '"rootfs_data"' /proc/mtd | cut -d: -f1 | tr -d 'mtd:')
	[ -n "$mtdnum" ] || { echo "[ubi-hook] no mtdnum" >/dev/console; return 0; }
	echo "[ubi-hook] mtdnum=$mtdnum" >/dev/console

	# Attach UBI if not already attached
	if [ ! -e /dev/ubi0_0 ]; then
		ubiattach -m "$mtdnum" -d 0 >/dev/console 2>&1 || {
			echo "[ubi-hook] ubiattach failed" >/dev/console
			return 0
		}
		# Give UBI background thread + udev/mdev time to settle
		sleep 2
	fi
	[ -e /dev/ubi0_0 ] || { echo "[ubi-hook] /dev/ubi0_0 missing" >/dev/console; return 0; }
	echo "[ubi-hook] /dev/ubi0_0 exists" >/dev/console

	# Pre-mount UBIFS volume where mount_root expects to find /tmp/overlay
	mkdir -p /tmp/overlay
	mount -t ubifs ubi0:rootfs_data /tmp/overlay >/dev/console 2>&1
	local rc=$?
	echo "[ubi-hook] mount RC=$rc" >/dev/console
	if [ "$rc" = "0" ]; then
		mkdir -p /tmp/overlay/upper /tmp/overlay/work
		echo "[ubi-hook] overlay ready" >/dev/console
	fi
}

boot_hook_add preinit_main attach_and_premount_ubifs_overlay

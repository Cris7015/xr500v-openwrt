-	en75_foe_entry_prepare(&e, MTK_PPE_PKT_TYPE_IPV4_HNAPT, l4proto, 1,
+	 * (the rewrite). Ethernet egress: dp=1 (GSW switch routes by the next-hop
+	 * dst MAC via its ARL -- match_all spike, cont29). WiFi egress (F2: smac ==
+	 * a registered mt76 AP vif): HALF-OFFLOAD -- force-to-CPU (dp=fcpu) so the
+	 * engine does the NAT then bounces the frame to the CPU, where the F3 demux
+	 * dev_queue_xmit's it to the mt76 vif (the OEM WHNAT model, cont32r/s).
+	 * PPPoE sid from FLOW_ACTION_PPPOE_PUSH (WiFi downstream has none). */
+	wifi_idx = en75_whnat_idx_by_mac(eth.h_source);
+	en75_foe_entry_prepare(&e, MTK_PPE_PKT_TYPE_IPV4_HNAPT, l4proto,
+			       wifi_idx >= 0 ? READ_ONCE(en75_ppe_fcpu_dp) : 1,
 			       eth.h_source, eth.h_dest);
 	en75_foe_entry_set_ipv4_tuple(&e, false, o_sip, o_sport, o_dip, o_dport);
 	en75_foe_entry_set_ipv4_tuple(&e, true, n_sip, n_sport, n_dip, n_dport);
 	if (sid)
 		en75_foe_entry_set_pppoe(&e, sid);
+	if (wifi_idx >= 0) {
+		/* magic VLAN the engine rides on the force-to-CPU frame: TCI = vif
+		 * index (0..15), etype 0x5678 (OEM QDMA-to-CPU tag). The F3 demux in
+		 * econet_qdma.c reads the TCI to pick the destination BSS netdev.
+		 * (The OEM force-to-CPU put vlan1=slot here; we put the vif idx so the
+		 * RX side recovers the BSS directly -- econet_ppe.c:2146 model.) */
+		e.ipv4.l2.vlan1 = wifi_idx;
+		e.ipv4.l2.etype = htons(0x5678);
+		e.ib1 &= ~MTK_FOE_IB1_BIND_VLAN_LAYER;
+		e.ib1 |= MTK_FOE_IB1_BIND_VLAN_TAG |
+			 FIELD_PREP(MTK_FOE_IB1_BIND_VLAN_LAYER, 1);
+		if (READ_ONCE(en75_ppe_fcpu_fqos))
+			e.ipv4.ib2 |= MTK_FOE_IB2_PSE_QOS;
+	}
 	/* build #72: the engine FORWARD_BUILDs its UNBIND key in swab32 order; match it
 	 * so the engine's LOOKUP of the real frame HITs our entry (we commit the real
 	 * tuple with no preserve_key, so we pre-swab like en75_build_test_flow does --
@@ -625,6 +644,7 @@
 		return -ENOMEM;
 	fe->data = e;		/* orig may be swab32 (tuple_swab) for the engine HIT */
 	fe->cookie = f->cookie;
+	fe->wifi_vif_idx = wifi_idx;	/* F2: >=0 if egress is an mt76 AP vif */
 	fe->ft_sip = ntohl(o_sip);	/* host-order match tuple for en75_ppe_ft_rx_bind */
 	fe->ft_dip = ntohl(o_dip);
 	fe->ft_sport = ntohs(o_sport);
@@ -632,8 +652,8 @@

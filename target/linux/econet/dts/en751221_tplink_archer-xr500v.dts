/dts-v1/;

#include "en751221.dtsi"
#include <dt-bindings/gpio/gpio.h>
#include <dt-bindings/input/input.h>

/ {
	model = "TP-Link Archer XR500v v1";
	compatible = "tplink,archer-xr500v", "econet,en751221";

	memory@0 {
		device_type = "memory";
		reg = <0x00000000 0x10000000>;
	};

	/* EN751221 PON-I2C source clock, matching the OEM and the upstream
	 * econet-eth-mainline model. The existing tc3162 GPIO driver leaves
	 * CHIP_SCUL 0x104 PON-I2C pinmux bit enabled on this board. */
	pon_i2c_clock: pon-i2c-clock {
		compatible = "fixed-clock";
		#clock-cells = <0>;
		clock-frequency = <20000000>;
	};

	pon_i2c: i2c@1fbf8000 {
		compatible = "mediatek,mt7621-i2c";
		reg = <0x1fbf8000 0x100>;
		clocks = <&pon_i2c_clock>;
		clock-frequency = <100000>;
		#address-cells = <1>;
		#size-cells = <0>;
		status = "okay";

		/* Diagnostic-only binding: reads ID/variant and raw OEM status bits;
		 * deliberately has no reset, init, latch-clear, laser, APD, ADC, or
		 * DDMI paths. */
		lddla@70 {
			compatible = "airoha,en7570-diag";
			reg = <0x70>;
		};
	};

	/* build #63: reserved high region for the PPE FoE table, OEM-style
	 * (OEM PpeFoeBase = ioremap(0x0dc00000)). no-map -> kernel never uses
	 * it; the econet-eth driver accesses it uncached via KSEG1. Testing if
	 * the FE DMA master only materializes FORWARD_BUILD entries here. */
	reserved-memory {
		#address-cells = <1>;
		#size-cells = <1>;
		ranges;

		ppe_foe_rsv: ppe-foe@dc00000 {
			reg = <0x0dc00000 0x00180000>;
			no-map;
		};

		/* panic-capture (plan wf_b4447b85): best-effort ramoops at the
		 * TOP 1 MiB of the 256 MiB (avoids low PHY-training scratch).
		 * RAM survival across the warm reset is likely-not-proven (closed
		 * DDR init ROM); netconsole in bootargs is the PRIMARY capture.
		 * ecc-size: reed-solomon corrects sparse DRAM decay over the
		 * ~100 ms refresh-less reset gap. */
		ramoops@ff00000 {
			compatible = "ramoops";
			reg = <0x0ff00000 0x00100000>;
			record-size  = <0x00020000>;
			console-size = <0x00040000>;
			pmsg-size    = <0x00020000>;
			ftrace-size  = <0x00000000>;
			ecc-size     = <16>;
			max-reason   = <5>;	/* KMSG_DUMP_OOPS and worse */
			no-map;
		};
	};

	chosen {
		stdout-path = "/serial@1fbf0000:115200";
		/*
		 * UBI overlay is attached at preinit time by
		 * /lib/preinit/79_ubi_attach (see base-files), NOT via kernel
		 * cmdline ubi.mtd=. The kernel-time auto-attach was found to
		 * mismark OOB on this NAND via en75_bmt, breaking subsequent
		 * userspace ubiformat. Userspace ubiattach is consistent.
		 *
		 * netconsole (panic-capture PRIMARY): cmdline is empty +
		 * MIPS_CMDLINE_FROM_DTB=y, so this IS the kernel cmdline. dev
		 * MUST be eth0 (only netdev at netconsole's late_initcall; the
		 * DSA user ports appear much later and netpoll rejects them);
		 * eth0 has no IP so src-ip is required. Receiver = .8, dst-mac
		 * baked (NETCONSOLE_DYNAMIC off to save kernel bytes).
		 */
		bootargs = "console=ttyS0,115200 netconsole=6665@192.168.68.222/eth0,6666@192.168.68.8/bc:24:11:a4:b6:6c";
	};

	leds {
		compatible = "gpio-leds";

		led-2  { label = "green:gpon";     gpios = <&gpio 2  GPIO_ACTIVE_LOW>; linux,default-trigger = "default-on"; };
		led-7  { label = "green:wps";      gpios = <&gpio 7  GPIO_ACTIVE_LOW>; };
		led-11 { label = "green:usb";      gpios = <&gpio 11 GPIO_ACTIVE_LOW>; };
		/* WiFi 2.4/5GHz LEDs are inside the MT7603/MT7662 chips (driven by
		 * the mt76 cdevs mt76-phy0/mt76-phy1), NOT these SoC GPIOs. */
		led-24 { label = "red:alarm";      gpios = <&gpio 24 GPIO_ACTIVE_LOW>; };
		led-25 { label = "green:phone1";   gpios = <&gpio 25 GPIO_ACTIVE_LOW>; };
		led-26 { label = "green:phone2";   gpios = <&gpio 26 GPIO_ACTIVE_LOW>; };
		led-28 { label = "green:internet"; gpios = <&gpio 28 GPIO_ACTIVE_LOW>; };
	};

	/*
	 * Rear-panel buttons. GPIO lines reverse-engineered from the OEM
	 * tp_gpio.ko (tp_btn_def table: RST=gpio0, WIFI=gpio4, WPS=gpio9) and
	 * confirmed empirically on the device: each line idles high and is
	 * pulled low while pressed (active-low). The reset long-press window of
	 * 0x32=50 polls x 100 ms = 5 s in the OEM table matches the user-guide's
	 * "hold 5 s to factory reset".
	 *
	 * gpio-keys-polled (not gpio-keys): the tc3162-gpio controller exposes
	 * no per-line interrupts, so the buttons must be polled. The OpenWrt
	 * gpio-button-hotplug driver binds this node and emits BUTTON= hotplug
	 * events to /etc/rc.button/{reset,rfkill,wps}.
	 */
	keys {
		compatible = "gpio-keys-polled";
		poll-interval = <20>;

		reset {
			label = "reset";
			linux,code = <KEY_RESTART>;
			gpios = <&gpio 0 GPIO_ACTIVE_LOW>;
			debounce-interval = <60>;
		};

		wifi {
			label = "wifi";
			linux,code = <KEY_RFKILL>;
			gpios = <&gpio 4 GPIO_ACTIVE_LOW>;
			debounce-interval = <60>;
		};

		wps {
			label = "wps";
			linux,code = <KEY_WPS_BUTTON>;
			gpios = <&gpio 9 GPIO_ACTIVE_LOW>;
			debounce-interval = <60>;
		};
	};
};

&nand {
	status = "okay";
	econet,bmt;
	/*
	 * Allow en75_bmt to write a Bad Block Table to the NAND reserve
	 * area on first boot. Without this property the driver gives up
	 * with "BBT not found" and falls back to per-boot OOB scanning,
	 * which conflicts with UBI's ECC parity in OOB and causes UBI
	 * to misdetect every PEB as bad after a write. With BBT, the
	 * bad-block status comes from the table not the OOB markers,
	 * so UBI persistence works across reboots.
	 */
	econet,can-write-factory-bbt;
	/*
	 * Provide an empty factory-badblocks list so en75_bmt's pub_init takes
	 * the "factory_badblocks given -> reconstruct BMT only" branch and
	 * SKIPS the destructive r_reconstruct_bbt() OOB scan. The OOB scan
	 * walks every block reading byte 0 raw and treats non-0xFF as bad,
	 * but byte 0 gets contaminated by UBI's writes so the scan reports
	 * more false bad blocks each boot. With empty factory-badblocks,
	 * user-area shift stays at 0 across reboots, which keeps the UBIFS
	 * volume's logical->physical mapping stable.
	 *
	 * Real factory bad blocks (if any) in the user area are handled by
	 * UBI itself (CONFIG_MTD_UBI_BEB_LIMIT) — UBI marks them on first
	 * write/erase failure and skips them for life of the volume.
	 */
	econet,factory-badblocks = <>;

	partitions {
		compatible = "fixed-partitions";
		#address-cells = <1>;
		#size-cells = <1>;

		/* XR500v partition layout (from /proc/mtd stock firmware) */

		partition@0 {
			label = "boot";
			reg = <0x0 0x40000>;
			read-only;
		};

		partition@40000 {
			label = "romfile";
			reg = <0x40000 0x40000>;
			read-only;
		};

		partition@80000 {
			label = "kernel";
			reg = <0x80000 0x300000>;
		};

		partition@380000 {
			/*
			 * Slot A rootfs holds the stock OEM squashfs (LZMA-compressed).
			 * Renamed from "rootfs" to "rootfs_stock" so OpenWrt's
			 * mtdsplit-support patch (drivers/mtd/mtdpart.c) does NOT match
			 * this partition by name — otherwise mtdsplit_squashfs runs on
			 * mtd3 (stock) and the global rootfs_found flag prevents it
			 * from running on mtd7 (rootfs1) where we actually need the
			 * overlay split.
			 */
			label = "rootfs_stock";
			reg = <0x380000 0x1000000>;
			read-only;
		};

		misc_partition: partition@1380000 {
			compatible = "nvmem-cells";
			label = "misc";
			reg = <0x1380000 0x480000>;
			#address-cells = <1>;
			#size-cells = <1>;
			read-only;

			/*
			 * Factory-programmed device data lives in this partition.
			 * Confirmed via `dd if=/dev/mtd_misc skip=0xF100 count=6`
			 * matching the same offset in the OEM stock dump:
			 *   0xF100: <ETH MAC, 6 bytes>
			 * The rest of the partition (most of it) is 0xFF padding.
			 */
			macaddr_misc_f100: macaddr@f100 {
				reg = <0xf100 0x6>;
			};

			/*
			 * iter36: MT7662 factory EEPROM (chip ID 0x7662 confirmed
			 * at byte 0). 512 bytes containing calibration data
			 * (TX power per-channel, etc). The mt76x2e driver reads it via
			 * nvmem-cells = <&eeprom_misc_e0000>; nvmem-cell-names = "eeprom".
			 * Without this, the driver uses conservative defaults (TX=3dBm).
			 */
			eeprom_misc_e0000: eeprom@e0000 {
				reg = <0xe0000 0x200>;
			};
		};

		partition@1800000 {
			label = "kernel1";
			reg = <0x1800000 0x300000>;
		};

		partition@1b00000 {
			/*
			 * Slot B rootfs (raw squashfs).
			 * linux,rootfs marks this partition as the root device for
			 * mount_root. mtd-split-squashfs still creates a
			 * "rootfs_data" sub-partition automatically after the squashfs
			 * end, but from iter35 onwards we do NOT use it: the UBI overlay
			 * lives in its own "openwrt_ubi" partition in the free area
			 * 0x3000000-0x7000000 (confirmed empty with a full dump).
			 * The preinit hook 79_ubi_attach now points to openwrt_ubi.
			 */
			label = "rootfs1";
			reg = <0x1b00000 0x1000000>;
			linux,rootfs;
		};

		partition@2b00000 {
			label = "others";
			reg = <0x2b00000 0x4e0000>;
		};

		partition@2fe0000 {
			label = "bootflag";
			reg = <0x2fe0000 0x20000>;
		};

		/*
		 * iter35: dedicated UBI partition in the unused free area.
		 *
		 * The stock OEM exposes /dev/mtd0 = "ALL" at 0x07000000 (112MB)
		 * — that is the en75_bmt "user" space before its reserve area
		 * (922 user blocks * 128KB = ~115MB, OEM reports 112MB).
		 * The 9 existing partitions sum to 0x3000000 (48MB), leaving
		 * 0x3000000-0x7000000 (64MB) available. Confirmed erased
		 * with a full dump on 2026-05-08 (16 chunks of 4MB, all
		 * md5 hash = 4MB of 0xff).
		 *
		 * This partition is provisioned with ubiformat/ubiattach/ubimkvol
		 * from a running OpenWrt (one-time per device); the preinit hook
		 * 79_ubi_attach attaches it on every boot.
		 */
		partition@3000000 {
			label = "openwrt_ubi";
			reg = <0x3000000 0x4000000>;
		};
	};
};


&gmac0 {
	status = "okay";
	nvmem-cells = <&macaddr_misc_f100>;
	nvmem-cell-names = "mac-address";
};

/*
 * Plan B (correct model, Caleb's dual-switch MDIO/MCM):
 * switch0 is the MCM MT7530 (mediatek,mt7530 + mediatek,mcm) hanging off the
 * SoC ethernet's MDIO bus at address 0x1f. It has 4 user GE ports (port@0..3)
 * and port@6 = CPU (trgmii to gmac0). The on-die switch is configured by
 * the bootloader for the cascade and is NOT a DSA device.
 * Internal PHYs of the MCM switch are auto-detected by the mt7530 driver.
 */
&switch0port0 {
	status = "disabled";
};

&switch0port1 {
	status = "okay";
	label = "lan4";
};

&switch0port2 {
	status = "okay";
	label = "lan3";
};

&switch0port3 {
	status = "okay";
	label = "lan2";
};

&switch0port4 {
	status = "okay";
	label = "lan1";
};

/*
 * iter57 v2: Enable PCIe (lost status=okay during the dts rewrite)
 * pcie0 = port0 (no slot there)
 * pcie1 + slot1 = MT7662 WiFi card
 */

&pcie0 {
	status = "okay";
};

&pcie1 {
	status = "okay";
};

&slot1 {
	wifi@0,0 {
		/* MT7662 dual-band 802.11ac */
		compatible = "mediatek,mt76";
		reg = <0x0000 0 0 0 0>;
		nvmem-cells = <&eeprom_misc_e0000>, <&macaddr_misc_f100>;
		nvmem-cell-names = "eeprom", "mac-address";
		/* 5GHz MAC = base flash 0xf100 + 2 (= OEM scheme: wlan5 BSSID ...3A).
		 * Without this, the 5GHz stayed at the base ...38 and collided with the
		 * DSA conduit / 2.4 GHz when the MT7603 increment failed. */
		mac-address-increment = <2>;

		/* Panel 5GHz LED = MT7662 MAC LED pin 2, active-low. mt76
		 * kicks MT_LED_CTRL on pin 2; the phy1tpt throughput trigger
		 * is auto-assigned by the driver (no board.d/uci needed). */
		led {
			led-sources = <2>;
			led-active-low;
		};
	};
};

&slot0 {
	wifi@0,0 {
		/* MT7603 2.4GHz -- synthetic inline EEPROM (wall 2). MAC is a placeholder +
		 * cal from the real eFuse; replace with the real EEPROM in the future. */
		compatible = "mediatek,mt76";
		reg = <0x0000 0 0 0 0>;
		/* Real factory MAC: base flash 0xf100 + 1 (per-device, universal) */
		nvmem-cells = <&macaddr_misc_f100>;
		nvmem-cell-names = "mac-address";
		mac-address-increment = <1>;

		/* Panel 2.4GHz LED = MT7603 chip-internal GPIO12+GPIO13
		 * (active-low), driven by the mt7603 driver from the LED
		 * callbacks (phy0tpt trigger auto-assigned). */
		mediatek,gpio-led;

		mediatek,eeprom-data = /bits/ 8 <
			0x03 0x76 0x00 0x00 0x02 0x76 0x03 0x50 0x00 0x01 0x00 0x00 0x00 0x00 0x00 0x00
			0x00 0x00 0x00 0x00 0x00 0x00 0x00 0x00 0x00 0x00 0x00 0x00 0x00 0x00 0x00 0x00
			0x00 0x00 0x00 0x00 0x00 0x00 0x00 0x00 0x00 0x00 0x00 0x00 0x00 0x00 0x00 0x00
			0x00 0x00 0x00 0x00 0x22 0x00 0x00 0x00 0x00 0x00 0x00 0x00 0x00 0x00 0x00 0x00
			0x00 0x00 0x00 0x00 0x00 0x00 0x00 0x00 0x00 0x00 0x00 0x00 0x00 0x00 0x00 0x00
			0x00 0x00 0x00 0x00 0x00 0xb8 0x40 0xc8 0x20 0x00 0x00 0x00 0x40 0xc8 0x20 0x00
			0x00 0x00 0x00 0x00 0x00 0x00 0x00 0x00 0x00 0x00 0x00 0x00 0x00 0x00 0x00 0x00
			0x00 0x00 0x00 0x00 0x00 0x00 0x00 0x00 0x00 0x00 0x00 0x00 0x00 0x00 0x00 0x00
			0x00 0x00 0x00 0x00 0x00 0x00 0x00 0x00 0x00 0x00 0x00 0x00 0x00 0x00 0x00 0x00
			0x00 0x00 0x00 0x00 0x00 0x00 0x00 0x00 0x00 0x00 0x00 0x00 0x00 0x00 0x00 0x00
			0x00 0x00 0x00 0x00 0x00 0x00 0x00 0x00 0x00 0x00 0x00 0x00 0x00 0x00 0x00 0x00
			0x00 0x00 0x00 0x00 0x00 0x00 0x00 0x00 0x00 0x00 0x00 0x00 0x00 0x00 0x00 0x00
			0x00 0x00 0x00 0x00 0x00 0x00 0x00 0x00 0x00 0x00 0x00 0x00 0x00 0x00 0x00 0x00
			0x00 0x00 0x00 0x00 0x00 0x00 0x00 0x00 0x00 0x00 0x00 0x00 0x00 0x00 0x00 0x00
			0x00 0x00 0x00 0x00 0x00 0x00 0x00 0x00 0x00 0x00 0x00 0x00 0x00 0x00 0x00 0x00
			0x05 0x00 0x00 0x00 0xa4 0x00 0x00 0x88 0x00 0x00 0x00 0x00 0x00 0x00 0x00 0x00
			0x00 0x00 0x00 0x00 0x00 0x00 0x00 0x00 0x00 0x00 0x00 0x00 0x00 0x00 0x00 0x00

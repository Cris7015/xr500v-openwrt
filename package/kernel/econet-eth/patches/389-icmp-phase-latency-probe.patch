+module_param_named(icmp_phase_rx_seen, en75_icmp_phase_rx_seen, int, 0444);
+module_param_named(icmp_phase_tx_seen, en75_icmp_phase_tx_seen, int, 0444);
+module_param_named(icmp_phase_tx_match, en75_icmp_phase_tx_match, int, 0444);
+module_param_named(icmp_phase_tx_miss, en75_icmp_phase_tx_miss, int, 0444);

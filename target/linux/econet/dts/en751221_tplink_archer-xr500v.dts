/dts-v1/;

#include "en751221.dtsi"

/ {
	model = "TP-Link Archer XR500v v1";
	compatible = "tplink,archer-xr500v", "econet,en751221";

	memory@0 {
		device_type = "memory";
		reg = <0x00000000 0x8000000>;
	};

	chosen {
		stdout-path = "/serial@1fbf0000:115200";
		/*
		 * UBI overlay: rootfs1 partition is now a UBI device (label "ubi"
		 * triggers OpenWrt's auto-attach patch). The squashfs lives in
		 * UBI volume "rootfs"; UBIFS overlay at "rootfs_data" is created
		 * by mount_root on first boot.
		 */
		bootargs = "ubi.mtd=ubi root=ubi0:rootfs rootfstype=squashfs";
	};
};

&nand {
	status = "okay";
	econet,bmt;

	partitions {
		compatible = "fixed-partitions";
		#address-cells = <1>;
		#size-cells = <1>;

		/* XR500v partition layout (from /proc/mtd stock firmware) */

		partition@0 {
			label = "boot";
			reg = <0x0 0x40000>;
			read-only;
		};

		partition@40000 {
			label = "romfile";
			reg = <0x40000 0x40000>;
			read-only;
		};

		partition@80000 {
			label = "kernel";
			reg = <0x80000 0x300000>;
		};

		partition@380000 {
			/*
			 * Slot A rootfs holds the stock OEM squashfs (LZMA-compressed).
			 * Renamed from "rootfs" to "rootfs_stock" so OpenWrt's
			 * mtdsplit-support patch (drivers/mtd/mtdpart.c) does NOT match
			 * this partition by name — otherwise mtdsplit_squashfs runs on
			 * mtd3 (stock) and the global rootfs_found flag prevents it
			 * from running on mtd7 (rootfs1) where we actually need the
			 * overlay split.
			 */
			label = "rootfs_stock";
			reg = <0x380000 0x1000000>;
			read-only;
		};

		partition@1380000 {
			label = "misc";
			reg = <0x1380000 0x480000>;
			/*
			 * TODO: XR500v NVMEM layout for WiFi EEPROM and MAC
			 * addresses is not yet mapped. Will be filled in once
			 * we have a running kernel and can dump the partition.
			 * For PoC Phase 1, leaving as plain partition.
			 */
		};

		partition@1800000 {
			label = "kernel1";
			reg = <0x1800000 0x300000>;
		};

		partition@1b00000 {
			/*
			 * Slot B "rootfs" — labeled "ubi" so the OpenWrt
			 * auto-attach patch (490-ubi-auto-attach-mtd-device-named-
			 * ubi-or-data-on-boot) runs UBI on this partition at boot.
			 * Image build uses Build/append-ubi to put a "rootfs"
			 * (squashfs ro) volume here; rootfs_data (ubifs rw) is
			 * created by mount_root on first boot.
			 */
			label = "ubi";
			reg = <0x1b00000 0x1000000>;
		};

		partition@2b00000 {
			label = "others";
			reg = <0x2b00000 0x4e0000>;
		};

		partition@2fe0000 {
			label = "bootflag";
			reg = <0x2fe0000 0x20000>;
		};

		/*
		 * NOTE: OpenWrt UBI partition NOT defined for PoC scope.
		 * The unused 0x3000000-0x7000000 (64MB) on the NAND likely
		 * contains BMT (Bad Block Table) and other bldr-managed data.
		 * Defining a UBI partition there without verifying could
		 * overwrite BMT and brick the device. Revisit in Phase 2+
		 * once we dump and analyze the actual contents.
		 *
		 * partition@3000000 {
		 *	label = "openwrt_ubi";
		 *	reg = <0x3000000 0x3ec0000>;
		 * };
		 */
	};
};

&gmac0 {
	status = "okay";
	/*
	 * TODO: MAC address NVMEM source not yet identified for XR500v.
	 * Will be wired once misc partition NVMEM layout is known.
	 * nvmem-cells = <&macaddr_xr500v 0>;
	 * nvmem-cell-names = "mac-address";
	 */
};

/*
 * iter 2: PCIe disabled to isolate kernel crash at EPC=0x81fb91a8 BADVADDR=0xc0000000.
 * Hipótesis Codex: ioremap del controlador PCIe o BAR del MT76 cae en KSEG2 y el
 * acceso falla con bus error porque el hardware XR500v no responde como espera el
 * driver econet,en7528-pcie (PHY/GPIO reset/chip diferente al VR1200v).
 * Si este boot llega a shell por UART, re-habilitar pcie0/pcie1 incrementalmente.
 */
&pcie0 { status = "disabled"; };
&pcie1 { status = "disabled"; };

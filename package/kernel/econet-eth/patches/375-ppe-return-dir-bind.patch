+/* Return-direction lookup for WAN->LAN ACK/data. The original key is pre-DNAT
+ * (server -> WAN IP), while the TX egress frame is post-DNAT (server -> LAN
+ * client), so match by source + ports and reject our own post-DNAT egress echo. */
+static int en75_ppe_rxslot_lookup_return(u32 nsip, u32 ndip, u16 nsport, u16 ndport)
+{
+	int i, idx = -1;
+
+	for (i = 0; i < 32; i++) {
+		if (!en75_rx_ring[i].valid || en75_rx_ring[i].sip != nsip ||
+		    en75_rx_ring[i].sport != nsport)
+			continue;
+		if (en75_rx_ring[i].dip == ndip)
+			continue;			/* post-DNAT egress echo */
+		idx = i;
+		if (en75_rx_ring[i].dport == ndport)
+			break;				/* exact if NAT preserved port */
+	}
+	return idx;
+}

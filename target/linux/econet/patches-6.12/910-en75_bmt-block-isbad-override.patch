Subject: en75_bmt: override mtd block_isbad/markbad so UBI doesn't depend on raw OOB

--- a/drivers/mtd/nand/en75_bmt.c	2026-05-07 06:27:53.777258060 +0000
+++ b/drivers/mtd/nand/en75_bmt.c	2026-05-07 06:28:50.150812974 +0000
@@ -1360,13 +1360,37 @@
 
 static struct en75_bmt_m en75_bmt_m;
 
+/*
+ * en75_bmt has shrunk mtd->size via the BBT shift, so any in-range block
+ * is good by construction. Skip the raw-OOB-byte-0 check that mis-flags
+ * blocks whose OOB carries residue from prior writes.
+ */
+static int en75_block_isbad(struct mtd_info *mtd, loff_t ofs)
+{
+	if (ofs < 0 || ofs >= mtd->size)
+		return 1;
+	return 0;
+}
+
+/*
+ * No-op markbad: don't stamp OOB[0..1]=0x00 with persistent false markers.
+ * UBI's own bad-PEB tracking handles wear-out.
+ */
+static int en75_block_markbad(struct mtd_info *mtd, loff_t ofs)
+{
+	return 0;
+}
+
 static int pub_init(struct device_node *np)
 {
 	int ret;
 
 	ret = w_init(&en75_bmt_m, np);
-	if (!ret)
+	if (!ret) {
 		w_sync_tables(&en75_bmt_m);
+		en75_bmt_m.mtk->mtd->_block_isbad = en75_block_isbad;
+		en75_bmt_m.mtk->mtd->_block_markbad = en75_block_markbad;
+	}
 	return ret;
 }
 
